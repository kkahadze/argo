    <TIER LANG_REF="xmf" LINGUISTIC_TYPE_REF="phrase" TIER_ID="A_phrase-txt-xmf">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2_flexid_08652c87-40e6-43b8-9864-8926a940c630"
                TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>- ქუჩუჩის ... ასე ვარე ქუჩუჩიშ სეზონი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann95_flexid_e5c3b2e4-1c63-4906-96d4-3f68ac6a0058"
                TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts5">
                <ANNOTATION_VALUE>მინ ტრადიციათჷ ჭუნა ვარდა ობინეხეეს, ვარდა ორტვინს ეშმადვანა, მარა მა ბჩუანქ, მუშენდა მოკო თენა ბრელქ ქოძირასი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann372_flexid_e8737ff1-e701-4452-8071-d8aa17b9b329"
                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts7">
                <ANNOTATION_VALUE>ქუჩუჩ რე უმოსო სამარგალოშ დო გურიაშჷ ტრადიცია.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann470_flexid_1b813906-661d-49ce-b8ea-30000f05865b"
                TIME_SLOT_REF1="ts8" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>კალანდობას კულტურა ხოლო უმოსო ჩქინ რე, ქოიჩქუნა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann598_flexid_ee2f9e35-0ee2-4bd6-bf5e-f6583aeda230"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>დო მარგალ კოჩი, სამარგალოს ახალწანა დო კუჩხა კალანდა ვარდუ ქუჩუჩიშ უმშო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann750_flexid_548dbc88-6534-4843-b40a-2b3094a7b9ef"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ანა თხირშე რე კეთებულჷ, მარა შურამიაშე ხოლო ორთუდეს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann878_flexid_35589bac-d071-4697-add0-9678387c9d4f"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>ასე ჩქი ქიგუაჸუნით გიშაძიებას, სოურე მორთ თენა, მუს ნიშნენც.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1035_flexid_dd40e470-140a-48aa-8009-3e53ac493c5b"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>რე ჟირ ვერსია.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1087_flexid_8cfe88ef-eccc-41a7-8057-9b70e619ba3b"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>ართ ვერსიათ ბასილი, წმინდა ბასილიშ ბჟაკე რენია იჩიებუნა დო თინა მოხვარნანია ახალწანაშ სერს თუ ქირსეშ სერს დო თიშენ რენია.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1395_flexid_4c2c982f-f8d0-447c-b0b3-40892892005c"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>მაჟია ვერსია ხოლო არსებენს, ათაქ ხო უშკურეფს გიამარგენა, დუც ხოლო თეს, ანა ნიშნენსია პლანეტებიშჷ, დედამიწაშ გილულასჷ ბჟაშჷ გარშემო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1688_flexid_8c58b307-8144-44ca-bdfe-b31621196540"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>მუკი მუკი არის გარშემო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1715_flexid_94f2137b-2cba-499a-a16f-5e74b3660f8e"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ათაქ უღუ უშკურეფი, ვარდა მუდგაინ ხილი, დუც ხოლო უღუ დო ათენა ნიშნენსია, პლანეტებიშ ბჟაშ გარშემო გილულას დო ათნა ხოლო ჩხორია რე.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2022_flexid_30134b8d-0bd4-463e-9372-e677c19cb52b"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>თქვა ქოიჩქჷნანო ჩხორია მურე?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2119_flexid_305d7e9c-ced5-49a4-ac68-1446fcccced7"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>მურე ჩხორია.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2164_flexid_634ecee3-15c5-4fac-9ebb-23272f3e5225"
                TIME_SLOT_REF1="ts31" TIME_SLOT_REF2="ts32">
                <ANNOTATION_VALUE>- ქიფჩიათ თიშე ხოლო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2229_flexid_47329956-ac8d-42cf-baf7-c54f4aa1c700"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>-ჩხორია ქართულად არი მზის სხივი, ათენეფ რე ჩხორიეფი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2337_flexid_2808bbf4-76f5-49ec-9c85-1a61b2c99648"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>-აი მუ დროს დუთმოდგუნდჷ თე ქუჩუჩის მარგაჲ კოჩი?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2471_flexid_e5fd880a-3efe-475a-b57e-e22e24ec3c42"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts38">
