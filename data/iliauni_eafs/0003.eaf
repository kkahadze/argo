    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4" ANNOTATION_REF="ann2_flexid_08652c87-40e6-43b8-9864-8926a940c630">
                <ANNOTATION_VALUE>There is a tradition of Kuchuchi [=Chichilaki, a Christmas tree made of hazelnut branches]. Now, it is not a Kuchuchi season.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann97" ANNOTATION_REF="ann95_flexid_e5c3b2e4-1c63-4906-96d4-3f68ac6a0058">
                <ANNOTATION_VALUE>Sometimes, following the tradition, it is either burnt in a vineyard or placed in a vegetable garden but I keep them because I want many people to see it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann374" ANNOTATION_REF="ann372_flexid_e8737ff1-e701-4452-8071-d8aa17b9b329">
                <ANNOTATION_VALUE>Chcichilaki is more traditional in Samegrelo and Guria.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann472" ANNOTATION_REF="ann470_flexid_1b813906-661d-49ce-b8ea-30000f05865b">
                <ANNOTATION_VALUE>You know tradition of "Kalanda" is predominantly ours.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann600" ANNOTATION_REF="ann598_flexid_ee2f9e35-0ee2-4bd6-bf5e-f6583aeda230">
                <ANNOTATION_VALUE>A Megrelian man in Samegrelo, can hardly be imagined without a chichilaki on the New Year's Day, on First Footing, nad on Kalanda (Christmas).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann752" ANNOTATION_REF="ann750_flexid_548dbc88-6534-4843-b40a-2b3094a7b9ef">
                <ANNOTATION_VALUE>This one has been made of a hazelnut but it is also made of a tree of heaven.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann880" ANNOTATION_REF="ann878_flexid_35589bac-d071-4697-add0-9678387c9d4f">
                <ANNOTATION_VALUE>Now, we have to explore where chichilaki has come from, what it means.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1037" ANNOTATION_REF="ann1035_flexid_dd40e470-140a-48aa-8009-3e53ac493c5b">
                <ANNOTATION_VALUE>There are two versions.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1089" ANNOTATION_REF="ann1087_flexid_8cfe88ef-eccc-41a7-8057-9b70e619ba3b">
                <ANNOTATION_VALUE>According to one version, it is said to be St Basil's hear and that it will bless us on the New Year's Day on Christmas, and, hence it is.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1397" ANNOTATION_REF="ann1395_flexid_4c2c982f-f8d0-447c-b0b3-40892892005c">
                <ANNOTATION_VALUE>There is another version: the fact that apples are fixed on top of it implies the movement of planets, of the earth around the sun.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1690" ANNOTATION_REF="ann1688_flexid_8c58b307-8144-44ca-bdfe-b31621196540">
                <ANNOTATION_VALUE>Muki-muki means around.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1717" ANNOTATION_REF="ann1715_flexid_94f2137b-2cba-499a-a16f-5e74b3660f8e">
                <ANNOTATION_VALUE>Here on its sides, there are apples or some other fruit, there are also some on top of it; they say that this symbolizes the movement of planets around the sun, and, besides, "Chkhoria" [=sun ray].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2024" ANNOTATION_REF="ann2022_flexid_30134b8d-0bd4-463e-9372-e677c19cb52b">
                <ANNOTATION_VALUE>Do you know what "chkhoria" means?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2121" ANNOTATION_REF="ann2119_flexid_305d7e9c-ced5-49a4-ac68-1446fcccced7">
                <ANNOTATION_VALUE>What is "chkhoria"?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2166" ANNOTATION_REF="ann2164_flexid_634ecee3-15c5-4fac-9ebb-23272f3e5225">
                <ANNOTATION_VALUE>Let's talk about it as well.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2231" ANNOTATION_REF="ann2229_flexid_47329956-ac8d-42cf-baf7-c54f4aa1c700">
                <ANNOTATION_VALUE>Chkhoria denotes a sun ray. These are chkhoria [=shaved parts of a chichilaki].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2339" ANNOTATION_REF="ann2337_flexid_2808bbf4-76f5-49ec-9c85-1a61b2c99648">
                <ANNOTATION_VALUE>When did a Megrelian individual installed a chichilaki?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2473" ANNOTATION_REF="ann2471_flexid_e5fd880a-3efe-475a-b57e-e22e24ec3c42">
                <ANNOTATION_VALUE>Well, it happened that a village had a master of chichilaki.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2601" ANNOTATION_REF="ann2599_flexid_b87e9f58-26c8-411b-9f9f-ebd81aa4d590">
                <ANNOTATION_VALUE>He collected branches, stickes, till the end of August, and, then he began; he knew when to begin shaving a chichilaki.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2903" ANNOTATION_REF="ann2901_flexid_6b46eca6-85b9-4cd2-83b1-f751c871f537">
                <ANNOTATION_VALUE>Because, if you begin latee, you will fail.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3010" ANNOTATION_REF="ann3008_flexid_9464bfaa-6706-4314-b5dc-13617318446d">
                <ANNOTATION_VALUE>People begin decorating it in the period prior to the New Year's Day.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3098" ANNOTATION_REF="ann3096_flexid_0cfb03a4-4a6c-41ee-9313-396f9c91d68b">
                <ANNOTATION_VALUE>What I also remember from my childhood is that it had hazelnut branches and that itwas decorated with candies.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3320" ANNOTATION_REF="ann3318_flexid_08a0ed31-8aaa-4ae7-a113-bc405a78dd1a">
                <ANNOTATION_VALUE>My mother said that a chichilaki was the same in her childhood.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3452" ANNOTATION_REF="ann3450_flexid_094e5481-6495-407c-aa6c-26d4a15dbb04">
                <ANNOTATION_VALUE>This tradition has not changed considerably.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="ka-Brai" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-ka-Brai">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5" ANNOTATION_REF="ann2_flexid_08652c87-40e6-43b8-9864-8926a940c630">
                <ANNOTATION_VALUE>ქუჩუჩის(=ჩიჩილაკის) [დადგმის ტრადიცია არსებობს]. ახლა არ არის ქუჩუჩის (=ჩიჩილაკის) სეზონი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann98" ANNOTATION_REF="ann95_flexid_e5c3b2e4-1c63-4906-96d4-3f68ac6a0058">
                <ANNOTATION_VALUE>ზოგჯერ ტრადიციულად [ტრადიციის მიხედვით], წვავენ ან ვენახში, ან ბოსტანში დებენ, მაგრამ მე ვინახავ, იმიტომ, რომ მინდა ეს ბევრმა ნახოს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann375" ANNOTATION_REF="ann372_flexid_e8737ff1-e701-4452-8071-d8aa17b9b329">
                <ANNOTATION_VALUE>ჩიჩილაკი არის უფრო სამეგრელოსა და გურიის ტრადიცია.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann473" ANNOTATION_REF="ann470_flexid_1b813906-661d-49ce-b8ea-30000f05865b">
                <ANNOTATION_VALUE>კალანდობის კულტურაც უფრო ჩვენია, იცით.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann601" ANNOTATION_REF="ann598_flexid_ee2f9e35-0ee2-4bd6-bf5e-f6583aeda230">
                <ANNOTATION_VALUE>მეგრელი კაცი სამეგრელოში, ახალ წელს, კუჩხაზე (=ფეხობა დღეს) და კალანდას არ იყო ჩიჩილაკის უმისოდ (=გარეშე).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann753" ANNOTATION_REF="ann750_flexid_548dbc88-6534-4843-b40a-2b3094a7b9ef">
                <ANNOTATION_VALUE>ეს თხილისგანაა გაკეთებული, მაგრამ შურამიასგან (=ხემყრალასგან) კიდევ აკეთებდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann881" ANNOTATION_REF="ann878_flexid_35589bac-d071-4697-add0-9678387c9d4f">
                <ANNOTATION_VALUE>ახლა ჩვენ გავყევით (=დავადექით) გამოძიებას, საიდან მოვიდა [ჩიჩილაკი], რას ნიშნავს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1038" ANNOTATION_REF="ann1035_flexid_dd40e470-140a-48aa-8009-3e53ac493c5b">
                <ANNOTATION_VALUE>არის ორი ვერსია.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1090" ANNOTATION_REF="ann1087_flexid_8cfe88ef-eccc-41a7-8057-9b70e619ba3b">
                <ANNOTATION_VALUE>ერთი ვერსიით, ბასილი, წმინდა ბასილის წვერი არისო ამბობენ და ის გვეხმარებაო (=შეგვეწევაო) ახალი წლის ღამეს  თუ ქრისტეშობის ღამეს და იმიტომ არისო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1398" ANNOTATION_REF="ann1395_flexid_4c2c982f-f8d0-447c-b0b3-40892892005c">
                <ANNOTATION_VALUE>მეორე ვერსიაც არსებობს: აქ ხომ ამაგრებენ ვაშლებს, თავზეც, ამას [=ვაშლებს ამაგრებენ], ეს ნიშნავსო პლანეტების, დედამიწის სვლას მზის გარშემო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1691" ANNOTATION_REF="ann1688_flexid_8c58b307-8144-44ca-bdfe-b31621196540">
                <ANNOTATION_VALUE>მუკი-მუკი არის (=ნიშნავს) -გარშემო[ს].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1718" ANNOTATION_REF="ann1715_flexid_94f2137b-2cba-499a-a16f-5e74b3660f8e">
                <ANNOTATION_VALUE>აქ [=გვერდზე] აქვს ვაშლები, ან რამე ხილი, თავზეც აქვს და ეს ნიშნავსო პლანეტების მზის გარშემო სიარულს და ესეც არის  - ჩხორია (=მზის სხივი).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2025" ANNOTATION_REF="ann2022_flexid_30134b8d-0bd4-463e-9372-e677c19cb52b">
                <ANNOTATION_VALUE>თქვენ იცით ჩხორია რა არის (=რას ნიშნავს)?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2122" ANNOTATION_REF="ann2119_flexid_305d7e9c-ced5-49a4-ac68-1446fcccced7">
                <ANNOTATION_VALUE>რა არის ჩხორია?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2167" ANNOTATION_REF="ann2164_flexid_634ecee3-15c5-4fac-9ebb-23272f3e5225">
                <ANNOTATION_VALUE>ვისაუბროთ მაგაზეც.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2232" ANNOTATION_REF="ann2229_flexid_47329956-ac8d-42cf-baf7-c54f4aa1c700">
                <ANNOTATION_VALUE>ჩხორია ქართულად არის მზის სხივი, ესენი არის ჩხორიები (=იგულისხ. ჩიჩილაკის ნათალი მასა)</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2340" ANNOTATION_REF="ann2337_flexid_2808bbf4-76f5-49ec-9c85-1a61b2c99648">
                <ANNOTATION_VALUE>აი, რა დროს (=როდის) დგამდა ამ ჩიჩილაკს მეგრელი კაცი?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2474" ANNOTATION_REF="ann2471_flexid_e5fd880a-3efe-475a-b57e-e22e24ec3c42">
                <ANNOTATION_VALUE>ახლა როგორ იყო: მექუჩუჩე (=ჩიჩილაკის გამომთლელი) სოფელს  ჰყავდა,  ოფუთეს [=სოფელს] ჰყავდა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2602" ANNOTATION_REF="ann2599_flexid_b87e9f58-26c8-411b-9f9f-ebd81aa4d590">
                <ANNOTATION_VALUE>აგვისტოს ბოლომდე აგროვებდა ამ ტოტებს, კეტებს (=ჯოხებს) და იწყებდა მერე - თავის დროზე. იცოდა როდის უნდა დაეწყო ამის გათლა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2904" ANNOTATION_REF="ann2901_flexid_6b46eca6-85b9-4cd2-83b1-f751c871f537">
                <ANNOTATION_VALUE>იმიტომ, რომ გვიან [თუ] გააკეთე, არ გამოგივა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3011" ANNOTATION_REF="ann3008_flexid_9464bfaa-6706-4314-b5dc-13617318446d">
                <ANNOTATION_VALUE>ახალი წლის პერიოდში იწყებდნენ გაწყობას (=მორთვას).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3099" ANNOTATION_REF="ann3096_flexid_0cfb03a4-4a6c-41ee-9313-396f9c91d68b">
                <ANNOTATION_VALUE>მე ბავშვობაში კიდევ მახსოვს  ჰქონდა თხილის ტოტები,  ხილი[თ] და კამფეტები[თ] იყო ამის მორთვა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3321" ANNOTATION_REF="ann3318_flexid_08a0ed31-8aaa-4ae7-a113-bc405a78dd1a">
                <ANNOTATION_VALUE>დედაჩემიც ამბობდა, [რომ] ასეთი იყო [ჩიჩილაკი] მისი ბავშვობის დროსაც.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3453" ANNOTATION_REF="ann3450_flexid_094e5481-6495-407c-aa6c-26d4a15dbb04">
                <ANNOTATION_VALUE>დიდად ეს ტრადიცია შეცვლილი არ არის.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="xmf-fonipa" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-xmf-fonipa">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6" ANNOTATION_REF="ann2_flexid_08652c87-40e6-43b8-9864-8926a940c630">
                <ANNOTATION_VALUE>kut͡ʃut͡ʃis ɑsɛ vɑrɛ kut͡ʃut͡ʃiʃ sɛzɔni.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann99" ANNOTATION_REF="ann95_flexid_e5c3b2e4-1c63-4906-96d4-3f68ac6a0058">
                <ANNOTATION_VALUE>min tʼrɑdit͡siɑtə t͡ʃʼunɑ vɑrdɑ ɔbinɛxɛɛs, vɑrdɑ ɔrtʼvins ɛʃmɑdvɑnɑ, mɑrɑ mɑ bt͡ʃuɑnk, muʃɛndɑ mɔkʼɔ tɛnɑ brɛlk kɔd͡zirɑsi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann376" ANNOTATION_REF="ann372_flexid_e8737ff1-e701-4452-8071-d8aa17b9b329">
                <ANNOTATION_VALUE>kut͡ʃut͡ʃ rɛ umɔsɔ sɑmɑrɡɑlɔʃ dɔ ɡuriɑʃə tʼrɑdit͡siɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann474" ANNOTATION_REF="ann470_flexid_1b813906-661d-49ce-b8ea-30000f05865b">
                <ANNOTATION_VALUE>kʼɑlɑndɔbɑs kʼultʼurɑ xɔlɔ umɔsɔ t͡ʃkin rɛ, kɔit͡ʃkunɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann602" ANNOTATION_REF="ann598_flexid_ee2f9e35-0ee2-4bd6-bf5e-f6583aeda230">
                <ANNOTATION_VALUE>dɔ mɑrɡɑl kʼɔt͡ʃi, sɑmɑrɡɑlɔs ɑxɑlt͡sʼɑnɑ dɔ kʼut͡ʃxɑ kʼɑlɑndɑ vɑrdu kut͡ʃut͡ʃiʃ umʃɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann754" ANNOTATION_REF="ann750_flexid_548dbc88-6534-4843-b40a-2b3094a7b9ef">
                <ANNOTATION_VALUE>ɑnɑ txirʃɛ rɛ kʼɛtɛbulə, mɑrɑ ʃurɑmiɑʃɛ xɔlɔ ɔrtudɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann882" ANNOTATION_REF="ann878_flexid_35589bac-d071-4697-add0-9678387c9d4f">
                <ANNOTATION_VALUE>ɑsɛ t͡ʃki kiɡuɑʔunit ɡiʃɑd͡ziɛbɑs, sɔurɛ mɔrt tɛnɑ, mus niʃnɛnt͡s.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1039" ANNOTATION_REF="ann1035_flexid_dd40e470-140a-48aa-8009-3e53ac493c5b">
                <ANNOTATION_VALUE>rɛ ʒir vɛrsiɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1091" ANNOTATION_REF="ann1087_flexid_8cfe88ef-eccc-41a7-8057-9b70e619ba3b">
                <ANNOTATION_VALUE>ɑrt vɛrsiɑt bɑsili, t͡sʼmindɑ bɑsiliʃ bʒɑkʼɛ rɛniɑ it͡ʃiɛbunɑ dɔ tinɑ mɔxvɑrnɑniɑ ɑxɑlt͡sʼɑnɑʃ sɛrs tu kirsɛʃ sɛrs dɔ tiʃɛn rɛniɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1399" ANNOTATION_REF="ann1395_flexid_4c2c982f-f8d0-447c-b0b3-40892892005c">
                <ANNOTATION_VALUE>mɑʒiɑ vɛrsiɑ xɔlɔ ɑrsɛbɛns, ɑtɑk xɔ uʃkʼurɛps ɡiɑmɑrɡɛnɑ, dut͡s xɔlɔ tɛs, ɑnɑ niʃnɛnsiɑ pʼlɑnɛtʼɛbiʃə, dɛdɑmit͡sʼɑʃ ɡilulɑsə bʒɑʃə ɡɑrʃɛmɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1692" ANNOTATION_REF="ann1688_flexid_8c58b307-8144-44ca-bdfe-b31621196540">
                <ANNOTATION_VALUE>mukʼi mukʼi ɑris ɡɑrʃɛmɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1719" ANNOTATION_REF="ann1715_flexid_94f2137b-2cba-499a-a16f-5e74b3660f8e">
                <ANNOTATION_VALUE>ɑtɑk uɣu uʃkʼurɛpi, vɑrdɑ mudɡɑin xili, dut͡s xɔlɔ uɣu dɔ ɑtɛnɑ niʃnɛnsiɑ, pʼlɑnɛtʼɛbiʃ bʒɑʃ ɡɑrʃɛmɔ ɡilulɑs dɔ ɑtnɑ xɔlɔ t͡ʃxɔriɑ rɛ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2026" ANNOTATION_REF="ann2022_flexid_30134b8d-0bd4-463e-9372-e677c19cb52b">
                <ANNOTATION_VALUE>tkvɑ kɔit͡ʃkənɑnɔ t͡ʃxɔriɑ murɛ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2123" ANNOTATION_REF="ann2119_flexid_305d7e9c-ced5-49a4-ac68-1446fcccced7">
                <ANNOTATION_VALUE>murɛ t͡ʃxɔriɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2168" ANNOTATION_REF="ann2164_flexid_634ecee3-15c5-4fac-9ebb-23272f3e5225">
                <ANNOTATION_VALUE>kipt͡ʃiɑt tiʃɛ xɔlɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2233" ANNOTATION_REF="ann2229_flexid_47329956-ac8d-42cf-baf7-c54f4aa1c700">
                <ANNOTATION_VALUE>t͡ʃxɔriɑ kɑrtulɑd ɑri mzis sxivi, ɑtɛnɛp rɛ t͡ʃxɔriɛpi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2341" ANNOTATION_REF="ann2337_flexid_2808bbf4-76f5-49ec-9c85-1a61b2c99648">
                <ANNOTATION_VALUE>ɑi mu drɔs dutmɔdɡundə tɛ kut͡ʃut͡ʃis mɑrɡɑj kʼɔt͡ʃi?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2475" ANNOTATION_REF="ann2471_flexid_e5fd880a-3efe-475a-b57e-e22e24ec3c42">
                <ANNOTATION_VALUE>ɑsɛ mut͡ʃʼɔ rdu, mɛkut͡ʃut͡ʃɛ sɔpɛlsə ʔundu, ɔputɛs ʔundu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2603" ANNOTATION_REF="ann2599_flexid_b87e9f58-26c8-411b-9f9f-ebd81aa4d590">
                <ANNOTATION_VALUE>ɑrɡusɔʃ bɔlɔʃɑx ʃɑqʼɑrɑndu ɑtɛ nɔʔɛlɛpsi, kʼɛtʼɛpsə dɔ it͡ʃʼqʼɑnd ukʼuli, muʃ pʼɛriɔdis ut͡ʃkud muʒɑm dit͡ʃʼqʼukʼɔ tɛʃ tɔluɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2905" ANNOTATION_REF="ann2901_flexid_6b46eca6-85b9-4cd2-83b1-f751c871f537">
                <ANNOTATION_VALUE>muʃɛndɑ ɡviɑn ɡɑkʼɛti dɑ vɛɡəʃɡɑlɛ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3012" ANNOTATION_REF="ann3008_flexid_9464bfaa-6706-4314-b5dc-13617318446d">
                <ANNOTATION_VALUE>dɔ ɑxɑlt͡sʼɑnɑʃ pʼɛriɔdis it͡ʃʼqʼɑndɛs mɔnt͡sʼqʼuɑlɑs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3100" ANNOTATION_REF="ann3096_flexid_0cfb03a4-4a6c-41ee-9313-396f9c91d68b">
                <ANNOTATION_VALUE>mɑ bɑɣɑnɔbɑs xɔlɔ bʃu txiriʃ nɔʔɛlɛp uɣudu dɔ xilɛpi dɔ kʼɑmpɛtʼɛpi də tɛʃ ɡɔnt͡sʼqʼuɑlɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3322" ANNOTATION_REF="ann3318_flexid_08a0ed31-8aaa-4ae7-a113-bc405a78dd1a">
                <ANNOTATION_VALUE>dɔ diɑt͡ʃkim xɔlɔ it͡ʃiɛbudu, tɛnɛri rdə tiʃ bɑɣɑnɔbɑs xɔlɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3454" ANNOTATION_REF="ann3450_flexid_094e5481-6495-407c-aa6c-26d4a15dbb04">
                <ANNOTATION_VALUE>didɔ tɛ tʼrɑdit͡siɑ tirɛl vɑrɛ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
