        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6" ANNOTATION_REF="ann3_flexid_24e5a57b-366c-4c78-9072-925bb8bbaed7">
                <ANNOTATION_VALUE>ɑi, tkvɑ ɑmzɑdɛnt lɑɑrt͡ʃʼɛms.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann72" ANNOTATION_REF="ann69_flexid_8a2489dd-1b50-47f5-9752-fc6f3cf1605c">
                <ANNOTATION_VALUE>ɑi, ɑtɑk ɡɛd͡z ɑsɛ lɑɑrt͡ʃʼɛmi dɔ tɛɛs mut͡ʃʼɔ ɑkʼɛtɛnt.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann204" ANNOTATION_REF="ann201_flexid_1b05fb8a-6b3b-4387-8636-1dd65c33b66d">
                <ANNOTATION_VALUE>ɑi, muʃɛ ɑkʼɛtɛntə dɔ tɛs mu... mɑrɡɑjɛp sɔ mitmiɔɡɑndɛɛs, mus mitmiɔɡɑndɛɛs?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann439" ANNOTATION_REF="ann436_flexid_e9d580af-afe5-448a-8e99-25fe89cb0fba">
                <ANNOTATION_VALUE>ɑɑsɛ kʼin ti bɔʃiʃ t͡ʃʼqʼɔlɔpuɑ rɛ tɛnɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann536" ANNOTATION_REF="ann533_flexid_b45ea23f-b259-4d2f-a5a2-ee7fb08f5436">
                <ANNOTATION_VALUE>sɛrɡi mɑkʼɑlɑtiɑʃ t͡sʼiɡni kɑʃɑmiɔl xɛʃɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann636" ANNOTATION_REF="ann633_flexid_a3ce05c3-c064-4082-b96b-ead4d2a6a618">
                <ANNOTATION_VALUE>tɛk sɑɔt͡sɑrɔ ɑp ɛt͡ʃʼɑpil tɛnɑ dɔ ti t͡sʼiɡʃɛ mut mit͡ʃkən, ɑtɛs mɑxɔlɔ kiɡɛt͡ʃiɛbutə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann870" ANNOTATION_REF="ann867_flexid_71b4c6e2-88fe-4852-ab5f-4825767eeec9">
                <ANNOTATION_VALUE>lɑrt͡ʃʼɛmiʃ bɑzrɔbɑ ʔɔpɛd xɔɔbis.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann958" ANNOTATION_REF="ann955_flexid_03d2f00f-02fa-4c55-91a7-aab28b5bb443">
                <ANNOTATION_VALUE>ɔdɔ ɑtɑvrɛ miʃən pʼirɔvnɛbɑ xɔbʃɑ, bɑzrɔbɑʃɑnə, mɛzɔbɛl mɛzɔbɛls ɔt͡ʃinɑnd, lɑrt͡ʃʼɛm kumɔmd͡ʒumɛvɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1175" ANNOTATION_REF="ann1172_flexid_32fcc014-fd44-4cec-80d4-60b4bcd0ea74">
                <ANNOTATION_VALUE>kɔmʔidiɑ dɔ kumɔmd͡ʒumɛvɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1273" ANNOTATION_REF="ann1270_flexid_ba37a493-926a-4a02-814f-1761664d9085">
                <ANNOTATION_VALUE>ɑtɛ sɑkʼrɑv vɑɔpɛd, tɛnɑ rdə sɑkɔnɛliʃi məkʼɑrtinɑpɑlə instʼrumɛntʼi, nɑmututu, ɛsɛ iɡi, bruɔ inɑ rɛ tɛnɑ, ʒiri, ɔtxi, ɑmʃv, ruɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1597" ANNOTATION_REF="ann1594_flexid_6068fd3d-ebdf-4077-bad3-e11f51b84d16">
                <ANNOTATION_VALUE>bruɔ kʼɑlɑmiɑ rɛ ɑkʼɔskʼvilə tɛnɑ, ɑtɛ ruɔ kʼɑlɑmiɑʃɛ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1724" ANNOTATION_REF="ann1721_flexid_ae2e5945-10f8-4b73-b200-b9d60e49a8a2">
                <ANNOTATION_VALUE>ɑrt ɑrt sɑkʼrɑviɛ ɑtɛnɑ, nɑmut t͡sʼqʼɑɑrs iʃɔlu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1846" ANNOTATION_REF="ann1843_flexid_bb1b564d-95c6-4439-8cf8-2d3cbcf13d1b">
                <ANNOTATION_VALUE>t͡sʼqʼɑr kiɡibɑtu dɔ ukʼul uɣ sɑɔt͡sɑr xmɑ dɔ ɑnɑ xɔlɔ vɛsvɑ..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2042" ANNOTATION_REF="ann2039_flexid_b00a9ada-bac7-4921-a69a-0d0b40476904">
                <ANNOTATION_VALUE>ɑtənɑ rɛ lɑkʼɑt͡siɑj ɛʃvɛbit skʼvili, mɑrɑ tɛʃ ɔkʼɔ rdɑs ɔkʼɔ skʼvili, tɛnɑ vɑkʼɔt͡siɑsi dɔ dud vɛd͡zirɛdɑsə ɔkʼɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2343" ANNOTATION_REF="ann2340_flexid_2591db16-e90a-4929-a074-9f6edca91d8a">
                <ANNOTATION_VALUE>dɑt͡ʃʼqʼɑpu dɔ dɑsɑsrul vɛd͡zirɛdɑs ɔkʼɔ sɔtinə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2453" ANNOTATION_REF="ann2450_flexid_cc424679-ec50-4d94-a75e-595af6df9f90">
                <ANNOTATION_VALUE>ɑtənɑ ɡuɑkʼɛtə dɔ ɑtɛ zɔmɛp mɑ xɔɔ lɑɑp vɑmt͡ʃkəd tɛj dɔ t͡sʼɑrmɔdɡɛnɑ vɑmɣəd mu dən.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2756" ANNOTATION_REF="ann2753_flexid_ce5edf49-6844-4e8b-a855-2c85445966f4">
                <ANNOTATION_VALUE>dɔ t͡sʼɑrmɔɡidɡinɛb, ɑtɛnɑ ɛti bɑɣɑnɑ bɔʃik kumɔrt, dɛmur bid͡ziɑvɑ, tku, muzɛums mɑpuniɑ nɑd͡zirɛpə dɔ t͡sʼɑrmɔidɡin, tɛnɑ tɛk tbilisʃɑ ɡurɑpulɛndə dɔ ukʼul ɑbɑrɛndə ti pʼɛriɔdij midurtumud dɔ tɛnɑ ɑrd͡zɑ duzimudə ɑtɑʃ dinɑxɑɛʃɛ, kutxuu ɔdɔ kumɔmiɣ zɔmɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3420" ANNOTATION_REF="ann3417_flexid_8baabc08-6b9a-4cb9-8d32-fdf07719d982">
                <ANNOTATION_VALUE>ɡuɑkʼɛtit tɛnɑ, ɛnɑ ukʼvɛ nɑɣdɑɑs tinɑ rɛ, mutu rdəni.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3600" ANNOTATION_REF="ann3597_flexid_dc9e036c-684f-4615-810f-a2ebe6f62334">
                <ANNOTATION_VALUE>mɑʒiɑ kuɑt͡ʃukə musə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3674" ANNOTATION_REF="ann3671_flexid_e9456543-7934-44d4-b5f1-b84d192f69c6">
                <ANNOTATION_VALUE>mɑsmɑ - bɑtumur pʼirɔvnɛbɑ də tɛnɑ, ɡvɑr ɡumɔt͡ʃʼqʼɔrd, ɑtɛɛ xɑlxur pɔlkʼlɔrs it͡ʃʼɑrɑndə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3892" ANNOTATION_REF="ann3889_flexid_fbb58d32-8763-4e97-9c8e-f94df9c5c512">
                <ANNOTATION_VALUE>vɑ... vɑ... vɑpʃ ɡvɑr.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3966" ANNOTATION_REF="ann3963_flexid_42dee727-1d3c-4900-9fe1-06315aba11db">
                <ANNOTATION_VALUE>ɔdɔ t͡sʼɑrmɔidɡini, ɛtis kuɑt͡ʃukə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4056" ANNOTATION_REF="ann4053_flexid_3dac2172-277b-42fb-bb9c-607855de5526">
                <ANNOTATION_VALUE>uprɔ st͡sʼɔrɑd, ɡukʼɛti dɔ kimud͡ʒɣɔn tɑurɛnɡɑnəʃɛ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4176" ANNOTATION_REF="ann4173_flexid_88ec050f-0ba2-4370-a815-020a6a14ab6a">
                <ANNOTATION_VALUE>ɑsɛɛ ɑtɛʃii upʼrɑtʼɛsɔbɑ murɛ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4254" ANNOTATION_REF="ann4251_flexid_3c3df33e-5861-4d88-8e4d-2e40a03aeeaf">
                <ANNOTATION_VALUE>tənɑd  mɑɡɑltɔɔ t͡ʃxɔulɛpsə ʃxvɑ xɔnɑrit ud͡zɑxədɛs, kʼuruɛns ʃxvɑ xɔnɑrit, mɔzvɛr... mɔzvɛrɛns ʃxvɑ xɔnɑrit.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4497" ANNOTATION_REF="ann4494_flexid_4be693a3-85fa-431f-85ac-776bbb0a3b5a">
                <ANNOTATION_VALUE>ɔdɔ ɑɑrd͡zɑ də sɑkɔnɛliʃ məkʼɑrtinɑpɑlə dɔ dɑd͡zɑxinɑlə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4602" ANNOTATION_REF="ann4599_flexid_a195a215-c2a8-4fba-bffe-8b4bd48293a0">
                <ANNOTATION_VALUE>ukʼulii mut͡ʃʼɔ sɑlɑmur, t͡ʃʼqʼiʃɛns uɣudɛs iɡivɛt mukʼɑrtinɑpɑli tɛʃi, ukʼul sɑkʼrɑvɔ ɡinirtən tɛʃi, ɡinirt tɛk xɔlɔ miɔɡɑmɑlɔ sɑkʼrɑvɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4865" ANNOTATION_REF="ann4862_flexid_85b49b6b-d8b9-40c8-8347-4aa315ac3077">
                <ANNOTATION_VALUE>ɑsɛ mɑ kimuɔʃvitʼinɑnk tɛɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4951" ANNOTATION_REF="ann4948_flexid_0e7c81ce-5390-4c89-bdb0-9aac3162fef1">
                <ANNOTATION_VALUE>ɑsɛ tkvɑt͡sɑlɔ t͡ʃɑbɛrvɑt, ɑsɛ dinɔbɑruɑtə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5025" ANNOTATION_REF="ann5022_flexid_4dc8b3f9-a74d-4425-b52d-bc08ec9848e7">
                <ANNOTATION_VALUE>ɑtɛk mɑ mut ɡinɔmit tɛ bɑɣɑnɑkə kɔit͡ʃkənɔ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5179" ANNOTATION_REF="ann5176_flexid_8450fad4-7251-4a94-aab5-fca4434a8768">
                <ANNOTATION_VALUE>bɑɣɑnɑs ud͡zɑxək, kəmɑpʼɑtʼi ɡiɔ, inɑ, mu d͡ʒɔxɔ, dɛdɑɑ..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5345" ANNOTATION_REF="ann5342_flexid_7f41870a-2d38-4598-8592-cfbcac8b4b03">
                <ANNOTATION_VALUE>ditʼɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5367" ANNOTATION_REF="ann5364_flexid_f74ca608-0527-4fd2-b617-b73e9d5656a8">
                <ANNOTATION_VALUE>ditʼɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5388" ANNOTATION_REF="ann5385_flexid_05574b0a-b2c6-4e01-ab3d-1be55b8bdc4d">
                <ANNOTATION_VALUE>sɑxɛl xɔlɔ  kɑ...kɑʃmɔmɔt͡ʃirt t͡ʃkɑk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5475" ANNOTATION_REF="ann5472_flexid_54a22310-0219-42bf-94bc-48c63a1502ae">
                <ANNOTATION_VALUE>,,dilɑ mʃvidɔbisɑ sɑkɑrtvɛlɔʃɑ’’ ʔɔpɛ mɔt͡sʼvɛul dɔ dɔmrɛkʼ ɑxɑl inɑs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5625" ANNOTATION_REF="ann5622_flexid_95d09338-a196-49ac-8d0c-5a75694f190b">
                <ANNOTATION_VALUE>ɔdɔ dɛmur bid͡ziɑvɑ, t͡ʃʼumɛ ɔt͡ʃʼmɑrɛs kɔrt͡ʃɔdəniɑɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5741" ANNOTATION_REF="ann5738_flexid_6437114d-dcde-4457-8dde-de32cf8ecba7">
                <ANNOTATION_VALUE>muʃɛni?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5755" ANNOTATION_REF="ann5752_flexid_22684baa-3c82-440e-9aa3-0d9230850458">
                <ANNOTATION_VALUE>mudɡɑrɛn mɔkʼɔn tik vɑtku dɔ dɔirɛkʼənkiɑ dɔ dɔmrɛkʼ vitiʃ ɡvɛrdis.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5969" ANNOTATION_REF="ann5966_flexid_3dd21f99-3557-4787-98e7-1da489d66e41">
                <ANNOTATION_VALUE>dɛmur bid͡ziɑvɑ, ɑsɛ kɛmɛrtiɑ, tʼɛlɛvizɔr t͡ʃɑrtiɑ, mit͡sʼu dɔ mukʼəvɔd͡ʒiniɔ, ɑmɑr kɔvd͡zir.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6197" ANNOTATION_REF="ann6194_flexid_991d70a7-9d4e-45de-aaa3-025807d9264c">
                <ANNOTATION_VALUE>dɔ t͡sʼɑrmɔidɡin, t͡ʃkim nɑkʼɛtɛb t͡ʃɔnɡurit dɔ ɑtɛ t͡ʃɛlɑ vɑrduɔ bid͡ziɑ miɔɡən, mɑ ɑtɑk t͡ʃilɑmurt͡s imɡɑrdi,  ti dɔnɛʃɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6490" ANNOTATION_REF="ann6487_flexid_5ca75486-a89e-4faa-ae80-dabec6841c6f">
                <ANNOTATION_VALUE>xɔ kəɡɑxiɔluɑ ɡɛmɔrɑɡɑdu tɛvrɛɡɑnʃɛ, mu d͡ʒɔxɔmɑk-ut͡sʼii.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6657" ANNOTATION_REF="ann6654_flexid_ee71321e-2189-4ae3-bf5e-056e1c96e276">
                <ANNOTATION_VALUE>ɑtɛnɑt rtuliɛ, mɑrɑ ti dɔnɛʃɑ kimiɔɡ dɔ kʼɑkʼɑlɛ dixɑj ʒirxɔlɔj t͡ʃɑbɛrvɑ xɔlɔ [rdə dɔ].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6871" ANNOTATION_REF="ann6868_flexid_dd91a44a-97e0-4949-a7c9-80e575c133f8">
                <ANNOTATION_VALUE>tɛnɑ ird sɔdɡɑdnə ɑtɑvrɛ t͡sʼɑlɛnd͡ʒixɑʃ rɑiɔnəʃɑ, tid͡ʒɡuɑ dɑintʼɛrɛsɛbuliɛ tɛnɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7048" ANNOTATION_REF="ann7045_flexid_0fc11a52-ad14-4725-a400-01ac7d63c121">
                <ANNOTATION_VALUE>ɔdɔ ɛtɛkə d͡ʒvɛɛʃ t͡ʃʼqʼəʃik dɑɡuru tɛɛnɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7156" ANNOTATION_REF="ann7153_flexid_77842336-346c-4793-aa9f-97b4aa23dc18">
                <ANNOTATION_VALUE>ɑtɛd͡ʒɡuɑ mɔitʼɛrɛs..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7187" ANNOTATION_REF="ann7184_flexid_4005b9a2-6540-4434-92a4-43dcc1759f1e">
                <ANNOTATION_VALUE>ɑis muʃɛ ɑmzɑdɛnt, ɑn mɑsɑjɑ muijɛ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7312" ANNOTATION_REF="ann7309_flexid_d5ef5397-f5d6-4a9a-9605-384648b391a4">
                <ANNOTATION_VALUE>ɑtənɑ ɔrɛ dɑsurɔ lɑrt͡ʃʼɛms ud͡zɑxənɑ tɛsə mɑrɡɑjurɔ. lɛrt͡sʼɑmi kɔrtulɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7470" ANNOTATION_REF="ann7467_flexid_960a5759-3e97-4a68-b39f-0df9e87521b8">
                <ANNOTATION_VALUE>lɑrt͡ʃʼɛmiɛ, t͡ʃɑɑns tɛnɑ tɑk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7553" ANNOTATION_REF="ann7550_flexid_37828380-e973-4cc3-b773-e5cb3dda034b">
                <ANNOTATION_VALUE>xvɑrɛndɛs tɛsə iʃi, murɛ tij d͡ʒɔxɔni, binɛxiʃ sinɑ vɑrdən ti drɔsə tɛʃ ɡɑbunɑpɑlɔ, məkʼɑkʼilɑrɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7827" ANNOTATION_REF="ann7824_flexid_f13b9945-7baf-4f8e-b81b-afa4bf3d7be7">
                <ANNOTATION_VALUE>nɑxvilɛns ɡinmɑbunuɑndɛs, kəɡɑdinuɑndɛs ɔsurɛp mindɔrs dɔ t͡ʃɑɑnd tɛnɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8019" ANNOTATION_REF="ann8016_flexid_196eb3e4-ffd1-4a37-86e8-d1d686de4a73">
                <ANNOTATION_VALUE>mɑ vɑmət͡ʃɑns, mɑrɑ ɑtɑk mɛzɔbɛls ut͡ʃɑns ɑrt dixɑs, mɑʒiɑ dixɑs, mudɑ dixɑs t͡ʃɑnsə dɔ ɛtɛurɛɡɑnʃɛ rɛ tɛnɑ mɔɣɑlirə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8314" ANNOTATION_REF="ann8311_flexid_766570c9-be2e-41de-bd16-edc6b390574b">
                <ANNOTATION_VALUE>ɛnɑ ʃiʃxvɑt ɡiʃɑɡɔrɛ ɔkʼɔ tɛnɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8405" ANNOTATION_REF="ann8402_flexid_befaf31e-9d2a-420f-91e7-8a3938167a16">
                <ANNOTATION_VALUE>ɔdɔ miɣə ɑsɛ ɔd͡zirɑpɑlɔ, nɑmdɑ pʼirvɛl sɑkʼrɑviɛ, miɔɡɑmɑliɛ vɑmit͡ʃk sɑkʼrɑviʃ sɑxɛl mɑrɡɑlurɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8638" ANNOTATION_REF="ann8635_flexid_d081491a-d434-4cf7-b9d8-19c44f32dc78">
                <ANNOTATION_VALUE>ɔdɔ mɑrɡɑluri, ɑtənɑ mɑrɡɑ... ɑtɛt it͡ʃʼqʼɑpə ɑrd͡zɑ mɑ... inɑ sɑkʼrɑv, mɑrɡɑlurə sɑkʼrɑvɛp.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8825" ANNOTATION_REF="ann8822_flexid_4188f846-9ffa-4ddb-8c06-dce861ec1ce3">
                <ANNOTATION_VALUE>lɑrt͡ʃʼɛmiʃ istʼɔriɑ ɑtɛd͡ʒɡuɑ rɛ mɔkʼlɛt.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
