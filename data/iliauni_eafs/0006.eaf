                <ANNOTATION_VALUE>ხოდა, წარმოიდგინე, მას ვაჩუქე.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4057" ANNOTATION_REF="ann4053_flexid_3dac2172-277b-42fb-bb9c-607855de5526">
                <ANNOTATION_VALUE>უფრო სწორად, გავაკეთე და გავუგზავნე აქეთა მხრიდან (=აქედან).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
