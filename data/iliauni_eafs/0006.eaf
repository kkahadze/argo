                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>აი, მუშე აკეთენთჷ დო თეს მუ... მარგაჲეფ სო მითმიოგანდეეს, მუს მითმიოგანდეეს?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann436_flexid_e9d580af-afe5-448a-8e99-25fe89cb0fba"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts13">
                <ANNOTATION_VALUE>- აასე კინ თი ბოშიშ ჭყოლოფუა რე თენა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann533_flexid_b45ea23f-b259-4d2f-a5a2-ee7fb08f5436"
                TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>სერგი მაკალათიაშ წიგნი ქაშამიოლ ხეშა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann633_flexid_a3ce05c3-c064-4082-b96b-ead4d2a6a618"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>თექ საოცარო აფ ეჭარილ თენა დო თი წიგშე მუთ მიჩქჷნ, ათეს მახოლო ქიგეჩიებუთჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann867_flexid_71b4c6e2-88fe-4852-ab5f-4825767eeec9"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>ლარჭემიშ ბაზრობა ჸოფედ ხოობის.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann955_flexid_03d2f00f-02fa-4c55-91a7-aab28b5bb443"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>ოდო ათავრე მიშჷნ პიროვნება ხობშა, ბაზრობაშანჷ, მეზობელ მეზობელს ოჩინანდ, ლარჭემ ქუმომჯუმევა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1172_flexid_32fcc014-fd44-4cec-80d4-60b4bcd0ea74"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>ქომჸიდია დო ქუმომჯუმევა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1270_flexid_ba37a493-926a-4a02-814f-1761664d9085"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ათე საკრავ ვაოფედ, თენა რდჷ საქონელიში მჷკართინაფალჷ ინსტრუმენტი, ნამუთუთუ, ესე იგი, ბრუო ინა რე თენა, ჟირი, ოთხი, ამშვ, რუო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1594_flexid_6068fd3d-ebdf-4077-bad3-e11f51b84d16"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>ბრუო კალამია რე აკოსკვილჷ თენა, ათე რუო კალამიაშე.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1721_flexid_ae2e5945-10f8-4b73-b200-b9d60e49a8a2"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts31">
                <ANNOTATION_VALUE>ართ ართ საკრავიე ათენა, ნამუთ წყაარს იშოლუ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1843_flexid_bb1b564d-95c6-4439-8cf8-2d3cbcf13d1b"
                TIME_SLOT_REF1="ts32" TIME_SLOT_REF2="ts33">
                <ANNOTATION_VALUE>წყარ ქიგიბათუ დო უკულ უღ საოცარ ხმა დო ანა ხოლო ვესვა..</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2039_flexid_b00a9ada-bac7-4921-a69a-0d0b40476904"
                TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ათჷნა რე ლაკაციაჲ ეშვებით სკვილი, მარა თეშ ოკო რდას ოკო სკვილი, თენა ვაკოციასი დო დუდ ვეძირედასჷ ოკო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2340_flexid_2591db16-e90a-4929-a074-9f6edca91d8a"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>დაჭყაფუ დო დასასრულ ვეძირედას ოკო სოთინჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2450_flexid_cc424679-ec50-4d94-a75e-595af6df9f90"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts41">
                <ANNOTATION_VALUE>ათჷნა გუაკეთჷ დო ათე ზომეფ მა ხოო ლააფ ვამჩქჷდ თეჲ დო წარმოდგენა ვამღჷდ მუ დჷნ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2753_flexid_ce5edf49-6844-4e8b-a855-2c85445966f4"
                TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>დო წარმოგიდგინებ, ათენა ეთი ბაღანა ბოშიქ ქუმორთ, დემურ ბიძიავა, თქუ, მუზეუმს მაფუნია ნაძირეფჷ დო წარმოიდგინ, თენა თექ თბილისშა გურაფულენდჷ დო უკულ აბარენდჷ თი პერიოდიჲ მიდურთუმუდ დო თენა არძა დუზიმუდჷ ათაშ დინახაეშე, ქუთხუუ ოდო ქუმომიღ ზომა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3417_flexid_8baabc08-6b9a-4cb9-8d32-fdf07719d982"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts46">
                <ANNOTATION_VALUE>გუაკეთით თენა, ენა უკვე ნაღდაას თინა რე, მუთუ რდჷნი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3597_flexid_dc9e036c-684f-4615-810f-a2ebe6f62334"
                TIME_SLOT_REF1="ts45" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>მაჟია ქუაჩუქჷ მუსჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3671_flexid_e9456543-7934-44d4-b5f1-b84d192f69c6"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts49">
                <ANNOTATION_VALUE>მასმა - ბათუმურ პიროვნება დჷ თენა, გვარ გუმოჭყორდ, ათეე ხალხურ ფოლკლორს იჭარანდჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3889_flexid_fbb58d32-8763-4e97-9c8e-f94df9c5c512"
                TIME_SLOT_REF1="ts50" TIME_SLOT_REF2="ts51">
                <ANNOTATION_VALUE>ვა... ვა... ვაფშ გვარ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3963_flexid_42dee727-1d3c-4900-9fe1-06315aba11db"
                TIME_SLOT_REF1="ts52" TIME_SLOT_REF2="ts54">
                <ANNOTATION_VALUE>ოდო წარმოიდგინი, ეთის ქუაჩუქჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4053_flexid_3dac2172-277b-42fb-bb9c-607855de5526"
                TIME_SLOT_REF1="ts53" TIME_SLOT_REF2="ts55">
                <ANNOTATION_VALUE>უფრო სწორად, გუკეთი დო ქიმუჯღონ თაურენგანჷშე.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4173_flexid_88ec050f-0ba2-4370-a815-020a6a14ab6a"
                TIME_SLOT_REF1="ts56" TIME_SLOT_REF2="ts60">
                <ANNOTATION_VALUE>ასეე ათეშიი უპრატესობა მურე?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4251_flexid_3c3df33e-5861-4d88-8e4d-2e40a03aeeaf"
                TIME_SLOT_REF1="ts59" TIME_SLOT_REF2="ts62">
                <ANNOTATION_VALUE>ათჷნად  მაგალთოო ჩხოულეფსჷ შხვა ხონარით უძახჷდეს, კურუენს შხვა ხონარით, მოზვერ... მოზვერენს შხვა ხონარით.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4494_flexid_4be693a3-85fa-431f-85ac-776bbb0a3b5a"
                TIME_SLOT_REF1="ts61" TIME_SLOT_REF2="ts63">
                <ANNOTATION_VALUE>ოდო აარძა დჷ საქონელიშ მჷკართინაფალჷ დო დაძახინალჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4599_flexid_a195a215-c2a8-4fba-bffe-8b4bd48293a0"
                TIME_SLOT_REF1="ts64" TIME_SLOT_REF2="ts65">
                <ANNOTATION_VALUE>უკულიი მუჭო სალამურ, ჭყიშენს უღუდეს იგივეთ მუკართინაფალი თეში, უკულ საკრავო გინირთჷნ თეში, გინირთ თექ ხოლო მიოგამალო საკრავო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4862_flexid_85b49b6b-d8b9-40c8-8347-4aa315ac3077"
