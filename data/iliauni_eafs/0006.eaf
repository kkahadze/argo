    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5" ANNOTATION_REF="ann3_flexid_24e5a57b-366c-4c78-9072-925bb8bbaed7">
                <ANNOTATION_VALUE>Well, you make this pipe.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann71" ANNOTATION_REF="ann69_flexid_8a2489dd-1b50-47f5-9752-fc6f3cf1605c">
                <ANNOTATION_VALUE>Here is a pipe; how do you make it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann203" ANNOTATION_REF="ann201_flexid_1b05fb8a-6b3b-4387-8636-1dd65c33b66d">
                <ANNOTATION_VALUE>Well, what is it made of? Where did Megrelians played it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann438" ANNOTATION_REF="ann436_flexid_e9d580af-afe5-448a-8e99-25fe89cb0fba">
                <ANNOTATION_VALUE>It is still thanks to that guy, Dito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann535" ANNOTATION_REF="ann533_flexid_b45ea23f-b259-4d2f-a5a2-ee7fb08f5436">
                <ANNOTATION_VALUE>I happened to get a book by Sergi Makalatia.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann635" ANNOTATION_REF="ann633_flexid_a3ce05c3-c064-4082-b96b-ead4d2a6a618">
                <ANNOTATION_VALUE>He provides an amazing description of a pipe. I'll tell you what I know from the book.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann869" ANNOTATION_REF="ann867_flexid_71b4c6e2-88fe-4852-ab5f-4825767eeec9">
                <ANNOTATION_VALUE>It says that there was pipe fair in Khobi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann957" ANNOTATION_REF="ann955_flexid_03d2f00f-02fa-4c55-91a7-aab28b5bb443">
                <ANNOTATION_VALUE>When someone from here went to the fair in Khobi, his neighbor asked him to buy a pipe for him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1174" ANNOTATION_REF="ann1172_flexid_32fcc014-fd44-4cec-80d4-60b4bcd0ea74">
                <ANNOTATION_VALUE>He asked to buy and bring it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1272" ANNOTATION_REF="ann1270_flexid_ba37a493-926a-4a02-814f-1761664d9085">
                <ANNOTATION_VALUE>It was not a musical instrument. It was a shepherd's pipe to summon livestock back. This is to say there are eight reed stems, two, four, six, eight.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1596" ANNOTATION_REF="ann1594_flexid_6068fd3d-ebdf-4077-bad3-e11f51b84d16">
                <ANNOTATION_VALUE>Eight stems are tied up. It is made of tied up eight stems.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1723" ANNOTATION_REF="ann1721_flexid_ae2e5945-10f8-4b73-b200-b9d60e49a8a2">
                <ANNOTATION_VALUE>It is one of the musical instruments which is soaked in water.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1845" ANNOTATION_REF="ann1843_flexid_bb1b564d-95c6-4439-8cf8-2d3cbcf13d1b">
                <ANNOTATION_VALUE>Water is poured onto it, and, then, it has an amazing sound.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2041" ANNOTATION_REF="ann2039_flexid_b00a9ada-bac7-4921-a69a-0d0b40476904">
                <ANNOTATION_VALUE>It is connected by means of acacia thorns; however; they should be tied up so that they will not dissemble, and the top of the knot is to be visinle.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2342" ANNOTATION_REF="ann2340_flexid_2591db16-e90a-4929-a074-9f6edca91d8a">
                <ANNOTATION_VALUE>A beginning and end of the knot should not be visible anywhere.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2452" ANNOTATION_REF="ann2450_flexid_cc424679-ec50-4d94-a75e-595af6df9f90">
                <ANNOTATION_VALUE>Dito provided me with the sizes, and this is what I made. I couldn't play it and had no idea what it was.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2755" ANNOTATION_REF="ann2753_flexid_ce5edf49-6844-4e8b-a855-2c85445966f4">
                <ANNOTATION_VALUE>Can you imagine? The child, the boy, Dito came and said: "Uncle Demuri, I have seen it at the museum". Imagine, he studied in Tbilisi and then passed exams. In that period, he went to the museum and measured all the pipes from inside; he asked the museum to allow him. And, he brought me the sizes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3419" ANNOTATION_REF="ann3417_flexid_8baabc08-6b9a-4cb9-8d32-fdf07719d982">
                <ANNOTATION_VALUE>I made this. It actually was a copy of the original version.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3599" ANNOTATION_REF="ann3597_flexid_dc9e036c-684f-4615-810f-a2ebe6f62334">
                <ANNOTATION_VALUE>I presented Dito with another one.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3673" ANNOTATION_REF="ann3671_flexid_e9456543-7934-44d4-b5f1-b84d192f69c6">
                <ANNOTATION_VALUE>As for the third one, there was a man from Batumi, I forgot his last name, who recorded folklore.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3891" ANNOTATION_REF="ann3889_flexid_fbb58d32-8763-4e97-9c8e-f94df9c5c512">
                <ANNOTATION_VALUE>I don't remember his surname.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3965" ANNOTATION_REF="ann3963_flexid_42dee727-1d3c-4900-9fe1-06315aba11db">
                <ANNOTATION_VALUE>And, imagine, I presented him with it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4055" ANNOTATION_REF="ann4053_flexid_3dac2172-277b-42fb-bb9c-607855de5526">
                <ANNOTATION_VALUE>More exactly, I made and sent it to him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4175" ANNOTATION_REF="ann4173_flexid_88ec050f-0ba2-4370-a815-020a6a14ab6a">
                <ANNOTATION_VALUE>Well, what is its advantage?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4253" ANNOTATION_REF="ann4251_flexid_3c3df33e-5861-4d88-8e4d-2e40a03aeeaf">
                <ANNOTATION_VALUE>It was that, for example, cows were summoned with one sound, oxen - with another, and calf - with still another. Various livestock were summoned with various sounds.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4496" ANNOTATION_REF="ann4494_flexid_4be693a3-85fa-431f-85ac-776bbb0a3b5a">
                <ANNOTATION_VALUE>All of the pipes were for calling and makeing return.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4601" ANNOTATION_REF="ann4599_flexid_a195a215-c2a8-4fba-bffe-8b4bd48293a0">
                <ANNOTATION_VALUE>Initially, a shepherd's pipe was used for calling livestock; later, it became a musical instrument.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4864" ANNOTATION_REF="ann4862_flexid_85b49b6b-d8b9-40c8-8347-4aa315ac3077">
                <ANNOTATION_VALUE>Now, I'll whistle with it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4950" ANNOTATION_REF="ann4948_flexid_0e7c81ce-5390-4c89-bdb0-9aac3162fef1">
                <ANNOTATION_VALUE>You have to blow it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5024" ANNOTATION_REF="ann5022_flexid_4dc8b3f9-a74d-4425-b52d-bc08ec9848e7">
                <ANNOTATION_VALUE>Do you know how Dito surprised me?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5178" ANNOTATION_REF="ann5176_flexid_8450fad4-7251-4a94-aab5-fca4434a8768">
                <ANNOTATION_VALUE>I'm calling the child, I'm sorry, Gia, what is his name, God...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5344" ANNOTATION_REF="ann5342_flexid_7f41870a-2d38-4598-8592-cfbcac8b4b03">
                <ANNOTATION_VALUE>Dito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5366" ANNOTATION_REF="ann5364_flexid_f74ca608-0527-4fd2-b617-b73e9d5656a8">
                <ANNOTATION_VALUE>Dito.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5387" ANNOTATION_REF="ann5385_flexid_05574b0a-b2c6-4e01-ab3d-1be55b8bdc4d">
                <ANNOTATION_VALUE>I made a mistake about his name.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5474" ANNOTATION_REF="ann5472_flexid_54a22310-0219-42bf-94bc-48c63a1502ae">
                <ANNOTATION_VALUE>He was invited to the show "Good Morning, Georgia" and called me.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5624" ANNOTATION_REF="ann5622_flexid_95d09338-a196-49ac-8d0c-5a75694f190b">
                <ANNOTATION_VALUE>He said: "Uncle Demuri, aren't busy tomorrow in the morning?"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5740" ANNOTATION_REF="ann5738_flexid_6437114d-dcde-4457-8dde-de32cf8ecba7">
                <ANNOTATION_VALUE>I said: "Why are you asking?"</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5754" ANNOTATION_REF="ann5752_flexid_22684baa-3c82-440e-9aa3-0d9230850458">
                <ANNOTATION_VALUE>He said he wanted something. He couldn't tell it to me and promised that he would call me. He called me at half past nine.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5968" ANNOTATION_REF="ann5966_flexid_3dd21f99-3557-4787-98e7-1da489d66e41">
                <ANNOTATION_VALUE>He said: "Uncle Demur, now go and switch on you TV". I watched it and saw him there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6196" ANNOTATION_REF="ann6194_flexid_991d70a7-9d4e-45de-aaa3-025807d9264c">
                <ANNOTATION_VALUE>Imagine, he played "Chela" with the lute made by me, my dear. I liked it so much that I cried here with tears running down.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6489" ANNOTATION_REF="ann6487_flexid_5ca75486-a89e-4faa-ae80-dabec6841c6f">
                <ANNOTATION_VALUE>He added: "Are you glad?"; I said that I, of course, was glad.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6656" ANNOTATION_REF="ann6654_flexid_ee71321e-2189-4ae3-bf5e-056e1c96e276">
                <ANNOTATION_VALUE>It is difficult to play the pipe but he played it so well that sometimes he blew in two pipes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6870" ANNOTATION_REF="ann6868_flexid_dd91a44a-97e0-4949-a7c9-80e575c133f8">
                <ANNOTATION_VALUE>Dito visited Tsalenjikha District because he is rather interested in musical instruments.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7047" ANNOTATION_REF="ann7045_flexid_0fc11a52-ad14-4725-a400-01ac7d63c121">
                <ANNOTATION_VALUE>There, in his village, an old shepherd taught him how to play it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7155" ANNOTATION_REF="ann7153_flexid_77842336-346c-4793-aa9f-97b4aa23dc18">
                <ANNOTATION_VALUE>He is rather interested.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7186" ANNOTATION_REF="ann7184_flexid_4005b9a2-6540-4434-92a4-43dcc1759f1e">
                <ANNOTATION_VALUE>What do you make it of? What material is it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7311" ANNOTATION_REF="ann7309_flexid_d5ef5397-f5d6-4a9a-9605-384648b391a4">
                <ANNOTATION_VALUE>The Megrelian for it is "larchemi." The Georgian is "lertsami" [=reed].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7469" ANNOTATION_REF="ann7467_flexid_960a5759-3e97-4a68-b39f-0df9e87521b8">
                <ANNOTATION_VALUE>Reeds grow here.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7552" ANNOTATION_REF="ann7550_flexid_37828380-e973-4cc3-b773-e5cb3dda034b">
                <ANNOTATION_VALUE>It was used, what do you call it, a wire for the vine, when there was no wire, it was used for fixing vines.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7826" ANNOTATION_REF="ann7824_flexid_f13b9945-7baf-4f8e-b81b-afa4bf3d7be7">
                <ANNOTATION_VALUE>Women hung and fixed washed clothes with it; and reeds grew.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8018" ANNOTATION_REF="ann8016_flexid_196eb3e4-ffd1-4a37-86e8-d1d686de4a73">
                <ANNOTATION_VALUE>I don't have it but my neighbor has on one spot, on another as well, it grows on many locations and is brought from there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8313" ANNOTATION_REF="ann8311_flexid_766570c9-be2e-41de-bd16-edc6b390574b">
                <ANNOTATION_VALUE>You have to choose it with respect to thickness.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8404" ANNOTATION_REF="ann8402_flexid_befaf31e-9d2a-420f-91e7-8a3938167a16">
                <ANNOTATION_VALUE>I have something to show you; this is the first musical instrument. It is percussion. I don't know the Megrelian word for the instrument.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8637" ANNOTATION_REF="ann8635_flexid_d081491a-d434-4cf7-b9d8-19c44f32dc78">
                <ANNOTATION_VALUE>It was Megrelian. This is the beginning of al Megrelian musical instruments, a history of Megrelian musical instruments.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8824" ANNOTATION_REF="ann8822_flexid_4188f846-9ffa-4ddb-8c06-dce861ec1ce3">
                <ANNOTATION_VALUE>This is the history of a pipe in short.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="ka-Brai" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-ka-Brai">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7" ANNOTATION_REF="ann3_flexid_24e5a57b-366c-4c78-9072-925bb8bbaed7">
                <ANNOTATION_VALUE>აი, თქვენ ამზადებთ ლარჭემს (=სალამურს).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann73" ANNOTATION_REF="ann69_flexid_8a2489dd-1b50-47f5-9752-fc6f3cf1605c">
                <ANNOTATION_VALUE>აი, აქ დევს სალამური და ამას როგორ აკეთებთ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann205" ANNOTATION_REF="ann201_flexid_1b05fb8a-6b3b-4387-8636-1dd65c33b66d">
                <ANNOTATION_VALUE>აი, რისგან აკეთებთ და ამას მეგრელები სად უკარვდნენ, რას (=რაზე)  უკრავდნენ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann440" ANNOTATION_REF="ann436_flexid_e9d580af-afe5-448a-8e99-25fe89cb0fba">
                <ANNOTATION_VALUE>ახლა ისევ იმ ბიჭის [=დიტოს] დამსახურებაა ეს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann537" ANNOTATION_REF="ann533_flexid_b45ea23f-b259-4d2f-a5a2-ee7fb08f5436">
                <ANNOTATION_VALUE>სერგი მაკალათიას წიგნი ჩამივარდა ხელში.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann637" ANNOTATION_REF="ann633_flexid_a3ce05c3-c064-4082-b96b-ead4d2a6a618">
                <ANNOTATION_VALUE>იქ საოცრად აქვს აღწერილი ეს [სალამურის შესახებ].  იმ წიგნიდან რაც ვიცი, ამას მეც გეტყვით.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann871" ANNOTATION_REF="ann867_flexid_71b4c6e2-88fe-4852-ab5f-4825767eeec9">
                <ANNOTATION_VALUE>სალამურის ბაზრობა ყოფილა ხობში.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann959" ANNOTATION_REF="ann955_flexid_03d2f00f-02fa-4c55-91a7-aab28b5bb443">
                <ANNOTATION_VALUE>აქედან [რომ] მიდოდა პიროვნება ხობში, ბაზრობაზე, მეზობელი მეზობელს აბარებდა, სალამური წამომიმძღვანიეო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1176" ANNOTATION_REF="ann1172_flexid_32fcc014-fd44-4cec-80d4-60b4bcd0ea74">
                <ANNOTATION_VALUE>მიყიდე და წამომიძღვანიეო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1274" ANNOTATION_REF="ann1270_flexid_ba37a493-926a-4a02-814f-1761664d9085">
                <ANNOTATION_VALUE>ეს საკრავი არ ყოფილა, ეს ყოფილა [წასული, გაქცეული] საქონლის მოსაბრუნებელი ინსტრუმენტი. ესე იგი, რვა ისა არის ეს [კალამია = ლერწმის ღერო], ორი, ოთხი, ექვსი, რვა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1598" ANNOTATION_REF="ann1594_flexid_6068fd3d-ebdf-4077-bad3-e11f51b84d16">
                <ANNOTATION_VALUE>რვა კალამია (=ლერწმის ღერო) შეკრული, ესა, ამ რვა კალამიასგან არის [შეკრული].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1725" ANNOTATION_REF="ann1721_flexid_ae2e5945-10f8-4b73-b200-b9d60e49a8a2">
                <ANNOTATION_VALUE>ერთ-ერთი საკრავია ეს [ლარჭემი], რომელიც წყალში სველდება.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1847" ANNOTATION_REF="ann1843_flexid_bb1b564d-95c6-4439-8cf8-2d3cbcf13d1b">
                <ANNOTATION_VALUE>წყალი დაესხმევა [=წყლით გაჯერდება] და მერე აქვს საოცარი ხმა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2043" ANNOTATION_REF="ann2039_flexid_b00a9ada-bac7-4921-a69a-0d0b40476904">
                <ANNOTATION_VALUE>ეს არის აკაციის ეშვებით შეკრული, მაგრამ ისე უნდა იყოს შეკრული, [რომ] არ დაიშალოს და თავი უნდა ჩანდეს [შეკრულის, ნასკვის].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2344" ANNOTATION_REF="ann2340_flexid_2591db16-e90a-4929-a074-9f6edca91d8a">
                <ANNOTATION_VALUE>[ნასკვის] დასაწყისი და დასარული არ უნდა ჩანდეს არსად.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2454" ANNOTATION_REF="ann2450_flexid_cc424679-ec50-4d94-a75e-595af6df9f90">
                <ANNOTATION_VALUE>ეს გავაკეთე და ეს ზომები [მომიტანა დიტომ].  მე ხომ თამაში (=დაკვრა) არ ვიცოდი ამის (=ამაზე) და წარმოდგენა არ მქონდა რა იყო [ეს].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2757" ANNOTATION_REF="ann2753_flexid_ce5edf49-6844-4e8b-a855-2c85445966f4">
                <ANNOTATION_VALUE>[ხომ] წარმოგიდგენია,   ის ბავშვი, ბიჭი [=დიტო] მოვიდა, დემური ბიძიაო, თქვა, მუზეუმში მაქვსო ნანახი და წარმოიდგინე, ეს იქ თბილისში სწავლობდა და მერე [რომ] აბარებდა, იმ პერიოდში წასულა და [ლარჭემის] ყველა [სალამური] გაუზომავს ასე შიგნიდან. უთხოვია [მუზეუმისთვის]. ხოდა მომიტანა ზომა (=ზომები).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3421" ANNOTATION_REF="ann3417_flexid_8baabc08-6b9a-4cb9-8d32-fdf07719d982">
                <ANNOTATION_VALUE>გავაკეთე ეს, ეს უკვე ნამდვილად ის იყო, რაც (=როგორიც) [ორიგინალი ნიმუში] იყო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3601" ANNOTATION_REF="ann3597_flexid_dc9e036c-684f-4615-810f-a2ebe6f62334">
                <ANNOTATION_VALUE>მეორე ვაჩქუ მას [=დიტოს].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3675" ANNOTATION_REF="ann3671_flexid_e9456543-7934-44d4-b5f1-b84d192f69c6">
                <ANNOTATION_VALUE>მესამე ბათუმელი პიროვნება იყო ეს, გვარი დამავიწყდა, ამ ხალხურ ფოლკლორს  იწერდა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3893" ANNOTATION_REF="ann3889_flexid_fbb58d32-8763-4e97-9c8e-f94df9c5c512">
                <ANNOTATION_VALUE>არ მახსოვს გვარი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
