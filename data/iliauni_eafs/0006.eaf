            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4255" ANNOTATION_REF="ann4251_flexid_3c3df33e-5861-4d88-8e4d-2e40a03aeeaf">
                <ANNOTATION_VALUE>ეს იყო, მაგალითად, ძროხებს სხვა ხმით ეძახდნენ, კუროებს სხვა ხმით, მოზვრებს სხვა ხმით.  [=სალამურის  ჯოხებით-ლერწმებით],  სხვადასხვა საქონელს სხვადასხვანაირად ეძახდნენ]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4498" ANNOTATION_REF="ann4494_flexid_4be693a3-85fa-431f-85ac-776bbb0a3b5a">
                <ANNOTATION_VALUE>[სალამურის] ყველა  [ჯოხი]  იყო საქონლის მოსაბრუნებელი და დასაძახებელი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4603" ANNOTATION_REF="ann4599_flexid_a195a215-c2a8-4fba-bffe-8b4bd48293a0">
                <ANNOTATION_VALUE>მერე როგორც  სალამური, რა ფუნქციითაც ის მწყემსებს ჰქონდათ საქონლის მოსაბრუნებლად [=ჩაბერვის ფუნქციით], ასეთნაირად გადაიქცა საკრავად.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
