        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5756" ANNOTATION_REF="ann5752_flexid_22684baa-3c82-440e-9aa3-0d9230850458">
                <ANNOTATION_VALUE>რაღაც მინდაო - ეს [=რაც უნდოდა] ვერ თქვა და დაგირეკავო [მერე]. დამირეკა ათის ნახევარზე.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5970" ANNOTATION_REF="ann5966_flexid_3dd21f99-3557-4787-98e7-1da489d66e41">
                <ANNOTATION_VALUE>დემური ბიძიაო, ახლა მიდიო, ტელევიზორი ჩართეო, მითხრა და [რომ] შევხედე, აგერ ვნახე.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6198" ANNOTATION_REF="ann6194_flexid_991d70a7-9d4e-45de-aaa3-025807d9264c">
                <ANNOTATION_VALUE>წარმოიდგინე, ჩემი გაკეთებული ჩონგურით  ჩელა არ იყო [=რომ] დაუკრა, ბიძია, მე აქ ცრემლს (=ცრემლით) ვტიროდი, იმ დონეზე [მომეწონა].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6491" ANNOTATION_REF="ann6487_flexid_5ca75486-a89e-4faa-ae80-dabec6841c6f">
                <ANNOTATION_VALUE>ხომ გაგიხარდაო, დაამატა [ ნათქვამს] იქიდან [ტელეფონიდან]. რას ჰქვია- მეთქი (=რა თქმა უნდა-მეთქი), ვუთხარი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6658" ANNOTATION_REF="ann6654_flexid_ee71321e-2189-4ae3-bf5e-056e1c96e276">
                <ANNOTATION_VALUE>ამით [=ლარჭემით] რთულია, მაგრამ იმ დონემდე (=იმ დონეზე) დაუკრა (=ძალიან კარგად დაუკრა). ზოგიერთ ადგილზე ორივეს (=ორივე ღეროში) ჩაბერვაც [იყო].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6872" ANNOTATION_REF="ann6868_flexid_dd91a44a-97e0-4949-a7c9-80e575c133f8">
                <ANNOTATION_VALUE>ეს [=დიტო]წავიდა სადღაც აქეთკენ, წალენჯიხის რაიონში, ისეთი დაინტერესებულია [=ძალიან დაინტერესებულია საკრავებით].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7049" ANNOTATION_REF="ann7045_flexid_0fc11a52-ad14-4725-a400-01ac7d63c121">
                <ANNOTATION_VALUE>იქ [თავის სოფელში] ძველმა [=მოხუცმა] მწყემსმა ასწავლა ეს [დაკვრა].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7157" ANNOTATION_REF="ann7153_flexid_77842336-346c-4793-aa9f-97b4aa23dc18">
                <ANNOTATION_VALUE>ასეთი [დაინტერესებულია].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7188" ANNOTATION_REF="ann7184_flexid_4005b9a2-6540-4434-92a4-43dcc1759f1e">
                <ANNOTATION_VALUE>ამას რისგან ამზადებთ, ან მასალა რა არის?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7313" ANNOTATION_REF="ann7309_flexid_d5ef5397-f5d6-4a9a-9605-384648b391a4">
                <ANNOTATION_VALUE>ეს არის, ნამდვილად, ლარჭემს ეძახიან ამას მეგრულად. ქართულად ლერწამი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7471" ANNOTATION_REF="ann7467_flexid_960a5759-3e97-4a68-b39f-0df9e87521b8">
                <ANNOTATION_VALUE>ლერწამია.  ხარობს ეს [=ლერწამი] აქ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7554" ANNOTATION_REF="ann7550_flexid_37828380-e973-4cc3-b773-e5cb3dda034b">
                <ANNOTATION_VALUE>იყენებდნენ ამას, იმის, რა არის მაგას [რომ] ჰქვია, ვენახის მავთული [რომ] არ იყო, იმ დროს ამის [ვაზის] გასაბმელად, მისამაგრებლად [იყენებდნენ].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7828" ANNOTATION_REF="ann7824_flexid_f13b9945-7baf-4f8e-b81b-afa4bf3d7be7">
                <ANNOTATION_VALUE>სარეცხს  გადაკიდებდნენ, გააფენდნენ ქალები მინდორში და ხარობდა ეს  [=ლერწამი].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8020" ANNOTATION_REF="ann8016_flexid_196eb3e4-ffd1-4a37-86e8-d1d686de4a73">
                <ANNOTATION_VALUE>მე არ მიდგას [=ჩემთან არ ხარობს], მაგრამ აქ მეზობელს აქვს ერთ ადგილზე. მეორე ადგილზე[ც]. რამდენ (=ბევრ) ადგილზე ხარობს და იქიდან არის ეს მოტანილი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8315" ANNOTATION_REF="ann8311_flexid_766570c9-be2e-41de-bd16-edc6b390574b">
                <ANNOTATION_VALUE>სიმსხვილით [=სისქით] უნდა გამოარჩიო უნდა, ესა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8406" ANNOTATION_REF="ann8402_flexid_befaf31e-9d2a-420f-91e7-8a3938167a16">
                <ANNOTATION_VALUE>მაქვს ახლა საჩვენებლად, რომ პირველი საკრავია, სარტყამია, არ ვიცი საკრავის სახელი მეგრულად.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8639" ANNOTATION_REF="ann8635_flexid_d081491a-d434-4cf7-b9d8-19c44f32dc78">
                <ANNOTATION_VALUE>მეგრული იყო ეს. ამით იწყება ყველა მეგრული საკრავი, მეგრული საკრავების  [ისტორია].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8826" ANNOTATION_REF="ann8822_flexid_4188f846-9ffa-4ddb-8c06-dce861ec1ce3">
                <ANNOTATION_VALUE>ლარჭემის (=სალამურის) ისტორია ასეთია, მოკლედ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="xmf-fonipa" LINGUISTIC_TYPE_REF="phrase-item"
