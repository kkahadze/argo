    <TIER LANG_REF="xmf" LINGUISTIC_TYPE_REF="phrase" TIER_ID="A_phrase-txt-xmf">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann5_flexid_70be4fb1-972a-4836-a447-eead8662fd6e"
                TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>-ათე პატჷნეფიში გურშენი მუ შილებე, მუ გჷგაშინენა, ჯვეშო უჩქუდეს ხო, ხვამა, წირუა?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann240_flexid_3b58bc2e-3c45-4821-a748-74ae14e25273"
                TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts5">
                <ANNOTATION_VALUE>- პატჷნეფშე ხვამათ უჩქუდეს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann309_flexid_e62b4e85-beb1-43ea-991e-69fca6b4507d"
                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>უკული წითელე პატჷნეფი მიდგას ოსურუდუნ, ქიგეგონენდეს შხვადო  სოდგა რდჷნჷ, თექ ოკო მიდეუნესკო თე მუნეფიში ბაღანა, თიშ ოძირაფშა მუდგარენი ტკბილეულით, ხილეულით დო იშო აშო გილმეშეს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann658_flexid_67b3e9a2-38b8-4531-b26b-71a79eb697d2"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>დო პლიუს ათეს ხოლო რდჷ ჯა ნეძი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann751_flexid_eee911da-9b06-47d6-946c-7bcc54b8249c"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>ნეძი რდჷ ჯა, ნამუში  ფესვის შილებედჷ  თი ბაღანა გაგთატარკონჷ ფესვი დო დიხაშ  შკას.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann994_flexid_d60b3ec9-806a-442a-9e7b-10b1b6f07890"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>თიჯგუა თხრილი რდჷ, ბაღანაში გჷთოჸუნაფა დო გატარება შეილებუდ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1151_flexid_a11644c8-bbff-4164-87fc-d75b88c5a0e0"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>დო მუდა ბაღანა გეტარებუდუნჷ, თიშ მიხედვით ჭითა ლენტეფი მიკიბუნუაფუდჷ თექი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1354_flexid_7907e7e4-ed7e-4106-9a18-fda7642775fa"
                TIME_SLOT_REF1="ts17" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>თი ლენტეფი ირიათო თექ რდჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1420_flexid_5b4ed219-e129-42c6-a12d-ddd0218fc381"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>მეუძინანდ კოჩჷნ, მეუძინანდჷ, მეუძინანდჷ  დო დღას, მუშით დელპებუდჷდა ვარა, კოჩი ვანკონწყჷნდჷ, ჭუალა ვეშილებედჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1756_flexid_c0a30737-85b0-4186-bc83-cbd806c23743"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>-მუ ვაშინერდ თე დროს მაგალთო, პატჷნეფი გიზოჯჷნდ ოჯახის თიწკმა?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1923_flexid_40d49d3b-648a-4ae3-b37e-0127ecbf16ef"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>-პატჷნეფი გიზოჯჷნ თი დროს ხმაური ვეშჷლებედჷ, ჩხუპ ვეშლებედჷ, ღვინიში შუმა ვეშილებედჷ, რდიკო ოკო მშვიდას, წყნარას, ნორმალურო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2280_flexid_61b29a82-0ce2-4e83-bd32-ccd5c3462407"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>-დიხაში ნჭყოლუა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2319_flexid_2f55cc35-1316-4771-8a50-1e0ccb4c4db9"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>-ვაა, ვეშილებედჷ დიხაში ნჭყოლუა მუთუნით, მუთუნი ცუდიშ გაკეთება მუთუნიშ ვეშლებედჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2531_flexid_7db1d69d-c4f2-4044-9766-b37aa060af34"
