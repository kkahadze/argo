    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7" ANNOTATION_REF="ann5_flexid_70be4fb1-972a-4836-a447-eead8662fd6e">
                <ANNOTATION_VALUE>What can you recollect about "batonebi" [=rashes]? Did people practice praying in the past?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann242" ANNOTATION_REF="ann240_flexid_3b58bc2e-3c45-4821-a748-74ae14e25273">
                <ANNOTATION_VALUE>They prayed when a child had batonebi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann311" ANNOTATION_REF="ann309_flexid_e62b4e85-beb1-43ea-991e-69fca6b4507d">
                <ANNOTATION_VALUE>Then, when someone had measles, they learnt where someone else was also infected, and they had to take their child to visit another one bringing sweets, fruit, and went to and fro.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann660" ANNOTATION_REF="ann658_flexid_67b3e9a2-38b8-4531-b26b-71a79eb697d2">
                <ANNOTATION_VALUE>And, moreover, there was a ritual of a walnut tree.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann753" ANNOTATION_REF="ann751_flexid_eee911da-9b06-47d6-946c-7bcc54b8249c">
                <ANNOTATION_VALUE>A walnut was a tree under roots of which you could let your child pass, between a ground and a root.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann996" ANNOTATION_REF="ann994_flexid_d60b3ec9-806a-442a-9e7b-10b1b6f07890">
                <ANNOTATION_VALUE>There was a ditch under which a child could pass.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1153" ANNOTATION_REF="ann1151_flexid_a11644c8-bbff-4164-87fc-d75b88c5a0e0">
                <ANNOTATION_VALUE>And, as many children were let to pass it, as many red ribbons were hung up there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1356" ANNOTATION_REF="ann1354_flexid_7907e7e4-ed7e-4106-9a18-fda7642775fa">
                <ANNOTATION_VALUE>Ribbons were always there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1422" ANNOTATION_REF="ann1420_flexid_5b4ed219-e129-42c6-a12d-ddd0218fc381">
                <ANNOTATION_VALUE>People added and added ribbons, and, if only it got rotten by itself, otherwise nobody removed them.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1758" ANNOTATION_REF="ann1756_flexid_c0a30737-85b0-4186-bc83-cbd806c23743">
                <ANNOTATION_VALUE>What was not allowed to do in a family with a child infected with "batonebi"?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1925" ANNOTATION_REF="ann1923_flexid_40d49d3b-648a-4ae3-b37e-0127ecbf16ef">
                <ANNOTATION_VALUE>When there was "batonebi", it was not allowed to make noise, to fight, to drink wine; you had to behave in a peaceful, calm, normal way.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2282" ANNOTATION_REF="ann2280_flexid_61b29a82-0ce2-4e83-bd32-ccd5c3462407">
                <ANNOTATION_VALUE>To dig earth.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2321" ANNOTATION_REF="ann2319_flexid_2f55cc35-1316-4771-8a50-1e0ccb4c4db9">
                <ANNOTATION_VALUE>No, it was not allowed to dig earth; it was not allowed to do bad things.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2533" ANNOTATION_REF="ann2531_flexid_7db1d69d-c4f2-4044-9766-b37aa060af34">
                <ANNOTATION_VALUE>Ah, I understand; thank you.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2599" ANNOTATION_REF="ann2597_flexid_ac53e096-f1d2-46f8-9375-52a92a3f45fa">
                <ANNOTATION_VALUE>Not at all, my dear.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="ka-Brai" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-ka-Brai">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8" ANNOTATION_REF="ann5_flexid_70be4fb1-972a-4836-a447-eead8662fd6e">
                <ANNOTATION_VALUE>- ამ ბატონების შესახებ რა შეიძლება რომ გაიხსენოთ, ძველად იცოდნენ, ხომ, ლოცვა, წირვა?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann243" ANNOTATION_REF="ann240_flexid_3b58bc2e-3c45-4821-a748-74ae14e25273">
                <ANNOTATION_VALUE>- ბატონები ლოცვით იცოდნენ [=ბატონების დროს ლოცულობდნენ]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann312" ANNOTATION_REF="ann309_flexid_e62b4e85-beb1-43ea-991e-69fca6b4507d">
                <ANNOTATION_VALUE>მერე, ვისაც წითელა ბატონები ჰყავდა, [ესენი] გაიგებდნენ, სხვაგანაც სად იყო [=კიდევ ვის უბრძანდებოდა], აი, იქ უნდა წაეყვანათ ეს თავიანთი ბავშვი, მის სანახავად ტკბილეულობით, ხილით და იქით-აქეთ დადიოდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann661" ANNOTATION_REF="ann658_flexid_67b3e9a2-38b8-4531-b26b-71a79eb697d2">
                <ANNOTATION_VALUE>და პლიუს ამას კიდევ იყო კაკლის ხე [=კაკლის ხის რიტუალი].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann754" ANNOTATION_REF="ann751_flexid_eee911da-9b06-47d6-946c-7bcc54b8249c">
                <ANNOTATION_VALUE>კაკალი იყო ხე, რომლიც ფესვებქვეშ შეგეძლო ბავში გაგეტარებინა ფესვსა და მიწას შორის.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann997" ANNOTATION_REF="ann994_flexid_d60b3ec9-806a-442a-9e7b-10b1b6f07890">
                <ANNOTATION_VALUE>ისეთი თხრილი იყო, ბავშვის ქვეშიდან გამოყვანა და გატარება შეიძლებოდა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1154" ANNOTATION_REF="ann1151_flexid_a11644c8-bbff-4164-87fc-d75b88c5a0e0">
                <ANNOTATION_VALUE>და რამდენი ბავშვიც გატარდებოდა, იმის მიხედვით წითელი ბანტები დაიკიდებოდა იქ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1357" ANNOTATION_REF="ann1354_flexid_7907e7e4-ed7e-4106-9a18-fda7642775fa">
                <ANNOTATION_VALUE>ეს ბანტები სულ იქ იყო [=ება].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1423" ANNOTATION_REF="ann1420_flexid_5b4ed219-e129-42c6-a12d-ddd0218fc381">
                <ANNOTATION_VALUE>უმატებდა და უმატებდა კაცი (=ადამიანი) და თავისით არასოდეს, თავისით თუ დალპებოდა თორემ, არ ჩამოხსნიდა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1759" ANNOTATION_REF="ann1756_flexid_c0a30737-85b0-4186-bc83-cbd806c23743">
                <ANNOTATION_VALUE>- არ არ იყო დაშვებული ამ დროს, მაგალითად, როცა ოჯახში ბატონები ბრძანდებოდა?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1926" ANNOTATION_REF="ann1923_flexid_40d49d3b-648a-4ae3-b37e-0127ecbf16ef">
                <ANNOTATION_VALUE>ბატონები რომ ბრძანდებოდა, იმ დროს ხმაური არ შეიძლებოდა, ჩხუბი არ შეიძლებოდა, ღვინოს სმა არ შეიძლებოდა, უნდა ყოფილიყავი მშვიდად, წყნარად, ნორმალურად.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2283" ANNOTATION_REF="ann2280_flexid_61b29a82-0ce2-4e83-bd32-ccd5c3462407">
                <ANNOTATION_VALUE>- მიწის ჭრა (=თხრა).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2322" ANNOTATION_REF="ann2319_flexid_2f55cc35-1316-4771-8a50-1e0ccb4c4db9">
                <ANNOTATION_VALUE>- არა, არ შეიძლებოდა მიწის თხრა, ცუდი რამეს კეთება არ შეიძლებოდა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2534" ANNOTATION_REF="ann2531_flexid_7db1d69d-c4f2-4044-9766-b37aa060af34">
                <ANNOTATION_VALUE>- აჰა, გასაგებია. მადლობა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2600" ANNOTATION_REF="ann2597_flexid_ac53e096-f1d2-46f8-9375-52a92a3f45fa">
                <ANNOTATION_VALUE>რას... რას ამბობ შენ შემოგევლე.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="xmf-fonipa" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-xmf-fonipa">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann9" ANNOTATION_REF="ann5_flexid_70be4fb1-972a-4836-a447-eead8662fd6e">
                <ANNOTATION_VALUE>ɑtɛ pʼɑtʼənɛpiʃi ɡurʃɛni mu ʃilɛbɛ, mu ɡəɡɑʃinɛnɑ, d͡ʒvɛʃɔ ut͡ʃkudɛs xɔ, xvɑmɑ, t͡sʼiruɑ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann244" ANNOTATION_REF="ann240_flexid_3b58bc2e-3c45-4821-a748-74ae14e25273">
                <ANNOTATION_VALUE>pʼɑtʼənɛpʃɛ xvɑmɑt ut͡ʃkudɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann313" ANNOTATION_REF="ann309_flexid_e62b4e85-beb1-43ea-991e-69fca6b4507d">
                <ANNOTATION_VALUE>ukʼuli t͡sʼitɛlɛ pʼɑtʼənɛpi midɡɑs ɔsurudun, kiɡɛɡɔnɛndɛs ʃxvɑdɔ  sɔdɡɑ rdənə, tɛk ɔkʼɔ midɛunɛskʼɔ tɛ munɛpiʃi bɑɣɑnɑ, tiʃ ɔd͡zirɑpʃɑ mudɡɑrɛni tʼkʼbilɛulit, xilɛulit dɔ iʃɔ ɑʃɔ ɡilmɛʃɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann662" ANNOTATION_REF="ann658_flexid_67b3e9a2-38b8-4531-b26b-71a79eb697d2">
                <ANNOTATION_VALUE>dɔ pʼlius ɑtɛs xɔlɔ rdə d͡ʒɑ nɛd͡zi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann755" ANNOTATION_REF="ann751_flexid_eee911da-9b06-47d6-946c-7bcc54b8249c">
                <ANNOTATION_VALUE>nɛd͡zi rdə d͡ʒɑ, nɑmuʃi  pɛsvis ʃilɛbɛdə  ti bɑɣɑnɑ ɡɑɡtɑtʼɑrkʼɔnə pɛsvi dɔ dixɑʃ  ʃkʼɑs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann998" ANNOTATION_REF="ann994_flexid_d60b3ec9-806a-442a-9e7b-10b1b6f07890">
                <ANNOTATION_VALUE>tid͡ʒɡuɑ txrili rdə, bɑɣɑnɑʃi ɡətɔʔunɑpɑ dɔ ɡɑtʼɑrɛbɑ ʃɛilɛbud.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1155" ANNOTATION_REF="ann1151_flexid_a11644c8-bbff-4164-87fc-d75b88c5a0e0">
                <ANNOTATION_VALUE>dɔ mudɑ bɑɣɑnɑ ɡɛtʼɑrɛbudunə, tiʃ mixɛdvit t͡ʃʼitɑ lɛntʼɛpi mikʼibunuɑpudə tɛki.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1358" ANNOTATION_REF="ann1354_flexid_7907e7e4-ed7e-4106-9a18-fda7642775fa">
                <ANNOTATION_VALUE>ti lɛntʼɛpi iriɑtɔ tɛk rdə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1424" ANNOTATION_REF="ann1420_flexid_5b4ed219-e129-42c6-a12d-ddd0218fc381">
                <ANNOTATION_VALUE>mɛud͡zinɑnd kʼɔt͡ʃən, mɛud͡zinɑndə, mɛud͡zinɑndə  dɔ dɣɑs, muʃit dɛlpʼɛbudədɑ vɑrɑ, kʼɔt͡ʃi vɑnkʼɔnt͡sʼqʼəndə, t͡ʃʼuɑlɑ vɛʃilɛbɛdə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1760" ANNOTATION_REF="ann1756_flexid_c0a30737-85b0-4186-bc83-cbd806c23743">
                <ANNOTATION_VALUE>mu vɑʃinɛrd tɛ drɔs mɑɡɑltɔ, pʼɑtʼənɛpi ɡizɔd͡ʒənd ɔd͡ʒɑxis tit͡sʼkʼmɑ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1927" ANNOTATION_REF="ann1923_flexid_40d49d3b-648a-4ae3-b37e-0127ecbf16ef">
                <ANNOTATION_VALUE>pʼɑtʼənɛpi ɡizɔd͡ʒən ti drɔs xmɑuri vɛʃəlɛbɛdə, t͡ʃxupʼ vɛʃlɛbɛdə, ɣviniʃi ʃumɑ vɛʃilɛbɛdə, rdikʼɔ ɔkʼɔ mʃvidɑs, t͡sʼqʼnɑrɑs, nɔrmɑlurɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2284" ANNOTATION_REF="ann2280_flexid_61b29a82-0ce2-4e83-bd32-ccd5c3462407">
                <ANNOTATION_VALUE>dixɑʃi nt͡ʃʼqʼɔluɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2323" ANNOTATION_REF="ann2319_flexid_2f55cc35-1316-4771-8a50-1e0ccb4c4db9">
                <ANNOTATION_VALUE>vɑɑ, vɛʃilɛbɛdə dixɑʃi nt͡ʃʼqʼɔluɑ mutunit, mutuni t͡sudiʃ ɡɑkʼɛtɛbɑ mutuniʃ vɛʃlɛbɛdə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2535" ANNOTATION_REF="ann2531_flexid_7db1d69d-c4f2-4044-9766-b37aa060af34">
                <ANNOTATION_VALUE>ɑhɑ, ɡɑsɑɡɛbi rɛ, d͡ʒɡiri, mɑdlɔbɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2601" ANNOTATION_REF="ann2597_flexid_ac53e096-f1d2-46f8-9375-52a92a3f45fa">
                <ANNOTATION_VALUE>rɑs... mus it͡ʃiɛbuk skʼɑn ɡɔlvɑprɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
