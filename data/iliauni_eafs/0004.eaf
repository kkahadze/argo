                ANNOTATION_ID="ann4822_flexid_fa683def-413c-43b1-aa03-5b04b2c96f8d"
                TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts63">
                <ANNOTATION_VALUE>ოდო ექ ნუ შხვა ვერსია რე ნამდაა გექვაუა დო ნუ მაინც ესე იგი, თი, ისა თურქის ხეს, ხექ ვეშიეხ.</ANNOTATION_VALUE>
