        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4056_flexid_6397a717-0813-49b8-903b-d1a70122bfba"
                TIME_SLOT_REF1="ts56" TIME_SLOT_REF2="ts57">
                <ANNOTATION_VALUE>ოდო თიშ უკული თი არდგილს, რახანთ ასე მოკათ ოსურიში გიგნასხაპინა ადგილი რე თინანი, თი ადგილს დედამოკა ქიგიადუა დო ასე ხოლო დედამოკა ჯოხო თი ადგილს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4392_flexid_dc78957a-2a63-4886-b539-34d7f7efb20b"
                TIME_SLOT_REF1="ts58" TIME_SLOT_REF2="ts59">
                <ANNOTATION_VALUE>დო ქუა ხოლო ნამუთ თექ რენი,  ეთი ქუა ნამუც გიოსხაპუა თი ოსურქჷნი, თი ქუაქ უკული მიიღუა იშ ფორმა მოკათ... მოკათ ოსურიშ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4702_flexid_a5d78387-dc0b-49e7-86d3-c32a765a95af"
                TIME_SLOT_REF1="ts60" TIME_SLOT_REF2="ts61">
                <ANNOTATION_VALUE>ხო, ოსურიშ, ქალის ფორმა, ანუ ოსურიშ ფორმა მიიღუა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
