    <TIER LANG_REF="xmf" LINGUISTIC_TYPE_REF="phrase"
        PARENT_REF="A_paragraph" TIER_ID="A_phrase-txt-xmf">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3_flexid_8f5b27ad-195c-4905-9f2f-688728eb0677"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>თექ [ბერთემს] რე ხოლო დედამოკა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann75_flexid_6e8ce3f3-c740-46c2-9707-62910ac303dc"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts7">
                <ANNOTATION_VALUE>ხო და დედამოკააში ისტორია თენერიე ნამდა თი შკა ოშკაბანე საუკუნეემსია, კოჩ თქუანსჷნ, მახუთაა საუკუნეშეე მავითოხუთაშახ  შუა საუკუნეეფი დჷ დო თიშ უკულ ხოლო თე ჩქინ სამარგალოს და საერთოდ საქორთუოს ირო გითმიანთხუუდუ თურქეფი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann580_flexid_2e06c262-4216-4918-8b75-84ebd182c728"
                TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>მა თაშ გამიგებუ თენა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann663_flexid_f04490f9-8233-400b-9e4a-98e60d419681"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts11">
                <ANNOTATION_VALUE>ბაღანობაში ის გირაგადჷქ, მუჭო მიხსნენდეს თეს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann797_flexid_b9b69560-44bd-4480-bf5e-b8880292ed5c"
                TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>მა საერთოდ ირო მაინტერესენდ ისტორია.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann882_flexid_a5d22faa-491a-4c34-8a95-5d0f7f6193b5"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts15">
                <ANNOTATION_VALUE>დო თე მუჟანს ვარდუო კოჩიი ჩქინ ოჯახშა  სტუმარი  ქიმიშუ, ვარდა მუთუნინი,  თინეფ მუთუნ  ჯვეშ ამბეებს მოყვენდეს და, მა  თექ გევოხედ დო ირიათო გაფაციცეფით  უჯინეედი  თინემს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1329_flexid_7566eaa5-1e8d-4251-8be4-2431c68837d3"
                TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts19">
                <ANNOTATION_VALUE>დო თენეფიშ ნარაგადშე...  .</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1376_flexid_13e85cde-9ff5-41fa-bff1-a048e7b75748"
                TIME_SLOT_REF1="ts20" TIME_SLOT_REF2="ts21">
                <ANNOTATION_VALUE>ასე  ვერსია ნამუთ ინტერნეტის გეძჷნ, ჭიჭე შხვანერიე დო მა ათაშ მაფ გჷნაგეფ თენა, ნამდა, ათე დედამოკაშ ტერიტორიასჷ მოკათ ოსურს გამათხოზუა  დამპყრ...  თურქიქ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1751_flexid_313fbf2a-2a90-4309-8a20-325e6d8e8fd5"
                TIME_SLOT_REF1="ts22" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>ქოძირუა თემომენტის თეენა, ნამუც წყარს ეშმა..</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1873_flexid_d8f6df22-143f-4349-ab60-56d48f904777"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts25">
                <ANNOTATION_VALUE>წყარ, წყურგიჲშე წყარ მოუღუდუა, ხოდა გამათხოზუა თექ ოჭოფალო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2044_flexid_f785445c-c694-4c09-87a9-cd63170bf494"
                TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ონიი, ირტუა თე მოკათ ოსურქ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2122_flexid_83131b51-3b89-4c3c-a9ea-d9cd43094fe2"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts29">
                <ANNOTATION_VALUE>ირტუანჷ, ტეხირ პიჯშე ირტუა, დიდყობკონი თიგურშენი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2266_flexid_a77b47ba-a59f-4fb3-b1d0-6df4ef3b7a4d"
                TIME_SLOT_REF1="ts30" TIME_SLOT_REF2="ts31">
                <ANNOTATION_VALUE>ონი გამათხოზუ ე კოჩიქ ხოლო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2345_flexid_c7f230ee-e403-470c-92aa-535b00e655fe"
                TIME_SLOT_REF1="ts32" TIME_SLOT_REF2="ts34">
                <ANNOTATION_VALUE>გამაათხოზჷნი, ტახირს ხო ქაადირთჷ ასე, ქაადირთ, მუ ქიმნას ასე ტეხირსჷნი,  გაჩერდუა თე ოსურქ, გაჩერდუა დო თე თურქიშ ხეს ეშალკონ თიშა ისხუნუუა ტეხირშა ქასხაპუკოვანი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2791_flexid_3397adeb-8f29-4b95-a5e3-a33d9bd23508"
                TIME_SLOT_REF1="ts33" TIME_SLOT_REF2="ts35">
                <ANNOTATION_VALUE>თი მომენტისია, ლეგენდა რე - ტეხირქ დეჭიჭარუა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2913_flexid_08e80d1f-e867-4d81-8f20-220ea3dc0394"
                TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts37">
                <ANNOTATION_VALUE>თი ადგილს მართაჲო ჭიჭე რე,  ძაამ ვიწრო ხეობა რე თი ადგირს, თი დედამოკა რე თექ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3109_flexid_c2f6bdce-0523-4401-bc31-a0bd93a2bf2e"
                TIME_SLOT_REF1="ts38" TIME_SLOT_REF2="ts40">
                <ANNOTATION_VALUE>დო ათე ოსურქ ქაასხაპუა დო გეგნოსხაპუა მაჟია ნაპირიშა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3248_flexid_4fae2ce9-52eb-4ca9-9b69-4b2abd685491"
                TIME_SLOT_REF1="ts39" TIME_SLOT_REF2="ts42">
                <ANNOTATION_VALUE>მა ათაშ  მაფუდ გინაგებ, ინტერნეტის თაშ ვეგეძ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
