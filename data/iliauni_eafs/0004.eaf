    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5" ANNOTATION_REF="ann3_flexid_8f5b27ad-195c-4905-9f2f-688728eb0677">
                <ANNOTATION_VALUE>Here, in Betlemi, there is also a location called "Dedamoka".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann77" ANNOTATION_REF="ann75_flexid_6e8ce3f3-c740-46c2-9707-62910ac303dc">
                <ANNOTATION_VALUE>The history of Dedamoka is the following: in the middle ages, as people say, from the 5th century till the 15th, and after that, Samegrelo and, Georgia, at large, were invaded by Turks.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann582" ANNOTATION_REF="ann580_flexid_2e06c262-4216-4918-8b75-84ebd182c728">
                <ANNOTATION_VALUE>I have heard it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann665" ANNOTATION_REF="ann663_flexid_f04490f9-8233-400b-9e4a-98e60d419681">
                <ANNOTATION_VALUE>I am telling you how I was told about it in my childhood.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann799" ANNOTATION_REF="ann797_flexid_b9b69560-44bd-4480-bf5e-b8880292ed5c">
                <ANNOTATION_VALUE>Generally, I have always been interested in history.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann884" ANNOTATION_REF="ann882_flexid_a5d22faa-491a-4c34-8a95-5d0f7f6193b5">
                <ANNOTATION_VALUE>Whenever a guest visited our family, or something happened, people told old stories, and I used to sit there listening very attentively.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1331" ANNOTATION_REF="ann1329_flexid_7566eaa5-1e8d-4251-8be4-2431c68837d3">
                <ANNOTATION_VALUE>I am telling you what I have heard from them.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1378" ANNOTATION_REF="ann1376_flexid_13e85cde-9ff5-41fa-bff1-a048e7b75748">
                <ANNOTATION_VALUE>Presently, the version, which is published in the Internet, is slightly different, and I have heard that it was the territory of Dedamoka where a pregnant woman was chased by a Turk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1753" ANNOTATION_REF="ann1751_flexid_313fbf2a-2a90-4309-8a20-325e6d8e8fd5">
                <ANNOTATION_VALUE>He saw the pregnant woman who was taking water from the spring.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1875" ANNOTATION_REF="ann1873_flexid_d8f6df22-143f-4349-ab60-56d48f904777">
                <ANNOTATION_VALUE>She was taking water from the spring, and the Turk chased her in order to catch her.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2046" ANNOTATION_REF="ann2044_flexid_f785445c-c694-4c09-87a9-cd63170bf494">
                <ANNOTATION_VALUE>The pregnant woman ran away.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2124" ANNOTATION_REF="ann2122_flexid_83131b51-3b89-4c3c-a9ea-d9cd43094fe2">
                <ANNOTATION_VALUE>She ran away; she ran away towards the bank of the Tekhuri river in order to hide herself.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2268" ANNOTATION_REF="ann2266_flexid_a77b47ba-a59f-4fb3-b1d0-6df4ef3b7a4d">
                <ANNOTATION_VALUE>And, the man chased her.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2347" ANNOTATION_REF="ann2345_flexid_c7f230ee-e403-470c-92aa-535b00e655fe">
                <ANNOTATION_VALUE>When she was chased, she reached the Tekhuri; she came there and she didn't know what to do. The woman stopped, and, in order not to get caught by the Turk, she jumped into the Tekhuri.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2793" ANNOTATION_REF="ann2791_flexid_3397adeb-8f29-4b95-a5e3-a33d9bd23508">
                <ANNOTATION_VALUE>In that moment, as the legend goes, the Tekhuri decreased.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2915" ANNOTATION_REF="ann2913_flexid_08e80d1f-e867-4d81-8f20-220ea3dc0394">
                <ANNOTATION_VALUE>The river is actually small in that location. The gorge is very narrow where there is Dedamoka.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3111" ANNOTATION_REF="ann3109_flexid_c2f6bdce-0523-4401-bc31-a0bd93a2bf2e">
                <ANNOTATION_VALUE>The woman jumped onto the opposite bank of the river.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3250" ANNOTATION_REF="ann3248_flexid_4fae2ce9-52eb-4ca9-9b69-4b2abd685491">
                <ANNOTATION_VALUE>This is what I have heard. This version isn't available in the Internet/</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3391" ANNOTATION_REF="ann3389_flexid_e9c33d37-c16a-4dd7-8518-d8223ef6b17b">
                <ANNOTATION_VALUE>That version says that she jumped onto a rock and turned to stone.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3529" ANNOTATION_REF="ann3527_flexid_8ae86f7c-ab0b-408d-8605-606b4a2cd7d4">
                <ANNOTATION_VALUE>Aha.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3544" ANNOTATION_REF="ann3542_flexid_2727e5ef-8933-4865-8b86-56345096af1c">
                <ANNOTATION_VALUE>And, I have not heard the Internet version. In my childhood, aged people told that the woman survived and escaped.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3773" ANNOTATION_REF="ann3771_flexid_8e43269f-8904-4a0e-9e48-89536139b8d7">
                <ANNOTATION_VALUE>The Turk too jumped into the river but he didn't reach the opposite bank.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3979" ANNOTATION_REF="ann3977_flexid_01edeb52-8ca3-4994-8d2c-e9ad6d20a9a7">
                <ANNOTATION_VALUE>The Turk drowned.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4058" ANNOTATION_REF="ann4056_flexid_6397a717-0813-49b8-903b-d1a70122bfba">
                <ANNOTATION_VALUE>And, since then, the place where the pregnant woman jumped was named Dedamoka, and it is called Dedamoka.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4394" ANNOTATION_REF="ann4392_flexid_dc78957a-2a63-4886-b539-34d7f7efb20b">
                <ANNOTATION_VALUE>And, the rock, which is there on which the woman is said to have jumped on, the rock took a shape of a pregnant woman.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4704" ANNOTATION_REF="ann4702_flexid_a5d78387-dc0b-49e7-86d3-c32a765a95af">
                <ANNOTATION_VALUE>And, the rock took the shape of a woman.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4824" ANNOTATION_REF="ann4822_flexid_fa683def-413c-43b1-aa03-5b04b2c96f8d">
                <ANNOTATION_VALUE>And, there, in the Internet, there is a different version that she turned to stone, that is to say that Turk failed to reach her.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="ka-Brai" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-ka-Brai">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann7" ANNOTATION_REF="ann3_flexid_8f5b27ad-195c-4905-9f2f-688728eb0677">
                <ANNOTATION_VALUE>იქ [ბეთლემში] არის კიდევ [ადგილი] დედამოკა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann79" ANNOTATION_REF="ann75_flexid_6e8ce3f3-c740-46c2-9707-62910ac303dc">
                <ANNOTATION_VALUE>დედამოკას ისტორია ასეთია, რომ იმ შუა საუკუნეებშიო, კაცი (=ადამიანი) რომ იტყვის (მეხუთე საუკუნიდან მეთხუთმეტემდე შუა საუკუნეები იყო) და მას მერე ამ ჩვენს სამეგრელოს და საერთოდ საქართველოს ყოველთვის ესხმოდა თურქები.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann584" ANNOTATION_REF="ann580_flexid_2e06c262-4216-4918-8b75-84ebd182c728">
                <ANNOTATION_VALUE>მე ასე გამიგია ეს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann667" ANNOTATION_REF="ann663_flexid_f04490f9-8233-400b-9e4a-98e60d419681">
                <ANNOTATION_VALUE>ბავშვობის იმას გეუბნები [პერიოდის ამბავს]. როგორ გვიხსნიდნენ ამას.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann801" ANNOTATION_REF="ann797_flexid_b9b69560-44bd-4480-bf5e-b8880292ed5c">
                <ANNOTATION_VALUE>მე საერთოდ სულ მაინტერესებდა ისტორია.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann886" ANNOTATION_REF="ann882_flexid_a5d22faa-491a-4c34-8a95-5d0f7f6193b5">
                <ANNOTATION_VALUE>ეს როცა არ იყო (=როდესაც) კაცი, სტუმარი ჩვენს ოჯახში მოვიდოდა, ან რამე [თუ ხდებოდა], ისინი რამე ძველ ამბებს [თუ] მოყვებოდნენ, მე იქ ვიჯექი და გაფაციცებით ვუყურებდი (=ვუსმენდი) მათ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1333" ANNOTATION_REF="ann1329_flexid_7566eaa5-1e8d-4251-8be4-2431c68837d3">
                <ANNOTATION_VALUE>და ამათი ნათქვამიდან [რაც გამიგია, მაგას ვამბობ].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1380" ANNOTATION_REF="ann1376_flexid_13e85cde-9ff5-41fa-bff1-a048e7b75748">
                <ANNOTATION_VALUE>ახლა, ვერსია, რომელიც ინტერნეტში დევს [=მოიპოვება], ცოტა სხვანაირია და მე ასე მაქვს განაგები (=ასე გამიგია), რომ ამ დედამოკას ტერიტორიაზე ორსულ ქალს გამოეკიდაო [დამპყრობელი]. თურქი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1755" ANNOTATION_REF="ann1751_flexid_313fbf2a-2a90-4309-8a20-325e6d8e8fd5">
                <ANNOTATION_VALUE>ნახაო ამ მომენტში ეს [ორსული ქალი], რომელიც წყალს [იღებდა წყაროდან].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1877" ANNOTATION_REF="ann1873_flexid_d8f6df22-143f-4349-ab60-56d48f904777">
                <ANNOTATION_VALUE>წყალი, წყაროდან წყალი მოჰქონდაო. ხოდა, გამოეკიდაო ეს [თურქი} დასაჭერად.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2048" ANNOTATION_REF="ann2044_flexid_f785445c-c694-4c09-87a9-cd63170bf494">
                <ANNOTATION_VALUE>გაიქცაო ეს ორსული ქალი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2126" ANNOTATION_REF="ann2122_flexid_83131b51-3b89-4c3c-a9ea-d9cd43094fe2">
                <ANNOTATION_VALUE>[რომ] გაიქცაო, ტეხურის ნაპირიდან გაიქცაო, [რომ] დამალულიყო იმიტომ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2270" ANNOTATION_REF="ann2266_flexid_a77b47ba-a59f-4fb3-b1d0-6df4ef3b7a4d">
                <ANNOTATION_VALUE>ხოდა, გამოეკიდა ეს კაციც.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2349" ANNOTATION_REF="ann2345_flexid_c7f230ee-e403-470c-92aa-535b00e655fe">
                <ANNOTATION_VALUE>[რომ]  გამოეკიდა, ტეხურს ხომ მიადგა ახლა, მიადგა [და] რა ქნას ახლა ტეხურზე. გაჩერდაო ეს ქალი, გაჩერდაო და ამ თურქის ხელში რომ ჩავარდნილიყო მაგას არჩია ტეხურზე გადამხტარიყოო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2795" ANNOTATION_REF="ann2791_flexid_3397adeb-8f29-4b95-a5e3-a33d9bd23508">
                <ANNOTATION_VALUE>იმ მომენტშიო, ლეგენდაა  - ტეხური დაპატარავდაო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2917" ANNOTATION_REF="ann2913_flexid_08e80d1f-e867-4d81-8f20-220ea3dc0394">
                <ANNOTATION_VALUE>იმ ადგილზე მართლა პატარაა [წყალი], ძლიან ვიწრო ხეობაა იმ ადგილზე, ის დედამოკა [რომ] არის იქ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3113" ANNOTATION_REF="ann3109_flexid_c2f6bdce-0523-4401-bc31-a0bd93a2bf2e">
                <ANNOTATION_VALUE>ეს ქალი ახტაო და გადახტაო [მდინარის] მეორე ნაპირზე.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3252" ANNOTATION_REF="ann3248_flexid_4fae2ce9-52eb-4ca9-9b69-4b2abd685491">
                <ANNOTATION_VALUE>მე ასე მქონდა განაგები (=ასე გამიგია), ინტენეტში ასე (=ასეთი ვერსია) არ დევს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3393" ANNOTATION_REF="ann3389_flexid_e9c33d37-c16a-4dd7-8518-d8223ef6b17b">
                <ANNOTATION_VALUE>ქვას დაახტაო და გაქვავდაო ასე (=ასეთი შინაარსის ვერსია) დევს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3531" ANNOTATION_REF="ann3527_flexid_8ae86f7c-ab0b-408d-8605-606b4a2cd7d4">
                <ANNOTATION_VALUE>აჰა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3546" ANNOTATION_REF="ann3542_flexid_2727e5ef-8933-4865-8b86-56345096af1c">
                <ANNOTATION_VALUE>ხოდა, მე არა [ინტერნეტში არსებული ვერსია] არ [გამიგია]. ბავშვობაში ასე,  ძველები (=ასაკოვნები) ჩვენ ასე გვეტყოდნენ, რომ გადარჩაო ეს [ქალი] და გაიქცაო ამით (=ამგვარად).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3775" ANNOTATION_REF="ann3771_flexid_8e43269f-8904-4a0e-9e48-89536139b8d7">
                <ANNOTATION_VALUE>ეს თურქიც გადახტაო, მგარამ ეს წყალში ჩავარდაო, იქით [მეორე ნაპირზე] ვერ გადახტაო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3981" ANNOTATION_REF="ann3977_flexid_01edeb52-8ca3-4994-8d2c-e9ad6d20a9a7">
                <ANNOTATION_VALUE>დაიხრჩოო იქით ეს თურქი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4060" ANNOTATION_REF="ann4056_flexid_6397a717-0813-49b8-903b-d1a70122bfba">
                <ANNOTATION_VALUE>და მას მერე იმ ადგილს, რადგანაც ახლა ორსული ქალის გადანახტომი ადგილია ის, იმ ადგილს დედამოკა დაერქვაო და ახლაც დედამოკა ჰქვია იმ ადგილს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4396" ANNOTATION_REF="ann4392_flexid_dc78957a-2a63-4886-b539-34d7f7efb20b">
                <ANNOTATION_VALUE>და ქვაც, რომელიც იქაა , ის ქვა, რომელსაც დაახტაო ის ქალი, იმ ქვამ მერე მიიღოო იმის ფორმა  - ორსული ქალის.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4706" ANNOTATION_REF="ann4702_flexid_a5d78387-dc0b-49e7-86d3-c32a765a95af">
                <ANNOTATION_VALUE>ხო ქალის, ქალის ფორმა  მიიღოო [ქვამ].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4826" ANNOTATION_REF="ann4822_flexid_fa683def-413c-43b1-aa03-5b04b2c96f8d">
                <ANNOTATION_VALUE>და იქ  [ინტერნეტში] ნუ, სხვა ვერსიაა. [ის] რომ გაქვავდაო და ნუ მაინც, ესე იგი, ის ისა (ის აზრია გატარებული, რომ) - თურქის ხელი არ შეეხოო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="xmf-fonipa" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-xmf-fonipa">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6" ANNOTATION_REF="ann3_flexid_8f5b27ad-195c-4905-9f2f-688728eb0677">
                <ANNOTATION_VALUE>​​tɛk [bɛrtɛms] rɛ xɔlɔ dɛdɑmɔkʼɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann78" ANNOTATION_REF="ann75_flexid_6e8ce3f3-c740-46c2-9707-62910ac303dc">
                <ANNOTATION_VALUE>​xɔ dɑ dɛdɑmɔkʼɑɑʃi istʼɔriɑ tɛnɛriɛ nɑmdɑ ti ʃkʼɑ ɔʃkʼɑbɑnɛ sɑukʼunɛɛmsiɑ, kʼɔt͡ʃ tkuɑnsən, mɑxutɑɑ sɑukʼunɛʃɛɛ mɑvitɔxutɑʃɑx  ʃuɑ sɑukʼunɛɛpi də dɔ tiʃ ukʼul xɔlɔ tɛ t͡ʃkin sɑmɑrɡɑlɔs dɑ sɑɛrtɔd sɑkɔrtuɔs irɔ ɡitmiɑntxuudu turkɛpi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann583" ANNOTATION_REF="ann580_flexid_2e06c262-4216-4918-8b75-84ebd182c728">
                <ANNOTATION_VALUE>mɑ tɑʃ ɡɑmiɡɛbu tɛnɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann666" ANNOTATION_REF="ann663_flexid_f04490f9-8233-400b-9e4a-98e60d419681">
                <ANNOTATION_VALUE>bɑɣɑnɔbɑʃi is ɡirɑɡɑdək, mut͡ʃʼɔ mixsnɛndɛs tɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann800" ANNOTATION_REF="ann797_flexid_b9b69560-44bd-4480-bf5e-b8880292ed5c">
                <ANNOTATION_VALUE>mɑ sɑɛrtɔd irɔ mɑintʼɛrɛsɛnd istʼɔriɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann885" ANNOTATION_REF="ann882_flexid_a5d22faa-491a-4c34-8a95-5d0f7f6193b5">
                <ANNOTATION_VALUE>dɔ tɛ muʒɑns vɑrduɔ kʼɔt͡ʃii t͡ʃkin ɔd͡ʒɑxʃɑ  stʼumɑri  kimiʃu, vɑrdɑ mutunini,  tinɛp mutun  d͡ʒvɛʃ ɑmbɛɛbs mɔqʼvɛndɛs dɑ, mɑ  tɛk ɡɛvɔxɛd dɔ iriɑtɔ ɡɑpɑt͡sit͡sɛpit  ud͡ʒinɛɛdi  tinɛms.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1332" ANNOTATION_REF="ann1329_flexid_7566eaa5-1e8d-4251-8be4-2431c68837d3">
                <ANNOTATION_VALUE>dɔ tɛnɛpiʃ nɑrɑɡɑdʃɛ...</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1379" ANNOTATION_REF="ann1376_flexid_13e85cde-9ff5-41fa-bff1-a048e7b75748">
                <ANNOTATION_VALUE>ɑsɛ vɛrsiɑ nɑmut intʼɛrnɛtʼis ɡɛd͡zən, t͡ʃʼit͡ʃʼɛ ʃxvɑnɛriɛ dɔ mɑ ɑtɑʃ mɑp ɡənɑɡɛp tɛnɑ, nɑmdɑ, ɑtɛ dɛdɑmɔkʼɑʃ tʼɛritʼɔriɑsə mɔkʼɑt ɔsurs ɡɑmɑtxɔzuɑ  dɑmpʼqʼr...  turkik.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1754" ANNOTATION_REF="ann1751_flexid_313fbf2a-2a90-4309-8a20-325e6d8e8fd5">
                <ANNOTATION_VALUE>kɔd͡ziruɑ tɛmɔmɛntʼis tɛɛnɑ, nɑmut͡s t͡sʼqʼɑrs ɛʃmɑ..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1876" ANNOTATION_REF="ann1873_flexid_d8f6df22-143f-4349-ab60-56d48f904777">
                <ANNOTATION_VALUE>t͡sʼqʼɑr, t͡sʼqʼurɡijʃɛ t͡sʼqʼɑr mɔuɣuduɑ, xɔdɑ ɡɑmɑtxɔzuɑ tɛk ɔt͡ʃʼɔpɑlɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2047" ANNOTATION_REF="ann2044_flexid_f785445c-c694-4c09-87a9-cd63170bf494">
                <ANNOTATION_VALUE>ɔnii, irtʼuɑ tɛ mɔkʼɑt ɔsurk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2125" ANNOTATION_REF="ann2122_flexid_83131b51-3b89-4c3c-a9ea-d9cd43094fe2">
                <ANNOTATION_VALUE>irtʼuɑnə, tʼɛxir pʼid͡ʒʃɛ irtʼuɑ, didqʼɔbkʼɔni tiɡurʃɛni.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2269" ANNOTATION_REF="ann2266_flexid_a77b47ba-a59f-4fb3-b1d0-6df4ef3b7a4d">
                <ANNOTATION_VALUE>ɔni ɡɑmɑtxɔzu ɛ kʼɔt͡ʃik xɔlɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2348" ANNOTATION_REF="ann2345_flexid_c7f230ee-e403-470c-92aa-535b00e655fe">
                <ANNOTATION_VALUE>ɡɑmɑɑtxɔzəni, tʼɑxirs xɔ kɑɑdirtə ɑsɛ, kɑɑdirt, mu kimnɑs ɑsɛ tʼɛxirsəni,  ɡɑt͡ʃɛrduɑ tɛ ɔsurk, ɡɑt͡ʃɛrduɑ dɔ tɛ turkiʃ xɛs ɛʃɑlkʼɔn tiʃɑ isxunuuɑ tʼɛxirʃɑ kɑsxɑpʼukʼɔvɑni.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2794" ANNOTATION_REF="ann2791_flexid_3397adeb-8f29-4b95-a5e3-a33d9bd23508">
                <ANNOTATION_VALUE>ti mɔmɛntʼisiɑ, lɛɡɛndɑ rɛ - tʼɛxirk dɛt͡ʃʼit͡ʃʼɑruɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2916" ANNOTATION_REF="ann2913_flexid_08e80d1f-e867-4d81-8f20-220ea3dc0394">
                <ANNOTATION_VALUE>ti ɑdɡils mɑrtɑjɔ t͡ʃʼit͡ʃʼɛ rɛ,  d͡zɑɑm vit͡sʼrɔ xɛɔbɑ rɛ ti ɑdɡirs, ti dɛdɑmɔkʼɑ rɛ tɛk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3112" ANNOTATION_REF="ann3109_flexid_c2f6bdce-0523-4401-bc31-a0bd93a2bf2e">
                <ANNOTATION_VALUE>dɔ ɑtɛ ɔsurk kɑɑsxɑpʼuɑ dɔ ɡɛɡnɔsxɑpʼuɑ mɑʒiɑ nɑpʼiriʃɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3251" ANNOTATION_REF="ann3248_flexid_4fae2ce9-52eb-4ca9-9b69-4b2abd685491">
                <ANNOTATION_VALUE>mɑ ɑtɑʃ  mɑpud ɡinɑɡɛb, intʼɛrnɛtʼis tɑʃ vɛɡɛd͡z.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3392" ANNOTATION_REF="ann3389_flexid_e9c33d37-c16a-4dd7-8518-d8223ef6b17b">
                <ANNOTATION_VALUE>kuɑs ɡiɡiɔsxɑpʼuɑ dɔ ɡɛkvɑuɑ, ɑtɑʃ ɡɛd͡z.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3530" ANNOTATION_REF="ann3527_flexid_8ae86f7c-ab0b-408d-8605-606b4a2cd7d4">
                <ANNOTATION_VALUE>-ɑhɑ</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3545" ANNOTATION_REF="ann3542_flexid_2727e5ef-8933-4865-8b86-56345096af1c">
                <ANNOTATION_VALUE>- xɔ dɔ mɑ vɑr, bɑɣɑnɔbɑs tɑʃ d͡ʒvɛʃɛp t͡ʃki ɑtɑʃ mit͡sʼiindɛs, nɑmdɑ ɡɛskiduɑ tɛk,  ɔdɔɔ irtʼuɑ tɛt.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3774" ANNOTATION_REF="ann3771_flexid_8e43269f-8904-4a0e-9e48-89536139b8d7">
                <ANNOTATION_VALUE>ɑtɛ turkik xɔlɔ kɑsxɑpʼuɑɑ, mɑrɑ ɛk t͡sʼqʼɑr kɛnɑɑntxuɑ iʃɔ, vɛɡnɑsxɑpʼuɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3980" ANNOTATION_REF="ann3977_flexid_01edeb52-8ca3-4994-8d2c-e9ad6d20a9a7">
                <ANNOTATION_VALUE>iʃɔ diiʃkʼviduɑ tɛ turkik.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4059" ANNOTATION_REF="ann4056_flexid_6397a717-0813-49b8-903b-d1a70122bfba">
                <ANNOTATION_VALUE>ɔdɔ tiʃ ukʼuli ti ɑrdɡils, rɑxɑnt ɑsɛ mɔkʼɑt ɔsuriʃi ɡiɡnɑsxɑpʼinɑ ɑdɡili rɛ tinɑni, ti ɑdɡils dɛdɑmɔkʼɑ kiɡiɑduɑ dɔ ɑsɛ xɔlɔ dɛdɑmɔkʼɑ d͡ʒɔxɔ ti ɑdɡils.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4395" ANNOTATION_REF="ann4392_flexid_dc78957a-2a63-4886-b539-34d7f7efb20b">
                <ANNOTATION_VALUE>dɔ kuɑ xɔlɔ nɑmut tɛk rɛni,  ɛti kuɑ nɑmut͡s ɡiɔsxɑpʼuɑ ti ɔsurkəni, ti kuɑk ukʼuli miiɣuɑ iʃ pɔrmɑ mɔkʼɑt... mɔkʼɑt ɔsuriʃ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4705" ANNOTATION_REF="ann4702_flexid_a5d78387-dc0b-49e7-86d3-c32a765a95af">
                <ANNOTATION_VALUE>xɔ, ɔsuriʃ, kɑlis pɔrmɑ, ɑnu ɔsuriʃ pɔrmɑ miiɣuɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4825" ANNOTATION_REF="ann4822_flexid_fa683def-413c-43b1-aa03-5b04b2c96f8d">
                <ANNOTATION_VALUE>ɔdɔ ɛk nu ʃxvɑ vɛrsiɑ rɛ nɑmdɑɑ ɡɛkvɑuɑ dɔ nu mɑint͡s ɛsɛ iɡi, ti, isɑ turkis xɛs, xɛk vɛʃiɛx.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
