                TIME_SLOT_REF1="ts52" TIME_SLOT_REF2="ts53">
                <ANNOTATION_VALUE>ათე თურქიქ ხოლო ქასხაპუაა, მარა ექ წყარ ქენაანთხუა იშო, ვეგნასხაპუა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
