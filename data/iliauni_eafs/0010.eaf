    <TIER LANG_REF="xmf" LINGUISTIC_TYPE_REF="phrase"
        PARENT_REF="A_paragraph" TIER_ID="A_phrase-txt-xmf">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4_flexid_e102df48-df25-4510-ad17-f62fe11e4dd6"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>ჯვარიში, ათე ტერიტორიასჷ ოხუუ დო ტობავარჩხილჷცჷნ ფერი, ლეგენდა რე ართ ათეშნერი, ნამუთ მა მაბრუო კლასის ვორდინ თიწკჷმა, ქჷდმავალეს სკოლას.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann391_flexid_ad62b07b-6359-430c-a857-c20eebd1ff63"
                TIME_SLOT_REF1="ts5" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>დო ჩქიმი მეზობელ კოჩქ დო მანგარ, ვეფხისტყაოსანც ზეპირო რაგადანდ დო მუ ხოლო ლექსეფს ჭარჷნდჷნ ფერ კოჩქ, გალ სამუშია რდჷ დო თიქ ქჷნმოჭარაფუ დო ათეშნერ რე თე ლეგენდაა:</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann824_flexid_6a1423e8-e9e6-428d-8895-3815fa59bcc8"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>ჯვარშავა მიშუა იშ ყარაჩიშჷ, ყარაჩ ჩრდილოეთ კავკასია რე, ყარაჩაი-ჩერქეზეთის რესპუბლიკა რე ასენ, ყარაჩშევა გილეშუა ოჩოკოჩი, დეემ კოჩი მუდგარენ, ნამუთია ათაქია ქიმიშუა დო  გეუვალუანდუა თე მეწონებუდუნი ფერ ძღაბის დო მიდეჸუნანდუა იშო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1367_flexid_7c94aca2-c13c-4d70-8470-899d00ffbfa0"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>თეშა მუთუნქ ვემმახვარჷნესია ჯვარელეფც, მუთუნცუ მუთუნით ვამარიებესია თეშა დო ბრელ ხანც იწვალებდესია თაში.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1682_flexid_5053dfbd-a485-4b5e-985e-292c65b0429b"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts16">
                <ANNOTATION_VALUE>დო ამ დროს გამკორჩქინდუა  თე დროს თაქი ხოლო ათეჯგურა დევგმირ მიდგარენი კეთილ კოჩქ დო არამხუტუ ჯოხონ ფერ კოჩი, არამხუტუ ჯოხონ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1991_flexid_15b84b4f-0bd4-4227-a244-bfd94ddd88d2"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts17">
                <ANNOTATION_VALUE>დო თინა ხოლო ადგილობრივ ვაჸოფე, მარა გამკორჩქინდუა თექ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2138_flexid_668e31d3-fe0b-4555-a61a-f55ce3c3716a"
                TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts19">
                <ANNOTATION_VALUE>ჯვარალემქ ქოთხიისია თესჷ, ქჷმმახვარითია.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2279_flexid_afc20f71-3c17-4b97-80a2-78417401ab08"
                TIME_SLOT_REF1="ts20" TIME_SLOT_REF2="ts21">
                <ANNOTATION_VALUE>ათეჯგუა, ათეჯგუა თაშია, თაშიან, უწუა  - ჯგირია ოდო  ქჷდოხვადუა წი თი კოჩქ ქჷმორთუან.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2524_flexid_f42dc4cd-e3db-4994-8cb5-1eb2ae553363"
                TIME_SLOT_REF1="ts22" TIME_SLOT_REF2="ts23">
                <ANNOTATION_VALUE>თინა გილეშუა ათაქ ოხაჩქუე ჯოხო გვალა დო ეთექ ჯოხო ყვირა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2684_flexid_0b49db13-b29e-420d-b1d0-c3fe6b69ae3f"
                TIME_SLOT_REF1="ts24" TIME_SLOT_REF2="ts25">
                <ANNOTATION_VALUE>გიმე ხო მოურც ამარი, ათაქ მაგანა მოურდუ მდინარე დო ათავრეშე რე  ყვიირა, ორი ათას მეტრამდეა სიმაღლე, ეურე ოხაჩქუე რე, თენეფ ჟირხოლო ჟიშე გინაჯინექჷნი, სკვამ რენა ჯიმალეფცაჲე.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3077_flexid_43092591-3ab0-45c6-b0f9-fcf950668275"
                TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts27">
                <ANNOTATION_VALUE>ხოდა თექ გვალეფც რე ინჭეფი, ასე ხოლო, თის სამკუთხედჷ ათეშნერი ინოსოფილი ადგილეფჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3262_flexid_59207f39-3271-492a-8e45-0bb9e6b80883"
                TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts29">
                <ANNOTATION_VALUE>მინ დიხას თირ ხოლო ინოსკიდ ჯიშტი დო ჭყჷშეფ თექ მუდას ინოდვანა, ხორცის შენახჷნა ა  მუდგარენეფ ფერ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3526_flexid_68df40d4-2a35-4685-b066-7a4da8b77db8"
                TIME_SLOT_REF1="ts30" TIME_SLOT_REF2="ts31">
                <ANNOTATION_VALUE>თინა ბრელ რე თი გვალასჷთ დო თე გვალასჷთ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3666_flexid_30fedf67-a5f0-4e89-b138-59471355d987"
                TIME_SLOT_REF1="ts32" TIME_SLOT_REF2="ts33">
                <ANNOTATION_VALUE>ჸათე ყვირასჷ რე ქუაქანცალია, ეს ცალკე დასრ... თე ლეგენდაშ ბოლოს რე თი ქუაქანცალიაშ  გურშენჷ, დაკავშირებულ რე თეწკჷმა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3916_flexid_d8e3c5f6-5b27-445e-803c-e9af707a520f"
                TIME_SLOT_REF1="ts36" TIME_SLOT_REF2="ts38">
                <ANNOTATION_VALUE>ქჷმორთ, პირდაპირ ქინკიჯინ ასე თეურშენი გვალასდჷნი, თაურშე ქჷდუძახუა არამხუტუქ,  ვეგმართავა, თაქ მა ვორექია დო ვაქიმინავა თენა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4280_flexid_4d210514-d74e-45da-8a14-f1761ad0467a"
                TIME_SLOT_REF1="ts37" TIME_SLOT_REF2="ts39">
                <ANNOTATION_VALUE>დო  ექ  უწუა, სი მი რექ, თაშ თეშია დო მოკლეთ იწკჷმა ქიბჩხუბათია.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4471_flexid_4a91d3b6-a8cd-41f2-8842-b19747618bfe"
                TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts44">
                <ANNOTATION_VALUE>ყვირას ქჷგმოდჷრთ არამხუტუქ, ყვირაშ გვალასჷ, ოხაჩქუეს - ოჩოკოჩიქ დო ქუდუჭყეს ართიანს ქუალეფიშ ჸოთამა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4700_flexid_f27e6c83-2ac3-4dcb-9bd8-8f2a56b5dd7a"
                TIME_SLOT_REF1="ts43" TIME_SLOT_REF2="ts45">
                <ANNOTATION_VALUE>ასე ენეფ ოჸოთანდეს თე ქუალეფ, მუშ მადიდა იჸედ, ხომ ქო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann4900_flexid_df52ef5f-e0c1-4629-ba21-7db1d36c55ee"
                TIME_SLOT_REF1="ts46" TIME_SLOT_REF2="ts48">
                <ANNOTATION_VALUE>ხოდა, იბრძოლეს კაი ხანი, რაღაც ვაფშ ასე, მარა თექი  რამდენიმე, მუზმარენ დღასჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann5052_flexid_cb6a3aa4-6ad4-4c51-ae4f-0eedcd41bb42"
                TIME_SLOT_REF1="ts47" TIME_SLOT_REF2="ts50">
                <ANNOTATION_VALUE>დო ბოლოს არამხუტუქია დოჭკირუა, ქჷმახვამილუა თი ქუა დო უკულ მაღურუდუნ  ფერქ აშო ქაჸოთუა თი ბოლო ძალათ დოშაყარუუა რახანთჷ, ქაჸოთუა დო არამხუტუს ქჷმოხვადუა ხესჷ, კჷლეს დო ჭი გოჭკირუა რა, დაჭრა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann5601_flexid_86cf3cf6-3269-47eb-883a-1fb84d9f09f1"
                TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts52">
                <ANNOTATION_VALUE>იქ დოღურჷ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann5645_flexid_ee493e77-2497-4871-9a49-ffafe931d5f2"
                TIME_SLOT_REF1="ts51" TIME_SLOT_REF2="ts53">
                <ANNOTATION_VALUE>დო არამხუტუ ღორონთეფიშ ჩამომავალიდუა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann5729_flexid_8705ecad-e32a-4927-befc-78a3556899bd"
                TIME_SLOT_REF1="ts54" TIME_SLOT_REF2="ts56">
                <ANNOTATION_VALUE>უკულია ტობავარჩხილს ქინიბონუა თე ხე.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann5829_flexid_981bc5b1-e16f-4ba0-9e0f-f319205d07ad"
                TIME_SLOT_REF1="ts55" TIME_SLOT_REF2="ts58">
                <ANNOTATION_VALUE>ოდო ათიშ გურშენ ტობავარჩხილიშ წყარ რენია წმინდა დო ამდღა ხოლო ასე, მა ხოლო გილუურქუ ტობავარჩხილშა, ასე ბოლო წანემს ჟირ სუმშახ ქუვორდი დო იშენ ვორიდჷდ თი ამბეს, მით უმეტეს - ჯვეშეფი.</ANNOTATION_VALUE>
