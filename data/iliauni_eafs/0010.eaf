        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2685" ANNOTATION_REF="ann2684_flexid_0b49db13-b29e-420d-b1d0-c3fe6b69ae3f">
                <ANNOTATION_VALUE>2.8</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
