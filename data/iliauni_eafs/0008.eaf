    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann9" ANNOTATION_REF="ann7_flexid_6e12951c-5ada-446c-8474-37acb0b84437">
                <ANNOTATION_VALUE>All right. Now let us turn to your village. The name of your village is Targameuli. Why was it named so?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann305" ANNOTATION_REF="ann303_flexid_54013928-20ad-4eac-b00b-499ed2a45232">
                <ANNOTATION_VALUE>Well, Targamui - this is how it translates into Megrelian, which means 'rested land', where there was, this is how we, Megrelians refer to a land where nobody has stepped; this is where these people settled, this place.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann762" ANNOTATION_REF="ann760_flexid_2c48dec1-69ba-4bee-bcb2-a5b91d94e31f">
                <ANNOTATION_VALUE>Here is Targameuli; the river Tekhuri flows, people live on the left and right banks of the Tekhuri.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann961" ANNOTATION_REF="ann959_flexid_052d01c9-53be-405e-bff0-31c7ca0b825e">
                <ANNOTATION_VALUE>In earlier centuries, they lived in the mountains where presently only St George's church is preseved which our ancestors referred to as a shrine.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1284" ANNOTATION_REF="ann1282_flexid_829b6447-ebf9-428f-88a9-cfaa32163380">
                <ANNOTATION_VALUE>There also was a cemetery.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1347" ANNOTATION_REF="ann1345_flexid_1a119e87-2eee-46d9-b881-08ac990166e1">
                <ANNOTATION_VALUE>Later on, people moved downwards because the Tekhuri was spread more widely and water was spread over more territory; as soon as the Tekhuri got lowered, villages appeared on its lower banks.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1796" ANNOTATION_REF="ann1794_flexid_02f855d5-2153-49a0-b0e7-bc07e830695c">
                <ANNOTATION_VALUE>How long does the village exist? Do you know people of which surnames live here? How many households are there?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2173" ANNOTATION_REF="ann2171_flexid_0e8ebc9b-01e0-40fa-861d-0054c530bcdd">
                <ANNOTATION_VALUE>Targamuli in Megrelian, normally, Targamuli nowhere... Iooked a lot in history [=sources] and it is not written from which time it exists, but people of various surnames live here.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2513" ANNOTATION_REF="ann2511_flexid_a2e08b87-db00-4ae9-b039-cfa40531da1d">
                <ANNOTATION_VALUE>For instance, there are Mishvelia, Naroushvili, Partsvania, Tsaava; there is a diversity of surnames.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2730" ANNOTATION_REF="ann2728_flexid_ac3b8a53-4690-4d76-863c-231170e6b9cb">
                <ANNOTATION_VALUE>The principal culture of our village is vine; vine-growers live here. Vine saplings are growm here, Megrelian breeds.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3024" ANNOTATION_REF="ann3022_flexid_95dca461-83d8-4e4f-9119-731d48714a8d">
                <ANNOTATION_VALUE>In the past, it was one of the cradles of Megrelian breeds.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3155" ANNOTATION_REF="ann3153_flexid_5f1b93eb-75c2-4109-afe6-6ea9bd23a76b">
                <ANNOTATION_VALUE>Most of the vineyards in Samegrelo were supplied from here, from our area.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3373" ANNOTATION_REF="ann3371_flexid_9c95a1c9-8457-45e4-b32d-c6e2c1cdf5e6">
                <ANNOTATION_VALUE>Which is your most favorite place in this village? Which place are you fond of most of all and why?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3600" ANNOTATION_REF="ann3598_flexid_9ce06753-8732-47ad-a6e8-b86064347b5e">
                <ANNOTATION_VALUE>My favorite place is a bank of the river Tekhura and another one is our shrine where there is St George's church.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3861" ANNOTATION_REF="ann3859_flexid_aa9449d5-519d-4ed8-8bd5-ee9b5883957e">
                <ANNOTATION_VALUE>When you climb there, the entire village is visible from above and you perceive warmth of soul there, so to say.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4136" ANNOTATION_REF="ann4134_flexid_7589376e-3b7f-40c7-b417-882e19a12d63">
                <ANNOTATION_VALUE>You just mentioned the shrine. Is there any legend associated with the shrine?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4402" ANNOTATION_REF="ann4400_flexid_9439c7a5-7be0-494c-94a0-a00ed37c70df">
                <ANNOTATION_VALUE>As far as I know from the history of my family, the patron icon is St George's church; it has been known historically that our family followed customs in a particular way.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4826" ANNOTATION_REF="ann4824_flexid_9da97b71-b3fd-4224-8fca-866bf40459ca">
                <ANNOTATION_VALUE>Holidays, St George's Day is celebrated twice a year: on November 23 and May 6. For our area it was particular, a particular holiday which we celebrate, St George's Day.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5240" ANNOTATION_REF="ann5238_flexid_d859fa0e-68c4-4884-9906-4f84ce83f1c6">
                <ANNOTATION_VALUE>All representatives of our surname are people from our village.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5396" ANNOTATION_REF="ann5394_flexid_a8440c49-08b3-4fce-822f-18bff3e6dcb8">
                <ANNOTATION_VALUE>Well, when was the holiday celebrated, on 23 or 6?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5540" ANNOTATION_REF="ann5538_flexid_5f6465ff-cf72-43e4-a852-18a836cb9000">
                <ANNOTATION_VALUE>On November 23 and May 6.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5632" ANNOTATION_REF="ann5630_flexid_777caff9-18a8-4c84-bbb4-c4df2a7fe87c">
                <ANNOTATION_VALUE>That is, did you celebrate it twice?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5715" ANNOTATION_REF="ann5713_flexid_9500f078-9241-4d1b-8eec-e2f57ea8626a">
                <ANNOTATION_VALUE>We normally celebrate both holidays.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5812" ANNOTATION_REF="ann5810_flexid_c9f87409-ce84-4ca1-a76d-4c2166228f81">
                <ANNOTATION_VALUE>And, what do you do? How do you celebrate it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5963" ANNOTATION_REF="ann5961_flexid_2d3b8232-aab0-42a3-8248-3e1befc9b572">
                <ANNOTATION_VALUE>How it is celebrated, a divine service is performed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6129" ANNOTATION_REF="ann6127_flexid_8772e99b-f43f-420d-bbcf-ff07d09a78b4">
                <ANNOTATION_VALUE>As its religious aspect, a priest arrives, a "babachia" [=father], so to say.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6324" ANNOTATION_REF="ann6322_flexid_9d90efec-f33d-4fea-9baf-ac4db7926614">
                <ANNOTATION_VALUE>He arrives, performs a divine service, and afterwards there is a traditional dinner.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6478" ANNOTATION_REF="ann6476_flexid_714218f1-23f4-4af8-8132-9c8541768366">
                <ANNOTATION_VALUE>People from all over the village, children, youth join a dinner, and old stories are recollected, old customs are recollected, and so on.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="ka-Brai" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-ka-Brai">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann11" ANNOTATION_REF="ann7_flexid_6e12951c-5ada-446c-8474-37acb0b84437">
                <ANNOTATION_VALUE>-კარგი, ახლა გადავიდეთ თქვენს სოფელზე, თქვენს სოფელს ჰქვია თარგამეული, ეს სახელი რატომ დაერქვა, რატომ დაარქვეს ეს სახელი?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann307" ANNOTATION_REF="ann303_flexid_54013928-20ad-4eac-b00b-499ed2a45232">
                <ANNOTATION_VALUE>ანუ თარგამუი -ასეა მეგრულად რომ გადავიყვანოთ,  რომელიც ნიშნავს დასვენებულ მიწას; სადაც იყო,  გაუვლელ [=სადაც არავის გაუვლია] მიწას ვეძახით ჩვენ - მეგრელები, [ასეთი მიწა].  სადაც მოხდა ამ ხალხის ერთ-ერთი დასახლება, ამ ადგილზე [=სადაც დაასახლეს ხალხი].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann764" ANNOTATION_REF="ann760_flexid_2c48dec1-69ba-4bee-bcb2-a5b91d94e31f">
                <ANNOTATION_VALUE>ანუ [აქ] არის თარგამეული: ტეხური მიდის (=მიედინება), ტეხურის მარცხენა და მარჯვენა  სანაპიროებზე ხალხი ცხოვრობს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann963" ANNOTATION_REF="ann959_flexid_052d01c9-53be-405e-bff0-31c7ca0b825e">
                <ANNOTATION_VALUE>ადრე საუკუნეებში მთაში ცხოვრობდა, სადაც დღეს მხოლოდ წმინდა გიორგის ეკლესიაა შემორჩენილი, სადაც  [=რომელსაც] სალოცავს ეძახდნენ ჩვენი წინაპრები და ის იყო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1286" ANNOTATION_REF="ann1282_flexid_829b6447-ebf9-428f-88a9-cfaa32163380">
                <ANNOTATION_VALUE>სასაფლაოც იქ იყო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1349" ANNOTATION_REF="ann1345_flexid_1a119e87-2eee-46d9-b881-08ac990166e1">
                <ANNOTATION_VALUE>მერე-მერე ხალხმა დაბლა-დაბლა ჩაიწია, იმიტომ რომ ტეხური უფრო დიდი მასშტაბით იყო გაშლილი და წყალი უფრო იყო გაშლილი; როგორც კი დაიწია ტეხურმა, ტეხურის დაბლა სანაპიროებდა გაშენდა სოფლები.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1798" ANNOTATION_REF="ann1794_flexid_02f855d5-2153-49a0-b0e7-bc07e830695c">
                <ANNOTATION_VALUE>- რამდენი წელია, რაც ეს სოფელი არსებობს და თუ იცით, რა გვარის ხალხი ცხოვრობს აქ, და რამდენი კომლია?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2175" ANNOTATION_REF="ann2171_flexid_0e8ebc9b-01e0-40fa-861d-0054c530bcdd">
                <ANNOTATION_VALUE>თარგამული მეგრულად, ჩვეულებრივ თარგამული არსად ... ისტორიაში [=წყაროებში] ბევრი ვეძებე და არ წერია, რომ საწყისი რა დროიდან არის [=რა დროიდან არსებობს], მაგრამ, როგორც ასეთი, ხალხი სხვადასხვა გვარისა ცხოვრობს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2515" ANNOTATION_REF="ann2511_flexid_a2e08b87-db00-4ae9-b039-cfa40531da1d">
                <ANNOTATION_VALUE>სიტყვაზე არის  მიშველიები, ნაროუშვილები, ფარცვანიები, ცაავები; გვარში მრავალფეროვნებაა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2732" ANNOTATION_REF="ann2728_flexid_ac3b8a53-4690-4d76-863c-231170e6b9cb">
                <ANNOTATION_VALUE>ჩვენი სოფლის ძირითადი კულტურა არის ვენახი, მევენახე ხალხი ცხოვრობს აქ, ნერგი, ნერგები გამოჰყავთ, მეგრული ჯიშები.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3026" ANNOTATION_REF="ann3022_flexid_95dca461-83d8-4e4f-9119-731d48714a8d">
                <ANNOTATION_VALUE>იქ იყო ადრე მეგრული ჯიშების ერთ-ერთი აკვანი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3157" ANNOTATION_REF="ann3153_flexid_5f1b93eb-75c2-4109-afe6-6ea9bd23a76b">
                <ANNOTATION_VALUE>სამეგრელოში ძირითადად, რაც კი ვენახებია, [ყველას] მომარაგება  აქედან  ხდებოდა, ჩვენი კუთხიდან.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3375" ANNOTATION_REF="ann3371_flexid_9c95a1c9-8457-45e4-b32d-c6e2c1cdf5e6">
                <ANNOTATION_VALUE>-აი, ამ სოფელში თქვენი ყველაზე საყვარელი ადგილი რომელია? რომელი ადგილი გიყვართ ყველაზე მეტად და რატომ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3602" ANNOTATION_REF="ann3598_flexid_9ce06753-8732-47ad-a6e8-b86064347b5e">
                <ANNOTATION_VALUE>- ჩემი საყვარელი ადგილია ტეხურის პირი და მეორეა ჩვენი სალოცავი, სადაც წმინდა გიორგის სახელობის ეკლესია გვაქვს</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3863" ANNOTATION_REF="ann3859_flexid_aa9449d5-519d-4ed8-8bd5-ee9b5883957e">
                <ANNOTATION_VALUE>იქ რომ ახვალ მაღლიდან მთელი, მთელი სოფელი მოჩანს და იქ სულის სითბოს გებულობ, რა, ასე რომ ვთქვათ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4138" ANNOTATION_REF="ann4134_flexid_7589376e-3b7f-40c7-b417-882e19a12d63">
                <ANNOTATION_VALUE>-თქვენ ახლა ახსენეთ სალოცაობა[ ???? ], და რამე მასთან დაკავშირებული თქმულება ან გადმოცემა ხომ არ არის, რომელიც იმ სალოცავს უკავშირდება.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4404" ANNOTATION_REF="ann4400_flexid_9439c7a5-7be0-494c-94a0-a00ed37c70df">
                <ANNOTATION_VALUE>- ჩვენი გვარის ერთ-ერთი ისტორია [=ისტორიიდან] როგორც ვიცი, მფარველი ხატი  არის წმინდა გიორგი სალოცავი;  ისტორიულად ცნობილია, რომ ჩვენი გვარი განსაკუთრებულად იცავდა წეს-ჩვეულებებს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4828" ANNOTATION_REF="ann4824_flexid_9da97b71-b3fd-4224-8fca-866bf40459ca">
                <ANNOTATION_VALUE>დღესასწაულები, წმინდა გიორგობა წელიწადში ორჯერ რომ არის, ოცდასამ ნოემბერს და ექვს მაისს, ჩვენი კუთხისთვის განსაკუთრებული ეს იყო; განსაკუთრებული დღესასწაული,  რომელსაც [=როდესაც] ჩვენ წმინდა გიორგობას აღვნიშნავთ;</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5242" ANNOTATION_REF="ann5238_flexid_d859fa0e-68c4-4884-9906-4f84ce83f1c6">
                <ANNOTATION_VALUE>ჩვენი გვარის ყველა წარმომადგენელი ჩვენი სოფლის, კუთხის  ხალხია.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5398" ANNOTATION_REF="ann5394_flexid_a8440c49-08b3-4fce-822f-18bff3e6dcb8">
                <ANNOTATION_VALUE>- ანუ ამ დღესასწაულს როდის აღნიშნავდნენ, ოცდასამში თუ ექვსში?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5542" ANNOTATION_REF="ann5538_flexid_5f6465ff-cf72-43e4-a852-18a836cb9000">
                <ANNOTATION_VALUE>- ოცდასამ ნოემბერს და ექვს მაისს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5634" ANNOTATION_REF="ann5630_flexid_777caff9-18a8-4c84-bbb4-c4df2a7fe87c">
                <ANNOTATION_VALUE>- ანუ ორივე დღესასწაულს [=ორივეჯერ] აღნიშნავთ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5717" ANNOTATION_REF="ann5713_flexid_9500f078-9241-4d1b-8eec-e2f57ea8626a">
                <ANNOTATION_VALUE>- ორივე დღესასწაულს აღვნიშნავთ ჩვეულებრივად.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5814" ANNOTATION_REF="ann5810_flexid_c9f87409-ce84-4ca1-a76d-4c2166228f81">
                <ANNOTATION_VALUE>- და რას აკეთებთ, ანუ როგორ აღნიშნავთ? რას აკეთებთ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5965" ANNOTATION_REF="ann5961_flexid_2d3b8232-aab0-42a3-8248-3e1befc9b572">
                <ANNOTATION_VALUE>- ანუ [როგორ] აღნშნავენ, ძირითადად მიდის წირვა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6131" ANNOTATION_REF="ann6127_flexid_8772e99b-f43f-420d-bbcf-ff07d09a78b4">
                <ANNOTATION_VALUE>საეკლესიო რომ ავიღოთ, მოდის მღვდელი, ბაბაჩია [=მამაო], ასე რომ ვთქვათ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6326" ANNOTATION_REF="ann6322_flexid_9d90efec-f33d-4fea-9baf-ac4db7926614">
                <ANNOTATION_VALUE>მოდის, წირვას აღავლენს და შემდეგ ჩვეულებრივ ტრადიციული ტრაპეზი იმართება.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6480" ANNOTATION_REF="ann6476_flexid_714218f1-23f4-4af8-8132-9c8541768366">
                <ANNOTATION_VALUE>მთელი სოფლის ხალხი, ბავშვები, ახალგაზრდები ტრაპეზს მიუსხდება და ძველი ამბების გახსენება მიდის, ძველი წესების გახსენება მიდის და ასე.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="xmf-fonipa" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-xmf-fonipa">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann10" ANNOTATION_REF="ann7_flexid_6e12951c-5ada-446c-8474-37acb0b84437">
                <ANNOTATION_VALUE>d͡ʒɡiir, ɑsɛ ɡɛɡnɔvtɑɑt tkvɑɑn sɔpɛjʃɑɑ, tkvɑɑn sɔpɛjs d͡ʒɔxɔ tɑrɡɑmɛulii, tɛ sɑxɛjk muʃɛɛn ɡiɑduu, muʃɛɛn ɡiɔdvɛɛs tɛ sɑxɛi?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann306" ANNOTATION_REF="ann303_flexid_54013928-20ad-4eac-b00b-499ed2a45232">
                <ANNOTATION_VALUE>ɑnu tɑrɡɑmuji tɑʃiɛɛ, mɑrɡɑjurɔ ɡɛɡnipʼɔnɑɑt, nɑmut d͡ʒɔxɔɔ mɔsvɑnd͡ʒɛji dixɑɑsə, sɔdɛt͡s ɔrdu, uji dixɑs ud͡zɑxuut t͡ʃkii -  mɑrɡɑjɛɛp, sɔdɛt͡s kumɔxvɑɑd tɛ xɑlxiʃ ɑrt ɑrt dɑsɑxlɛbɑɑk tɛ ɑdɡijs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann763" ANNOTATION_REF="ann760_flexid_2c48dec1-69ba-4bee-bcb2-a5b91d94e31f">
                <ANNOTATION_VALUE>ɑnu rɛ tɑrɡɑmuji, tʼɛxir mɛɛurs, tʼɛxiriʃ kʼvɑrt͡ʃxɑn dɔ mɑrd͡zɡvɑn sɑnɑpʼirɔɛɛps xɑlxi t͡sxɔvrɛɛns.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann962" ANNOTATION_REF="ann959_flexid_052d01c9-53be-405e-bff0-31c7ca0b825e">
                <ANNOTATION_VALUE>t͡sxɔvrɛɛnd ɑdrɛ sɑukʼunɛɛps ɡɔjɑɑs, sɔdɛt͡s ɑmdɣɑɑ xvɑjɛ rɛ ʃɛmɔrt͡ʃɛnii t͡sʼmindɑ ɡiɔrɡiʃ ɛkʼlɛsiɑɑ, sɔdɛ ɔxvɑmɛɛs ud͡zɑxudɛɛs t͡ʃkin t͡sʼinɑpʼrɛpii dɔ tinɑ ɔrdu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1285" ANNOTATION_REF="ann1282_flexid_829b6447-ebf9-428f-88a9-cfaa32163380">
                <ANNOTATION_VALUE>sɑsɑplɑɔ xɔjɔ tɛki du.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1348" ANNOTATION_REF="ann1345_flexid_1a119e87-2eee-46d9-b881-08ac990166e1">
                <ANNOTATION_VALUE>ukʼuj ukʼuj  xɑlxiik tudɔ tudɔ ɡijɛkʼiin, tiɡurʃɛn nɑmdɡɑ tʼɛxir  uprɔ did mɑʃtʼɑbiit ɔrd ɡɔpɑt͡ʃiji dɔ t͡sʼqʼɑri uprɔ didi rdə; mut͡ʃʼɔ dɛɛrkʼu tʼɛxiirkəni, uprɔ tudɔ tʼɛxirs, sɑnɑpʼirɔɛps ɡɛɛʃɛn, ɡɛɛʃɛnin sɔpɛjk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1797" ANNOTATION_REF="ann1794_flexid_02f855d5-2153-49a0-b0e7-bc07e830695c">
                <ANNOTATION_VALUE>tɛ sɔpɛrs, ɑnu muzmɑ xɑniɛ mut ɑnu rɛ, kɔit͡ʃkənɑdɑɑ, muzmɑ t͡sʼɑnɑɛ ɑrsɛbɛɛns dɔ mɑɡɑjitɔ mu ɡvɑrii xɑɑlx t͡sxɔvrɛɛns tɑɑk  dɔ muzmɑ kʼɔmliɛ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2174" ANNOTATION_REF="ann2171_flexid_0e8ebc9b-01e0-40fa-861d-0054c530bcdd">
                <ANNOTATION_VALUE>tɑrɡɑmuli mɑrɡɑjurɔ, t͡ʃɛulɛbriv tɑrɡɑmuli sɔtin vɑɑ... istʼɔriɑɑs brɛj vɡɔri dɔ vɑɑt͡ʃʼɑr, nɑmdɡɑ sɑt͡sʼqʼisi mudrɔʃɛ rɛ, mɑrɑ mut͡ʃʼɔ tɑʃin, xɑlxii d͡ziritɑdɔ tɑk ʃxvɑdɔʃxvɑ ɡvɑrɛpi t͡sxɔvrɛɛns.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2514" ANNOTATION_REF="ann2511_flexid_a2e08b87-db00-4ae9-b039-cfa40531da1d">
                <ANNOTATION_VALUE>rɛ sitʼqʼvɑʃɑ miʃvɛliɛpi, nɑruskʼuɑjɛpii, rɛɛnɑ sɑrtɑniɛɛp, pɑrt͡svɑniɛɛp, t͡sɑvɛpi, rɛ mrɑvɑlpɛrɔvnɛbɑ ɡvɑɑrs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2731" ANNOTATION_REF="ann2728_flexid_ac3b8a53-4690-4d76-863c-231170e6b9cb">
                <ANNOTATION_VALUE>d͡ziritɑd t͡ʃkiin sɔpɛjiʃi ɑrt ɑrt kʼultʼurɑ, nɑmut͡s rɛ binɛxi dɔ mɛbinɛxɛɛ xɑlx t͡sxɔvrɛns tɑk;  nɛrɡii, nɛrɡɛpi ɡiʃmɑʔunɑ mɑrɡɑjur d͡ʒiʃɛpii.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3025" ANNOTATION_REF="ann3022_flexid_95dca461-83d8-4e4f-9119-731d48714a8d">
                <ANNOTATION_VALUE>tɑk ɔrd ɑdrɛ mɑrɡɑjur d͡ʒiʃɛpiʃ ɑrt ɑrti ɑkʼvɑnii duu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3156" ANNOTATION_REF="ann3153_flexid_5f1b93eb-75c2-4109-afe6-6ea9bd23a76b">
                <ANNOTATION_VALUE>d͡ziritɑd sɑmɑrɡɑjɔʃɛɛ, mut umrɑvlɛɛst͡sʼilɔ, mut ɡɔɔt͡ʃɑɑns binɛxiin, tɑurɛʃɛ mutmɔxvɑduu mɔmɑrɑɡɛbɑɑ, t͡ʃkin kʼutxuʃi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3374" ANNOTATION_REF="ann3371_flexid_9c95a1c9-8457-45e4-b32d-c6e2c1cdf5e6">
                <ANNOTATION_VALUE>ɑi tɛ sɔpɛrs tkvɑɑn ɑrd͡zɑʃɛɛ sɑqʼvɑrɛi ɑdɡii nɑmuɛ; nɑm ɑdɡii ɡiɔrɑ ɑrd͡zɑʃɛ mɛtʼɔ dɔ muʃɛni?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3601" ANNOTATION_REF="ann3598_flexid_9ce06753-8732-47ad-a6e8-b86064347b5e">
                <ANNOTATION_VALUE>t͡ʃkim sɑqʼvɑrɛi ɑdɡiji rɛ tʼɛxirpʼiid͡ʒ dɔ mɑʒiɑ rɛ t͡ʃkiin  ɔxvɑmɛɛ, sɔdɛt͡s t͡sʼmindɑ ɡiɔrɡiʃ sɑxɛlɔbɑʃ ɛkʼlɛsiɑ miɣunɑɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3862" ANNOTATION_REF="ann3859_flexid_aa9449d5-519d-4ed8-8bd5-ee9b5883957e">
                <ANNOTATION_VALUE>tɛk ɛkʼijɛnkən ʒidɔxʃɛɛ  mtɛl, mtɛji sɔpɛi mɔrt͡ʃkuu dɔ ɑi tɛk ʃuriiʃ sitʼibɑɑs ɡinɑpujɛnk rɑɑ, ɑtɑʃ kɔvtkuɑtə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4137" ANNOTATION_REF="ann4134_flexid_7589376e-3b7f-40c7-b417-882e19a12d63">
                <ANNOTATION_VALUE>dɔ tɛ sɔpɛɛrs, ɑi tundɑt͡s ɔxvɑmɛɔbɑ ɑxsɛniit ɑsɛ tkvɑ, rɛnɔ tiit͡sʼkʼmɑ dɑkʼɑvʃirɛbuj mutun tkmulɛbɑɑ ɑn ɡɑdmɔt͡sɛmɑ, nɑmut ti ɔxvɑmɛɛs ukʼɑvʃirdɛbuu ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4403" ANNOTATION_REF="ann4400_flexid_9439c7a5-7be0-494c-94a0-a00ed37c70df">
                <ANNOTATION_VALUE>t͡ʃkin ɡvɑriiʃ ɑrt ɑrt rɛ istʼɔriɑ mut͡ʃʼɔ mit͡ʃkunɑn, t͡ʃkin ɡvɑriiʃ, ɑnu  mpɑrvɛji xɑtʼi rɛ t͡sʼmidɑ ɡiɔrɡiʃ ɔxvɑmɛ, sɔdɛt͡s t͡ʃki istʼɔriɑʃɛ muursu nɑmdɡɑ, t͡ʃkini ɡvɑri ɡɑnsɑkʼutrɛbuji  it͡svɛɛndu t͡sʼɛs t͡ʃvɛulɛbɛps.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4827" ANNOTATION_REF="ann4824_flexid_9da97b71-b3fd-4224-8fca-866bf40459ca">
                <ANNOTATION_VALUE>dɣɛsɑst͡sʼɑulɛp, t͡sʼmindɑ ɡiɔrɡɔbɑ t͡sʼɑnɑʃɛ ʒirʃɑɑx rɛ, ɛt͡ʃdɔsum nɔɛmbɛrs dɔ ɑmʃvi mɛsisən, t͡ʃkin kʼutxuʃɔt ɡɑnsɑkʼutrɛbuji ɑtinɑdə nɑmdɡɑ, ɡɑnsɑkʼutrɛbuji dɣɛsɑsɑuli, nɑmusut͡s t͡ʃki t͡sʼmindɑ ɡiɔrɡɔbɑs ɛtmɛbɣniʃnɛntə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5241" ANNOTATION_REF="ann5238_flexid_d859fa0e-68c4-4884-9906-4f84ce83f1c6">
                <ANNOTATION_VALUE>ɑrd͡zɑ t͡ʃkin ɡvɑriiʃ t͡sʼɑrmɔmɑdɡɛnɛji, ɑsɛ rɛ t͡ʃkin sɔpɛjiʃ, kʼurtxuuʃ xɑlxi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5397" ANNOTATION_REF="ann5394_flexid_a8440c49-08b3-4fce-822f-18bff3e6dcb8">
                <ANNOTATION_VALUE>ɑnu tɛ dɣɛsɑst͡sʼɑuls ɑnu mudrɔs ɑtmɑɣniiʃnɛɛnt, ɛt͡ʃdɔsums tu ɑmʃviis?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5541" ANNOTATION_REF="ann5538_flexid_5f6465ff-cf72-43e4-a852-18a836cb9000">
                <ANNOTATION_VALUE>ɛt͡ʃdɔsum nɔɛmbɛrs dɔ ɑmʃv mɑis... mɛsiis.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5633" ANNOTATION_REF="ann5630_flexid_777caff9-18a8-4c84-bbb4-c4df2a7fe87c">
                <ANNOTATION_VALUE>ɑnu ʒirxɔjɔ dɣɛsɑst͡sʼɑus ɑtmɑɣniʃnɛntɔ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5716" ANNOTATION_REF="ann5713_flexid_9500f078-9241-4d1b-8eec-e2f57ea8626a">
                <ANNOTATION_VALUE>ʒirxɔjɔ dɣɛsɑst͡sʼɑuul ɛtmɛɣniʃnɛɛb t͡ʃvɛulɛbrivɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5813" ANNOTATION_REF="ann5810_flexid_c9f87409-ce84-4ca1-a76d-4c2166228f81">
                <ANNOTATION_VALUE>dɔ mus ɑkʼɛtɛnt; ɑnu mut͡ʃʼɔ ɑtmɑɣniʃnɛnt, mus ɔrtət?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5964" ANNOTATION_REF="ann5961_flexid_2d3b8232-aab0-42a3-8248-3e1befc9b572">
                <ANNOTATION_VALUE>ɑnu ɛtmɛɣniʃnɛɛb d͡ziritɑdi rɛ, mɛursu,  t͡sʼirvɑ mɛursu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6130" ANNOTATION_REF="ann6127_flexid_8772e99b-f43f-420d-bbcf-ff07d09a78b4">
                <ANNOTATION_VALUE>sɑɛkʼlɛsiɔ ɡɔpt͡ʃʼɔpɑtən, pʼɑpʼɑ mutmuursu dɔ, bɑbɑt͡ʃiɑ, ɑtɑʃ kɔptkuɑtənə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6325" ANNOTATION_REF="ann6322_flexid_9d90efec-f33d-4fea-9baf-ac4db7926614">
                <ANNOTATION_VALUE>mutmuurs, t͡sʼirvɑs ɑɣɑvlɛɛns dɔ ukʼuj t͡ʃvɛulɛbriv tʼrɑdit͡siul tʼrɑpʼɛzi imɑrtɛbuu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6479" ANNOTATION_REF="ann6476_flexid_714218f1-23f4-4af8-8132-9c8541768366">
                <ANNOTATION_VALUE>mtɛj sɔpɛjiʃ xɑlxii, bɑɣɑnɛɛp, ɑxɑlɡɑzrdɔbɑɑ  tʼrɑpʼɛziis kiinkʼudɔxɔduut dɔ d͡ʒvɛʃ ɑmbɛɛps ɡɔʃinɑ mɛursu, d͡ʒvɛʃ t͡sʼɛsɛpiʃ ɡɔʃinɑ mɛursu dɔ tɑɑʃi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-segnum-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann8" ANNOTATION_REF="ann7_flexid_6e12951c-5ada-446c-8474-37acb0b84437">
                <ANNOTATION_VALUE>1</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann304" ANNOTATION_REF="ann303_flexid_54013928-20ad-4eac-b00b-499ed2a45232">
                <ANNOTATION_VALUE>2.1</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann761" ANNOTATION_REF="ann760_flexid_2c48dec1-69ba-4bee-bcb2-a5b91d94e31f">
                <ANNOTATION_VALUE>2.2</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann960" ANNOTATION_REF="ann959_flexid_052d01c9-53be-405e-bff0-31c7ca0b825e">
