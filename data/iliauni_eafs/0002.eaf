    <TIER LANG_REF="xmf" LINGUISTIC_TYPE_REF="phrase" TIER_ID="A_phrase-txt-xmf">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2_flexid_96c14b2e-6a18-42ac-aa4e-4b716af5fb06"
                TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts3">
                <ANNOTATION_VALUE>თვითონ ასე მა სოდეთ მუვშენქინ, თე სოფელს ჯოხო ზუბი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann143_flexid_48844f9f-948e-42ed-a45c-02f478e1554c"
                TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts6">
                <ANNOTATION_VALUE>თვითონ თე წარმომავლობა თე სიტყვაში, სოვრე მორთუ ზუბიქინ, დიდი ფიქრი ვაკო თეს, რუსეფიშ მუშულაშ უკული ოკო რდას დო თე ტერიტორია, ადრე, ა, სოდეთ ასე სოფელიენ, თენა ჸოფე ხობწყარპიჯი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann551_flexid_4928ebd0-2997-45e8-aa7f-a8b663f6c3f8"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>ანუ დასახლება ვაჸოფე.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann608_flexid_ca34ebe4-35f1-4be2-a854-7be636f641d5"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>ოდო მიდგარენი კოს მინოჸვე ურემი, ოდო ქუძირუ რუსი მიდგარენი განწარებული გილერულე დო ქოუკითხირ მუ გოკონია, თუ მუ გაწუხენსიან, თეს უთქუალ ზუბი, ზუბია დო კიბირს ნოჭუე.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1086_flexid_37f0693c-42a2-4292-a478-0d676248ec86"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>მარა ინდროს რუსული სოფელს მითინს ვაუჩქუდუ, ოდო თე კოჩშა ხოლო მუთუნი, ასე ვთქვათ, შენწება თე მეურემეში განშე ვაჸოფე.</ANNOTATION_VALUE>
