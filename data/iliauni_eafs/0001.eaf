    <TIER LANG_REF="xmf" LINGUISTIC_TYPE_REF="phrase"
        PARENT_REF="A_paragraph" TIER_ID="A_phrase-txt-xmf">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann9_flexid_817988fa-0df2-46aa-8fff-92403b3396a6"
                TIME_SLOT_REF1="ts3" TIME_SLOT_REF2="ts4">
                <ANNOTATION_VALUE>- დო თე კაჭიჭი მუჭომ ჸურძენიდ ან მუ ფერიდ?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann160_flexid_57d6e6d2-c0ae-42df-8822-c4b979d416f5"
                TIME_SLOT_REF1="ts7" TIME_SLOT_REF2="ts8">
                <ANNOTATION_VALUE>- ჭიფანაა... ჭიფანა ჸურძენ უუღუ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann241_flexid_45f1b6a2-753f-4bcd-9326-988e4483acb0"
                TIME_SLOT_REF1="ts9" TIME_SLOT_REF2="ts10">
                <ANNOTATION_VALUE>ჭიფანა კაკალეფ უღუუ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann311_flexid_75cd3623-ac5c-4f48-a6f5-b5fcd24e858f"
                TIME_SLOT_REF1="ts11" TIME_SLOT_REF2="ts12">
                <ANNOTATION_VALUE>ჯგირ ღვინ უუჩქუ, ჯგირო ქჷდარინუანქი დო, უჩა ღვინი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann482_flexid_46b0f9da-1cc5-40c8-892a-d4d43a0ec300"
                TIME_SLOT_REF1="ts13" TIME_SLOT_REF2="ts14">
                <ANNOTATION_VALUE>ხოოდო კაჭიჭიშ უმუშო ადესა ღვინ მუთუნ ვაარე, კოჩანას კაჭიჭჷ არძეენს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann657_flexid_e68588ab-8a86-481a-bcbe-a068c0c2c701"
                TIME_SLOT_REF1="ts15" TIME_SLOT_REF2="ts17">
                <ANNOTATION_VALUE>ხოო ათეჲ გურშენი დიო კაჭიჭი რე, ადრე მოშმელენს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann784_flexid_df0a8ebb-478a-4306-9758-b1da0afde2eb"
                TIME_SLOT_REF1="ts16" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>კაჭიჭის დოჭახუნდეს, ქოდარინუანდეს, უკულ ადესას დოწილუნდეს, თის ქუდარინუანდეს დო უკულ ათე ღვინს ართმაჟიას ქუხოლუანდეეს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1128_flexid_df11600a-c269-4e6a-b940-b61c685f8e1b"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>ოოდო თინა უმოსო აუჩარენდუ ადესას.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1221_flexid_f9d88373-8a95-4fe7-ad9d-47800c3886bb"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts23">
                <ANNOTATION_VALUE>ადესას ბრელ მუთუ ინა ვაუღ, მუ ჯოხო, ღვინობაჲ დიდ მუთუნ ღირსება ვაუღ ისი დო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1479_flexid_a302b17c-817c-44ab-a300-71fb6058eabd"
                TIME_SLOT_REF1="ts24" TIME_SLOT_REF2="ts25">
                <ANNOTATION_VALUE>კაჭიჭ არძენდუ მუჭოთი ძალას არძენდუუ, კოჩანას არძენდ ღვინსი დო ფერს ხოლო არძენდ დო არომატის ხოლო არძენდ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1810_flexid_d1191800-3de0-44f8-a32e-ebb89915670a"
                TIME_SLOT_REF1="ts26" TIME_SLOT_REF2="ts28">
                <ANNOTATION_VALUE>ადესა ჯგირ არომატ უღ, მარა კაჭიჭ გეთმუუძინაანდ ხოლო დო ათე უჩა ღვინი, ართმაჟია ხოლაფირი ჩქიმ ბაღანობას არძას უღუდ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2132_flexid_51ec9802-dd4c-403e-8d27-191bd5e321d7"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts29">
                <ANNOTATION_VALUE>ათაქ ჩქიმ მეზობელეფს, არძას უღუდ თე კაჭიჭ დო ადეს მეტ მუთუნ ვაჩანდ თაქინეშის.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2367_flexid_d15275dd-7bd2-402d-8617-f09c63c00694"
                TIME_SLOT_REF1="ts32" TIME_SLOT_REF2="ts33">
                <ANNOTATION_VALUE>ხოდო ჩეეში ჩაანდუ ხოლო ჩქიმ ბაღანობას.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2465_flexid_d77070ec-a495-4fd5-8019-522268b921a4"
                TIME_SLOT_REF1="ts34" TIME_SLOT_REF2="ts36">
                <ANNOTATION_VALUE>ჩეში ჯოხოდუ, ნოვას უძახუნა მაჟიანერო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2568_flexid_6fc60a87-1190-4a43-8e64-566bd2d4d74f"
                TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts37">
                <ANNOTATION_VALUE>ჩე ჸურძენიე თენა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2638_flexid_1b85f887-f5a3-4827-be4c-aa9b12706d3e"
                TIME_SLOT_REF1="ts38" TIME_SLOT_REF2="ts39">
                <ANNOTATION_VALUE>ხოოდო ეთიშე ჩე ღვინს ოდგინანდეეს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2732_flexid_3e299ffa-7a8e-4aef-bfec-a96c09edda63"
                TIME_SLOT_REF1="ts40" TIME_SLOT_REF2="ts41">
                <ANNOTATION_VALUE>თის ხოლო მუშ ინა ოკო, გიჩქუდას ოკო მუნერო დაარინუე.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann2917_flexid_7985996d-d029-4db1-ad02-5072db4d1207"
                TIME_SLOT_REF1="ts42" TIME_SLOT_REF2="ts43">
                <ANNOTATION_VALUE>ჯგირო ქჷდარინუანქ დო შამპანურჯგურა ღვინ ქოდოდირთუ, მუსით ჯოხო დო.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3115_flexid_717a09d8-63b8-4624-8c31-3c7a6fb0548d"
                TIME_SLOT_REF1="ts44" TIME_SLOT_REF2="ts45">
                <ANNOTATION_VALUE>უკულ არ დღა უღ თის, ეთიმ დღას გინაჩირთუ დო მუშით ქოოდოცენს.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann3316_flexid_5fd07ef6-16b0-4234-bd6c-cd3b0d768bcb"
                TIME_SLOT_REF1="ts46" TIME_SLOT_REF2="ts47">
                <ANNOTATION_VALUE>ოოდო ეთი დღააშახ მუთუნფერო გოწილე ოკო, ნამდა ვადოცუასიი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
