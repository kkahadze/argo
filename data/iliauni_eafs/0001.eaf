    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann11" ANNOTATION_REF="ann9_flexid_817988fa-0df2-46aa-8fff-92403b3396a6">
                <ANNOTATION_VALUE>What kind of grape was Kachichi? What color was it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann162" ANNOTATION_REF="ann160_flexid_57d6e6d2-c0ae-42df-8822-c4b979d416f5">
                <ANNOTATION_VALUE>It has small... small grapes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann243" ANNOTATION_REF="ann241_flexid_45f1b6a2-753f-4bcd-9326-988e4483acb0">
                <ANNOTATION_VALUE>It has smaller grapes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann313" ANNOTATION_REF="ann311_flexid_75cd3623-ac5c-4f48-a6f5-b5fcd24e858f">
                <ANNOTATION_VALUE>Good wine is made of it if you make it properly, red wine.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann484" ANNOTATION_REF="ann482_flexid_46b0f9da-1cc5-40c8-892a-d4d43a0ec300">
                <ANNOTATION_VALUE>And, without Kachichi, Isabella wine is nothing. It is Kachichi that gives it strength.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann659" ANNOTATION_REF="ann657_flexid_e68588ab-8a86-481a-bcbe-a068c0c2c701">
                <ANNOTATION_VALUE>And, owing to this, Kachichi is prior. It ripens earlier.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann786" ANNOTATION_REF="ann784_flexid_df0a8ebb-478a-4306-9758-b1da0afde2eb">
                <ANNOTATION_VALUE>Kachichi was squeezed and wine was made. Later, Isabella was squeezed and wine was made. Later, the wines were mixed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1130" ANNOTATION_REF="ann1128_flexid_df11600a-c269-4e6a-b940-b61c685f8e1b">
                <ANNOTATION_VALUE>And, it made Isabella darker.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1223" ANNOTATION_REF="ann1221_flexid_f9d88373-8a95-4fe7-ad9d-47800c3886bb">
                <ANNOTATION_VALUE>Isabella does not have much that, what do you call it. It does not have much worth of wine.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1481" ANNOTATION_REF="ann1479_flexid_a302b17c-817c-44ab-a300-71fb6058eabd">
                <ANNOTATION_VALUE>It was Kachichi that gave it strength, power, and gave it color as well. It have aroma too.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1812" ANNOTATION_REF="ann1810_flexid_d1191800-3de0-44f8-a32e-ebb89915670a">
                <ANNOTATION_VALUE>Isabella has good aroma; however, Kachichi increased it, and, in my childhood, everybody had a mixture of these two wines.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2134" ANNOTATION_REF="ann2132_flexid_51ec9802-dd4c-403e-8d27-191bd5e321d7">
                <ANNOTATION_VALUE>Here, all of my neighbor had Kachichi and Isabella. Nothing else thrived here.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2369" ANNOTATION_REF="ann2367_flexid_d15275dd-7bd2-402d-8617-f09c63c00694">
                <ANNOTATION_VALUE>Well, Cheshi too thrived in my childhood.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2467" ANNOTATION_REF="ann2465_flexid_d77070ec-a495-4fd5-8019-522268b921a4">
                <ANNOTATION_VALUE>Its name was Chemi, also known as Nova.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2570" ANNOTATION_REF="ann2568_flexid_6fc60a87-1190-4a43-8e64-566bd2d4d74f">
                <ANNOTATION_VALUE>This is a white grape.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2640" ANNOTATION_REF="ann2638_flexid_1b85f887-f5a3-4827-be4c-aa9b12706d3e">
                <ANNOTATION_VALUE>And, white wine was made of it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2734" ANNOTATION_REF="ann2732_flexid_3e299ffa-7a8e-4aef-bfec-a96c09edda63">
                <ANNOTATION_VALUE>You should be competent how to make it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2919" ANNOTATION_REF="ann2917_flexid_7985996d-d029-4db1-ad02-5072db4d1207">
                <ANNOTATION_VALUE>If you make it well, the wine will be like a champaign as such.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3117" ANNOTATION_REF="ann3115_flexid_717a09d8-63b8-4624-8c31-3c7a6fb0548d">
                <ANNOTATION_VALUE>And, it has a specific day; if you miss the day, its grapes will fall down.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3318" ANNOTATION_REF="ann3316_flexid_5fd07ef6-16b0-4234-bd6c-cd3b0d768bcb">
                <ANNOTATION_VALUE>You have to manage to pick them on that day not to let them fall down.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3474" ANNOTATION_REF="ann3472_flexid_8cdee47d-2230-4f7b-aabc-12d94611b661">
                <ANNOTATION_VALUE>- Did grandmother and grandfather know a special method for making it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3645" ANNOTATION_REF="ann3643_flexid_dff0b300-88a0-4f42-88f0-10849bb51ef4">
                <ANNOTATION_VALUE>- They did; they knew it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3739" ANNOTATION_REF="ann3737_flexid_f4958ff0-8810-4d29-b298-9fc80e8e1d07">
                <ANNOTATION_VALUE>I did tell you that they set fire near it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3876" ANNOTATION_REF="ann3874_flexid_e3605e29-fd49-4d88-b8de-69d994b7f6ff">
                <ANNOTATION_VALUE>They took care of it there. They did not open the door not to let cold in, and they set fire.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4116" ANNOTATION_REF="ann4114_flexid_30ea6b89-6595-45ca-9824-845291bbd9c5">
                <ANNOTATION_VALUE>They used to day that wine needed warmth and cold should not reach it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4300" ANNOTATION_REF="ann4298_flexid_83cf5678-9e91-458c-83d7-7b038222edda">
                <ANNOTATION_VALUE>They knew when to squeeze it, when to move  it into fermenting bottles.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4453" ANNOTATION_REF="ann4451_flexid_9c4ff1ad-9db4-4781-b846-d48e2844ce2f">
                <ANNOTATION_VALUE>For exmple, wine should not be left in grape skins and pips; it will turn into vinegar.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4649" ANNOTATION_REF="ann4647_flexid_02b67c61-c11a-4a9f-ba13-d1933221ab50">
                <ANNOTATION_VALUE>They knew when to move it to fermenting bottles, when to filter it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4875" ANNOTATION_REF="ann4873_flexid_8f2e78fe-0d0f-4538-bfad-5950130abb77">
                <ANNOTATION_VALUE>When it got lees on it, they filtered it for the second time.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5001" ANNOTATION_REF="ann4999_flexid_d33eec2a-d1a4-4985-87c8-32ebb249b7a6">
                <ANNOTATION_VALUE>After fermentation, wine was moved into a demijohn.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5061" ANNOTATION_REF="ann5059_flexid_99554394-bd5a-45ec-ac19-f4ff781986e9">
                <ANNOTATION_VALUE>I remember well that wine kept fermenting in it too.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5164" ANNOTATION_REF="ann5162_flexid_bcde138c-1f16-455e-ae5e-c14e87da8740">
                <ANNOTATION_VALUE>Sugar was added to it. Without sugar, our local grape is not worth.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5329" ANNOTATION_REF="ann5327_flexid_2833584b-87c7-4d75-8611-f5e2afdf9f8a">
                <ANNOTATION_VALUE>Syrup was made and added when grapes were squeezed.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5557" ANNOTATION_REF="ann5555_flexid_efc130eb-d738-4685-b179-4512e8b9bfe2">
                <ANNOTATION_VALUE>And, very good wine was made, and we, children were allowed to drink a little, as I remember.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5777" ANNOTATION_REF="ann5775_flexid_1a2d4bef-d882-4545-8db3-142bf4d9ee03">
                <ANNOTATION_VALUE>It was such a delicious wine.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="ka-Brai" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-ka-Brai">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann13" ANNOTATION_REF="ann9_flexid_817988fa-0df2-46aa-8fff-92403b3396a6">
                <ANNOTATION_VALUE>- და ეს კაჭიჭი როგორი ყურძენი იყო ან რა ფერის იყო?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann164" ANNOTATION_REF="ann160_flexid_57d6e6d2-c0ae-42df-8822-c4b979d416f5">
                <ANNOTATION_VALUE>წვრილი... წვრილი ყურძენი აქვს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann245" ANNOTATION_REF="ann241_flexid_45f1b6a2-753f-4bcd-9326-988e4483acb0">
                <ANNOTATION_VALUE>პატარა კაკლები  აქვს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann315" ANNOTATION_REF="ann311_flexid_75cd3623-ac5c-4f48-a6f5-b5fcd24e858f">
                <ANNOTATION_VALUE>კარგი ღვინო იცის, თუ კარგად დააყენებ, შავი ღვინო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann486" ANNOTATION_REF="ann482_flexid_46b0f9da-1cc5-40c8-892a-d4d43a0ec300">
                <ANNOTATION_VALUE>ხოდა, კაჭიჭის გარეშე ადესის ღვინო არაფერია, კაცობას  (=ძლიერს) კაჭიჭი აძლევს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann661" ANNOTATION_REF="ann657_flexid_e68588ab-8a86-481a-bcbe-a068c0c2c701">
                <ANNOTATION_VALUE>ხოო ამის გამო ჯერ  კაჭიჭი არის, ადრე შემოდის (=უფრო ადრე მწიფდება).</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann788" ANNOTATION_REF="ann784_flexid_df0a8ebb-478a-4306-9758-b1da0afde2eb">
                <ANNOTATION_VALUE>კაჭიჭს დაჭეჭყავდნენ, დააყენებდნენ, მერე კრეფდნენ ადესას, იმას დააყენებდნენ და მერე ამ ღვინოს ერთიმეორეში აურევდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1132" ANNOTATION_REF="ann1128_flexid_df11600a-c269-4e6a-b940-b61c685f8e1b">
                <ANNOTATION_VALUE>და ის უფრო აშავებდა ადესას.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1225" ANNOTATION_REF="ann1221_flexid_f9d88373-8a95-4fe7-ad9d-47800c3886bb">
                <ANNOTATION_VALUE>ადესას დიდი ის არ აქვს, როგორ ჰქვია, ღვინობის დიდი ღირსება არა აქვს მას.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1483" ANNOTATION_REF="ann1479_flexid_a302b17c-817c-44ab-a300-71fb6058eabd">
                <ANNOTATION_VALUE>კაჭიჭი აძლევდა, როგორც ასეთი, მას ძალას, კაცობას (=სიძლიერეს) აძლევდა და ფერსაც აძლევდა, არომატსაც აძლევდა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1814" ANNOTATION_REF="ann1810_flexid_d1191800-3de0-44f8-a32e-ebb89915670a">
                <ANNOTATION_VALUE>ადესას კარგი არომატი აქვს,  მაგრამ კაჭიჭი ამატებდა უფრო და ეს ორი ღვინო, ერთმანეთში შერეული, ყველას ჰქონდა ჩემს ბავშვობაში.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2136" ANNOTATION_REF="ann2132_flexid_51ec9802-dd4c-403e-8d27-191bd5e321d7">
                <ANNOTATION_VALUE>აქ ჩემს მეზობლებს ყველას ჰქონდა ეს   კაჭიჭი და ადესა, მეტი აარაფერი ხარობდა აქ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2371" ANNOTATION_REF="ann2367_flexid_d15275dd-7bd2-402d-8617-f09c63c00694">
                <ANNOTATION_VALUE>ხო ჩეში ხარობდა კიდევ ჩემს ბავშვობაში.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2469" ANNOTATION_REF="ann2465_flexid_d77070ec-a495-4fd5-8019-522268b921a4">
                <ANNOTATION_VALUE>ჩეში ერქვა, ნოვას ეძახიან მეორენაირად.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2572" ANNOTATION_REF="ann2568_flexid_6fc60a87-1190-4a43-8e64-566bd2d4d74f">
                <ANNOTATION_VALUE>თეთრი ყურძენია ეს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2642" ANNOTATION_REF="ann2638_flexid_1b85f887-f5a3-4827-be4c-aa9b12706d3e">
                <ANNOTATION_VALUE>ხოდა მაგისგან თეთრ ღვინოს აყენებდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2736" ANNOTATION_REF="ann2732_flexid_3e299ffa-7a8e-4aef-bfec-a96c09edda63">
                <ANNOTATION_VALUE>იმასაც თავისი ის (=ცოდნა) უნდა, უნდა იცოდე, როგორ დააყენო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2921" ANNOTATION_REF="ann2917_flexid_7985996d-d029-4db1-ad02-5072db4d1207">
                <ANNOTATION_VALUE>კარგად თუ დააყენებ, შამპანურივით ღვინო დადგება, რასაც ჰქვია.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3119" ANNOTATION_REF="ann3115_flexid_717a09d8-63b8-4624-8c31-3c7a6fb0548d">
                <ANNOTATION_VALUE>მერე ერიი დღე აქვს მას, იმ ერთ დღეს თუ გადასცდება, თავისით დაცვივდება.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3320" ANNOTATION_REF="ann3316_flexid_5fd07ef6-16b0-4234-bd6c-cd3b0d768bcb">
                <ANNOTATION_VALUE>იმ დღეს რაღაცნაირად უნდა დაკრიფო, რათა არ დაცვივდეს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3476" ANNOTATION_REF="ann3472_flexid_8cdee47d-2230-4f7b-aabc-12d94611b661">
                <ANNOTATION_VALUE>- ბებიას და ბაბუას  მისი დაყენების რამე განსაკუთრებული წესი ჰქონდათ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3647" ANNOTATION_REF="ann3643_flexid_dff0b300-88a0-4f42-88f0-10849bb51ef4">
                <ANNOTATION_VALUE>- იცოდნენ. თვითონ იცოდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3741" ANNOTATION_REF="ann3737_flexid_f4958ff0-8810-4d29-b298-9fc80e8e1d07">
                <ANNOTATION_VALUE>აი, ხომ გითხარი ახლა, ცეცხლს უნთებდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3878" ANNOTATION_REF="ann3874_flexid_e3605e29-fd49-4d88-b8de-69d994b7f6ff">
                <ANNOTATION_VALUE>იქ  აყურადებდა, კარს არ გააღებდნენ, სიცივე არ შევიდესო და იქ ცეცხლს ანთებდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4118" ANNOTATION_REF="ann4114_flexid_30ea6b89-6595-45ca-9824-845291bbd9c5">
                <ANNOTATION_VALUE>სითბო უნდაო ღვინოს, სიცივე არ უნდა შეხვდესო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4302" ANNOTATION_REF="ann4298_flexid_83cf5678-9e91-458c-83d7-7b038222edda">
                <ANNOTATION_VALUE>იცოდნენ როდის დაეწურათ, გადმოეტანათ [ჭურჭელში]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4455" ANNOTATION_REF="ann4451_flexid_9c4ff1ad-9db4-4781-b846-d48e2844ce2f">
                <ANNOTATION_VALUE>მაგალითად, არ შეიძლება ღვონო დიდხანს გააჩერო ჭაჭაში, დაძმარდება.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4651" ANNOTATION_REF="ann4647_flexid_02b67c61-c11a-4a9f-ba13-d1933221ab50">
                <ANNOTATION_VALUE>იცოდნენ, რა დროს უნდა გადაეტანათ [ჭურჭელში], რა დროს გადაეეწურათ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4877" ANNOTATION_REF="ann4873_flexid_8f2e78fe-0d0f-4538-bfad-5950130abb77">
                <ANNOTATION_VALUE>თხლეს რომ გაიკეთებდა, მერე მეორეჯერ  გადაწურავდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5003" ANNOTATION_REF="ann4999_flexid_d33eec2a-d1a4-4985-87c8-32ebb249b7a6">
                <ANNOTATION_VALUE>ღვინის ადუღების შემდეგ ბოცაში [ასხამდნენ].</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5063" ANNOTATION_REF="ann5059_flexid_99554394-bd5a-45ec-ac19-f4ff781986e9">
                <ANNOTATION_VALUE>იქაც დუღდა ღვინო, კარგად მახსოვს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5166" ANNOTATION_REF="ann5162_flexid_bcde138c-1f16-455e-ae5e-c14e87da8740">
                <ANNOTATION_VALUE>შაქარს უკეთებდნენ, უშაქროდ ჩვენი აქაური  ყურძენი არ ვარგა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5331" ANNOTATION_REF="ann5327_flexid_2833584b-87c7-4d75-8611-f5e2afdf9f8a">
                <ANNOTATION_VALUE>ხოდა, სიროპს მოადუღებდნენ  და იმას შეურევდნენ იმ დროს, როცა დაჭეჭყავდნენ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5559" ANNOTATION_REF="ann5555_flexid_efc130eb-d738-4685-b179-4512e8b9bfe2">
                <ANNOTATION_VALUE>ხოდა, ძალიან კარგი ღვინო გამოდიოდა და ბავშვებსაც გვაძლევდნენ (=გვასმევდნენ) ცოტას, მახსოვს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5779" ANNOTATION_REF="ann5775_flexid_1a2d4bef-d882-4545-8db3-142bf4d9ee03">
                <ANNOTATION_VALUE>ისეთი გემრიელი ღვინო იყო.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="xmf-fonipa" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-xmf-fonipa">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann12" ANNOTATION_REF="ann9_flexid_817988fa-0df2-46aa-8fff-92403b3396a6">
                <ANNOTATION_VALUE>dɔ tɛ kʼɑt͡ʃʼit͡ʃʼi mut͡ʃʼɔm ʔurd͡zɛnid ɑn mu pɛrid?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann163" ANNOTATION_REF="ann160_flexid_57d6e6d2-c0ae-42df-8822-c4b979d416f5">
                <ANNOTATION_VALUE>- t͡ʃʼipɑnɑɑ... t͡ʃʼipɑnɑ ʔurd͡zɛn uuɣu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann244" ANNOTATION_REF="ann241_flexid_45f1b6a2-753f-4bcd-9326-988e4483acb0">
                <ANNOTATION_VALUE>t͡ʃʼipɑnɑ kʼɑkʼɑlɛp uɣuu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann314" ANNOTATION_REF="ann311_flexid_75cd3623-ac5c-4f48-a6f5-b5fcd24e858f">
                <ANNOTATION_VALUE>d͡ʒɡir ɣvin uut͡ʃku, d͡ʒɡirɔ kədɑrinuɑnki dɔ, ut͡ʃɑ ɣvini.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann485" ANNOTATION_REF="ann482_flexid_46b0f9da-1cc5-40c8-892a-d4d43a0ec300">
                <ANNOTATION_VALUE>xɔɔdɔ kʼɑt͡ʃʼit͡ʃʼiʃ umusɔ ɑdɛsɑ ɣvin mutun vɑɑrɛ, kʼɔt͡ʃɑnɑs kʼɑt͡ʃʼit͡ʃʼə ɑrd͡zɛɛns.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann660" ANNOTATION_REF="ann657_flexid_e68588ab-8a86-481a-bcbe-a068c0c2c701">
                <ANNOTATION_VALUE>xɔɔ ɑtɛj ɡurʃɛni diɔ kʼɑt͡ʃʼit͡ʃʼi rɛ, ɑdrɛ mɔʃmɛlɛns.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann787" ANNOTATION_REF="ann784_flexid_df0a8ebb-478a-4306-9758-b1da0afde2eb">
                <ANNOTATION_VALUE>kʼɑt͡ʃʼit͡ʃʼis dɔt͡ʃʼɑxundɛs, kɔdɑrinuɑndɛs, ukʼul ɑdɛsɑs dɔt͡sʼilundɛs, tis kudɑrinuɑndɛs dɔ ukʼul ɑtɛ ɣvins ɑrtmɑʒiɑs kuxɔluɑndɛɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1131" ANNOTATION_REF="ann1128_flexid_df11600a-c269-4e6a-b940-b61c685f8e1b">
                <ANNOTATION_VALUE>ɔɔdɔ tinɑ umɔsɔ ɑut͡ʃɑrɛndu ɑdɛsɑs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1224" ANNOTATION_REF="ann1221_flexid_f9d88373-8a95-4fe7-ad9d-47800c3886bb">
                <ANNOTATION_VALUE>ɑdɛsɑs brɛl mutu inɑ vɑuɣ, mu d͡ʒɔxɔ, ɣvinɔbɑj did mutun ɣirsɛbɑ vɑuɣ isi dɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1482" ANNOTATION_REF="ann1479_flexid_a302b17c-817c-44ab-a300-71fb6058eabd">
                <ANNOTATION_VALUE>kʼɑt͡ʃʼit͡ʃʼ ɑrd͡zɛndu mut͡ʃʼɔti d͡zɑlɑs ɑrd͡zɛnduu, kʼɔt͡ʃɑnɑs ɑrd͡zɛnd ɣvinsi dɔ pɛrs xɔlɔ ɑrd͡zɛnd dɔ ɑrɔmɑtʼis xɔlɔ ɑrd͡zɛnd.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1813" ANNOTATION_REF="ann1810_flexid_d1191800-3de0-44f8-a32e-ebb89915670a">
                <ANNOTATION_VALUE>ɑdɛsɑ d͡ʒɡir ɑrɔmɑtʼ uɣ, mɑrɑ kʼɑt͡ʃʼit͡ʃʼ ɡɛtmuud͡zinɑɑnd xɔlɔ dɔ ɑtɛ ut͡ʃɑ ɣvini, ɑrtmɑʒiɑ xɔlɑpiri t͡ʃkim bɑɣɑnɔbɑs ɑrd͡zɑs uɣud.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2135" ANNOTATION_REF="ann2132_flexid_51ec9802-dd4c-403e-8d27-191bd5e321d7">
                <ANNOTATION_VALUE>ɑtɑk t͡ʃkim mɛzɔbɛlɛps, ɑrd͡zɑs uɣud tɛ kʼɑt͡ʃʼit͡ʃʼ dɔ ɑdɛs mɛtʼ mutun vɑt͡ʃɑnd tɑkinɛʃis.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2370" ANNOTATION_REF="ann2367_flexid_d15275dd-7bd2-402d-8617-f09c63c00694">
                <ANNOTATION_VALUE>xɔdɔ t͡ʃɛɛʃi t͡ʃɑɑndu xɔlɔ t͡ʃkim bɑɣɑnɔbɑs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2468" ANNOTATION_REF="ann2465_flexid_d77070ec-a495-4fd5-8019-522268b921a4">
                <ANNOTATION_VALUE>t͡ʃɛʃi d͡ʒɔxɔdu, nɔvɑs ud͡zɑxunɑ mɑʒiɑnɛrɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2571" ANNOTATION_REF="ann2568_flexid_6fc60a87-1190-4a43-8e64-566bd2d4d74f">
                <ANNOTATION_VALUE>t͡ʃɛ ʔurd͡zɛniɛ tɛnɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2641" ANNOTATION_REF="ann2638_flexid_1b85f887-f5a3-4827-be4c-aa9b12706d3e">
                <ANNOTATION_VALUE>xɔɔdɔ ɛtiʃɛ t͡ʃɛ ɣvins ɔdɡinɑndɛɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2735" ANNOTATION_REF="ann2732_flexid_3e299ffa-7a8e-4aef-bfec-a96c09edda63">
                <ANNOTATION_VALUE>tis xɔlɔ muʃ inɑ ɔkʼɔ, ɡit͡ʃkudɑs ɔkʼɔ munɛrɔ dɑɑrinuɛ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2920" ANNOTATION_REF="ann2917_flexid_7985996d-d029-4db1-ad02-5072db4d1207">
                <ANNOTATION_VALUE>d͡ʒɡirɔ kədɑrinuɑnk dɔ ʃɑmpʼɑnurd͡ʒɡurɑ ɣvin kɔdɔdirtu, musit d͡ʒɔxɔ dɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3118" ANNOTATION_REF="ann3115_flexid_717a09d8-63b8-4624-8c31-3c7a6fb0548d">
                <ANNOTATION_VALUE>ukʼul ɑr dɣɑ uɣ tis, ɛtim dɣɑs ɡinɑt͡ʃirtu dɔ muʃit kɔɔdɔt͡sɛns.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3319" ANNOTATION_REF="ann3316_flexid_5fd07ef6-16b0-4234-bd6c-cd3b0d768bcb">
                <ANNOTATION_VALUE>ɔɔdɔ ɛti dɣɑɑʃɑx mutunpɛrɔ ɡɔt͡sʼilɛ ɔkʼɔ, nɑmdɑ vɑdɔt͡suɑsii.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3475" ANNOTATION_REF="ann3472_flexid_8cdee47d-2230-4f7b-aabc-12d94611b661">
                <ANNOTATION_VALUE>- tɛ bɛb dɔ bɑbus mutun t͡sʼɛs uuɣudɛsɔ ɛʃ dɔrinɑpɑʃi ɡɑnsɑkʼutrɛbuj?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3646" ANNOTATION_REF="ann3643_flexid_dff0b300-88a0-4f42-88f0-10849bb51ef4">
                <ANNOTATION_VALUE>- ut͡ʃkudɛɛs, munɛps ut͡ʃkudɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3740" ANNOTATION_REF="ann3737_flexid_f4958ff0-8810-4d29-b298-9fc80e8e1d07">
                <ANNOTATION_VALUE>ɑ, xɔ kɔit͡sʼi ɑsɛ,   dɑt͡ʃxirs ikʼmuurd͡zɑndɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3877" ANNOTATION_REF="ann3874_flexid_e3605e29-fd49-4d88-b8de-69d994b7f6ff">
                <ANNOTATION_VALUE>ɛtɛk  miɔrt͡ʃkiɛd, kʼɑrs vɑɡɑd͡ʒɑndɛs, t͡ʃxuruk vɛmilɑsiɑ dɔ ɛtɛk dɑt͡ʃxirs ikʼɑrd͡zɑndɛɛs.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4117" ANNOTATION_REF="ann4114_flexid_30ea6b89-6595-45ca-9824-845291bbd9c5">
                <ANNOTATION_VALUE>sitʼibɑ ɔkʼɔniɑ ɣviinsi, t͡ʃxuruk vɑmɔxvɑdɑs ɔkʼɔniɑ dɔ ɣviinsi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4301" ANNOTATION_REF="ann4298_flexid_83cf5678-9e91-458c-83d7-7b038222edda">
                <ANNOTATION_VALUE>ut͡ʃkudɛs mu drɔs ɡɛut͡sʼirudɛs, ɡɛiɔbɛɛskʼɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4454" ANNOTATION_REF="ann4451_flexid_9c4ff1ad-9db4-4781-b846-d48e2844ce2f">
                <ANNOTATION_VALUE>mɑɡɑjitɔ, ɣvin xɔ brɛjxɑns vɛʃilɛbɛ t͡ʃʼɑt͡ʃʼɑs ɡɑt͡ʃɛmɛbuli, dɛd͡zmɑrɛbuniɑ dɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4650" ANNOTATION_REF="ann4647_flexid_02b67c61-c11a-4a9f-ba13-d1933221ab50">
                <ANNOTATION_VALUE>ut͡ʃkudɛs mu drɔs ɡɛubunudɛskʼɔ, mu drɔs ɡinut͡sʼirudɛskʼɔ ɔkʼɔd.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4876" ANNOTATION_REF="ann4873_flexid_8f2e78fe-0d0f-4538-bfad-5950130abb77">
                <ANNOTATION_VALUE>ukʼul mɑʒiɑʃɑ ɡinɔt͡sʼirdəd, txɔlɔs mirinuɑndu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5002" ANNOTATION_REF="ann4999_flexid_d33eec2a-d1a4-4985-87c8-32ebb249b7a6">
                <ANNOTATION_VALUE>punɑpɑɑs ukʼul bɔt͡sɑʃɑ dini..</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5062" ANNOTATION_REF="ann5059_flexid_99554394-bd5a-45ec-ac19-f4ff781986e9">
                <ANNOTATION_VALUE>ɛtɛk xɔlɔ puund ɣvin, mʃu ɡvɑlɛd͡ʒɡirɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5165" ANNOTATION_REF="ann5162_flexid_bcde138c-1f16-455e-ae5e-c14e87da8740">
                <ANNOTATION_VALUE>ʃɑnkɑrs uxɔluɑndɛs, uʃɑnkɑrɛt ɑsɛ t͡ʃkin ʔurd͡zɛn, ɑtɑkiɑn vɛɛrɡu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5330" ANNOTATION_REF="ann5327_flexid_2833584b-87c7-4d75-8611-f5e2afdf9f8a">
                <ANNOTATION_VALUE>ɔɔdɔ, sirɔpʼis dɑpunuɑndɛɛs dɔ ɛtis kuxɔluɑndɛɛs, muʒɑmsit dɔt͡ʃʼɑxundɛs timdrɔsə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5558" ANNOTATION_REF="ann5555_flexid_efc130eb-d738-4685-b179-4512e8b9bfe2">
                <ANNOTATION_VALUE>ɔɔdɔ, ɡvɑjɛ d͡ʒɡir ɣvin iʃmɛlɛɛndu dɔ bɑɣɑnɛps xɔlɔ mɑrd͡zɛndɛɛs t͡ʃʼiɛ t͡ʃʼiɛt, pʃuu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5778" ANNOTATION_REF="ann5775_flexid_1a2d4bef-d882-4545-8db3-142bf4d9ee03">
                <ANNOTATION_VALUE>tid͡ʒɡuɑ ɡɛmuɑn ɣvin ɔrd.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
