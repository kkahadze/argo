                <ANNOTATION_VALUE>sɔdɛ mɛurs unt͡ʃɑʃin, tɛk ɔkʼɔpʼunt t͡ʃki, ɑbɑ mu pkimənɑt dɔ kiʃmɔtʼqʼvinɛs, bɑbuk dɔɣuruɑ, did bɑbuk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1235" ANNOTATION_REF="ann1231_flexid_0be4f817-9d8b-4803-9a6c-c33e421fe355">
                <ANNOTATION_VALUE>dɔ mɑlɑptit, muut?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1300" ANNOTATION_REF="ann1296_flexid_98cd8b6b-3142-43d6-b663-3c7d4db6dd3b">
                <ANNOTATION_VALUE>t͡ʃkim mumɑ t͡sxɛnt͡s ɡɛxɛ, t͡ʃʼit͡ʃʼɛ d͡ʒimɑ miʔunt͡su, sum t͡sʼɑnɛrin, ɑtɑk ukʼɛb dɔ t͡ʃkii, mɑ, t͡ʃkim didɑ dɔ unt͡ʃɑʃ inɑ, kʼut͡ʃxit ɛkʼɔptxɔzutu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1662" ANNOTATION_REF="ann1658_flexid_b5ca9c2c-a697-45b0-912f-eac1ebfd6ef4">
                <ANNOTATION_VALUE>ɛɛt͡ʃi kʼilɔmɛtʼri,  ɛs zɣɑpʼɑrivit rɛ, tiʃɛn ɡirɑɡɑduk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1777" ANNOTATION_REF="ann1773_flexid_bdc66dbc-d57c-4418-93e3-64530ef7b69e">
                <ANNOTATION_VALUE>ɛt͡ʃi kʼilɔmɛtʼri midɑptit dɔ kimɛptit bɑbuʃ ʔut͡ʃɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1922" ANNOTATION_REF="ann1918_flexid_ab2c80d6-eb36-4886-8042-f87d8728e2a1">
                <ANNOTATION_VALUE>ɑtɛ bɑbu, ɛk ɔdɑs ʔudɛs vɑrən, ɛti kuxnɑs did inɑ, ʃkɑ dixɑsə kududɡumnɑ inɑ dɔ bɑbə ɡilɑd͡ʒɑn tɑk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2213" ANNOTATION_REF="ann2209_flexid_b57b55ce-7093-4a14-a080-4b0657257b66">
                <ANNOTATION_VALUE>ɑsɛ iʃɔ vɑmnɔmrtum mɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2299" ANNOTATION_REF="ann2295_flexid_a56872e2-0452-4aa0-a09e-d0ed688c6e51">
                <ANNOTATION_VALUE>ɣurɛl dɣɑs vɑmɑp nɑd͡zirɛpə, t͡sʼɑrmɔdɡɛnil kəɡɑpnɔ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2447" ANNOTATION_REF="ann2443_flexid_aec293f3-ad13-4d6d-8b69-5019c4c53700">
                <ANNOTATION_VALUE>ɔɔdɔ ɑtɑʃ kintuɔd͡ʒinit mɑ dɔ bid͡ziskʼuɑ miʔund xɔlɔ t͡ʃʼit͡ʃʼɛt ukʼlɑʃ t͡ʃkimi.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2633" ANNOTATION_REF="ann2629_flexid_4cec7cca-152f-4420-9437-5f0e3b0119f4">
                <ANNOTATION_VALUE>ɑɑtɛnɑ ud͡ʒinitɔɔ, bɑbuʃ t͡ʃxvind nɛbɛtʼɑn ʒi ɑp ɛkʼunɛlə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2785" ANNOTATION_REF="ann2781_flexid_ed89446f-a793-4c7d-ad7f-f8757a51fbb8">
                <ANNOTATION_VALUE>tɛnɑ kɔbd͡zirit dɔ ɡɛnt͡sʼɔmiɔlɛs d͡zit͡sɑkə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2905" ANNOTATION_REF="ann2901_flexid_fe7a73cc-c26a-4c24-a848-e7f4dc979c84">
                <ANNOTATION_VALUE>mutunit vɑmmɑtʼɛbɛs tɛk, sɔiʃɑx ɔtxirɛʃɑ vɛbditə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3061" ANNOTATION_REF="ann3057_flexid_5bb9ae55-74f7-4d15-87fc-ae23efc8bb67">
                <ANNOTATION_VALUE>iɑxɑ ɑmdɣɑ xɔlɔ mɑd͡zit͡sinuɑp.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3143" ANNOTATION_REF="ann3139_flexid_747dc298-5f9a-4dd3-8253-d6211f895b94">
                <ANNOTATION_VALUE>ɑɑrti.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3165" ANNOTATION_REF="ann3161_flexid_87383622-2cdf-47a3-a9dd-89640bbe9204">
                <ANNOTATION_VALUE>mɑʒiɑ rdu xɔlɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3214" ANNOTATION_REF="ann3210_flexid_462af70a-c948-45ef-bffe-cd6dcfcbac41">
                <ANNOTATION_VALUE>xɔlɔ mɑ dɔ ti t͡ʃkim bid͡ziskuɑk midɑprtit, ɣɛlɛ kɔit͡ʃkənɔ murɛn?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3399" ANNOTATION_REF="ann3395_flexid_f95057c0-efcc-4838-98ac-2af386e6656e">
                <ANNOTATION_VALUE>kɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3415" ANNOTATION_REF="ann3411_flexid_d86e8a40-f1da-4b32-8000-9aa1cd141498">
                <ANNOTATION_VALUE>xɔm kɔit͡ʃk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3472" ANNOTATION_REF="ann3468_flexid_25bb5fc4-f954-46aa-a411-88fbb37c31e8">
                <ANNOTATION_VALUE>t͡ʃʼit͡ʃʼɛ t͡sʼqʼɑri.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3507" ANNOTATION_REF="ann3503_flexid_5052badc-fb61-42de-81af-ffb6f170da79">
                <ANNOTATION_VALUE>ɔ, dɑɡubɛbuli t͡sʼqʼɑri, min lɛtʼɑm, min mudɡɑrɛnə dɔ ʃɑrɑpʼid͡ʒi rɛ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3641" ANNOTATION_REF="ann3637_flexid_dd14fa9a-90a5-4bdb-91e5-0630e396bdf1">
                <ANNOTATION_VALUE>t͡ʃʼit͡ʃʼɛ vɔrɛt, t͡ʃʼit͡ʃʼɛ, immɑ skʼɔlɑs xɔlɔ kuɔrdiɔ, vɑmit͡ʃk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3827" ANNOTATION_REF="ann3823_flexid_1acb73fc-1c01-4536-bcf4-198e9bd4ad9f">
                <ANNOTATION_VALUE>ɔdɔ kʼu, tɛnɑs ɔpʼt͡ʃʼɔpunt, ɛniblɛnt ɣɑləʃɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3955" ANNOTATION_REF="ann3951_flexid_11de9384-3824-4e01-a825-a3e7901bfd17">
                <ANNOTATION_VALUE>ɑtɑk kɛt͡sʼipxunuɑ, mɑlɛpʼunɑnk ʃɑrɑs, kuɑlɛp kuɡunt͡sʼkʼɑri,  xɔlɔ mɑʒiɑ ɔkʼɔ ɔpʼt͡ʃʼɔpɛ. muʃɔ mɔkʼɔn misə ut͡ʃkə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4201" ANNOTATION_REF="ann4197_flexid_0cd758bf-dd67-424c-8c37-ee30d5992957">
                <ANNOTATION_VALUE>muʃɔ mɔkʼɔn misə ut͡ʃkə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4291" ANNOTATION_REF="ann4287_flexid_f112000c-c684-4f7a-b9a8-4eaba7e0ec6e">
                <ANNOTATION_VALUE>ɔdɔ kumɔprtiɔ, ɛnɑ vɑrɛ ukʼvɛ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4404" ANNOTATION_REF="ann4400_flexid_ad57ef0d-6774-405a-a8b1-86b6f670c6f8">
                <ANNOTATION_VALUE>ɑ dɔ, bɔlɔs irɔ tɑʃ kəɡmɔskʼidə ɔdɔ ɑtɛ ɑrt t͡ʃʼɔpil mɑlɛpʼɔnit dɔ mɑlɑptit ʔut͡ʃɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4651" ANNOTATION_REF="ann4647_flexid_bd7ce363-ec5f-4004-8cde-532da8235c49">
                <ANNOTATION_VALUE>sɔ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4666" ANNOTATION_REF="ann4662_flexid_8769ed17-f9a3-4868-8b6d-6b9d0e8c71e9">
                <ANNOTATION_VALUE>vɑrt t͡ʃkim ɛzɔ, vɑrti...  ɑrd͡zɑs uɣə ɔnt͡ʃʼɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4788" ANNOTATION_REF="ann4784_flexid_9fabf829-e640-42e1-af89-8cc16ffebc3d">
                <ANNOTATION_VALUE>ɔnt͡ʃʼɑ kɔit͡ʃkənɔ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4856" ANNOTATION_REF="ann4852_flexid_c1859678-90ba-45fa-8253-683167edfaac">
                <ANNOTATION_VALUE>t͡ʃʼɑ, xɔ?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4886" ANNOTATION_REF="ann4882_flexid_21fe0f7e-cbe4-4f77-bb44-c99685f47641">
                <ANNOTATION_VALUE>t͡ʃʼɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4907" ANNOTATION_REF="ann4903_flexid_909eff7c-2e01-4b1f-b950-f26cfbed5b62">
                <ANNOTATION_VALUE>t͡sʼqʼɑrij ɛʃɑɣɑlɑr.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4942" ANNOTATION_REF="ann4938_flexid_4daf2e3a-81c6-40b8-842f-c4c569c7b209">
                <ANNOTATION_VALUE>ɔnt͡ʃʼɑ mɑrɡɑlurɔ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4978" ANNOTATION_REF="ann4974_flexid_b5f66d16-57b3-48de-87b9-6cd2123f0450">
                <ANNOTATION_VALUE>ɑɑtɛnɑ irkʼɔsə uɣudə dɔ mu bɣɔlɑt tɛs dɔ ɡɛbt͡ʃʼɔp dɔ iʃ kɛntuɔxunɛ tɛk.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5220" ANNOTATION_REF="ann5216_flexid_8f074cf7-8cac-4c1b-a143-bf161130326f">
                <ANNOTATION_VALUE>kɛnuɔrɑɡvɛ, ɑɑɑ tʼɔmbɑrd, diidup, ɛɛnɑ mut͡ʃʼɔ pkimini mɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5371" ANNOTATION_REF="ann5367_flexid_b4fbac52-a0ea-4cee-9d67-3e6dcb15da79">
                <ANNOTATION_VALUE>t͡ʃkim bɑbu, mitiniʃ vɑpʃə, mitiniʃ dɔ bɑbu mit umɛtʼɛs mitins vɑlɑxundə, tɛnɑ tʼqʼurɑrd.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5595" ANNOTATION_REF="ann5591_flexid_0dcb555b-02f9-4ba0-9875-96bda55fb59e">
                <ANNOTATION_VALUE>txiriʃ t͡ʃʼinə ɡɛt͡ʃʼɔpu dɔ d͡zɑɑm mɑnɡɑrɔ ɡɔblɑxu, t͡ʃʼit͡ʃʼɛ bɑɣɑnɑ dɔ imtʼi ɔtxirɛʃɑ.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5793" ANNOTATION_REF="ann5789_flexid_a025c739-ad2b-4ac2-bdf1-a064edf452aa">
                <ANNOTATION_VALUE>ɔtxirɛʃɛ iʃɔ ɡinibli dɔ sɔdɡɑrɛnə ɔɔ sɛrʃɑ dɔ ukʼul ɔbt͡ʃʼɔpu dɔ kɔmxutʼɔru dɔ xɔm kɔit͡ʃkəniɑ ɑɑ, muzmɑ t͡sʼɑnɑ rɛ, ɡɑkʼvɛtil vɑɡɔbt͡ʃʼqʼɔlɑdə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6163" ANNOTATION_REF="ann6159_flexid_e7d1ef12-de34-4b86-9eb4-34710726dd4f">
                <ANNOTATION_VALUE>tɛnɑ ɑtɛt͡sɑl, mɛtʼ brɛl mutun zɣɑpʼrul, brɛl mutun, mɑrɑ inɑ ɑsɛ vɑuxud͡ʒɑns, ukʼul.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6362" ANNOTATION_REF="ann6358_flexid_84b58f3c-59a1-4095-bbbc-2de54dbf2eb7">
                <ANNOTATION_VALUE>bɛɛvri t͡sxɔvrɛbɑ brɛl mutuns ɡɔd͡zirɑnsə kʼɔt͡ʃis.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6481" ANNOTATION_REF="ann6477_flexid_4faa98ff-08b7-4d3a-8f02-c0ac447312f2">
                <ANNOTATION_VALUE>ɛzmɑ t͡sʼɑnɑ vɑrt unɑkʼlɔt ɔdɔ vɑrti ʃɛumt͡ʃnɛvɛlɔ vɛmɛursu.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6616" ANNOTATION_REF="ann6612_flexid_a0b5466a-409d-4e07-b72d-9b66aec90367">
                <ANNOTATION_VALUE>brɛli rɛ ɛnɑ dɔ ɔʃnɛr mudɡɑrɛnə.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
