    <TIER LANG_REF="en" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-en">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5" ANNOTATION_REF="ann3_flexid_4d72b049-e289-4426-90b8-53b2cd0abe0d">
                <ANNOTATION_VALUE>This is like a small fairy tale.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann80" ANNOTATION_REF="ann78_flexid_cc04c21a-6f4b-44ad-9935-257aadcc9886">
                <ANNOTATION_VALUE>I had a great grandfather.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann194" ANNOTATION_REF="ann192_flexid_2977ba3b-a22f-400f-87ca-826828d6e004">
                <ANNOTATION_VALUE>Generally, my father was a different man for his epoch.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann323" ANNOTATION_REF="ann321_flexid_8eaeb528-ce16-441b-9c6b-649a5f1e31aa">
                <ANNOTATION_VALUE>He moved a lot; he changed many homes.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann458" ANNOTATION_REF="ann456_flexid_40cc3e9b-4487-4fe9-8842-b50d94de152b">
                <ANNOTATION_VALUE>Well, it is a shame to say that but he changed many homes; however, he was educated. He was smart and spoke well.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann715" ANNOTATION_REF="ann713_flexid_6fb98680-86a1-4c43-911d-66094db3728d">
                <ANNOTATION_VALUE>He moved to the city to live there.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann791" ANNOTATION_REF="ann789_flexid_1558ef45-e6b3-461e-aa6d-6c6bca245127">
                <ANNOTATION_VALUE>I was little. It was in 1932.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann896" ANNOTATION_REF="ann894_flexid_351d78ca-a8f8-4b30-9086-9dbcbb18afdc">
                <ANNOTATION_VALUE>My father was sick.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann966" ANNOTATION_REF="ann964_flexid_97e1cdaa-aefb-43e0-8393-1f38c248a66c">
                <ANNOTATION_VALUE>Wherever he went, we followed. What could we do? We were informed that grandfather died, great grandfather.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1233" ANNOTATION_REF="ann1231_flexid_0be4f817-9d8b-4803-9a6c-c33e421fe355">
                <ANNOTATION_VALUE>And, what did we travel by?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1298" ANNOTATION_REF="ann1296_flexid_98cd8b6b-3142-43d6-b663-3c7d4db6dd3b">
                <ANNOTATION_VALUE>My father was riding a horse. I have a younger brother. He was carrying him, and we: I, my mother and my elder borther were following him.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1660" ANNOTATION_REF="ann1658_flexid_b5ca9c2c-a697-45b0-912f-eac1ebfd6ef4">
                <ANNOTATION_VALUE>We passed twenty kilometers. It is like a tale; that is why I am telling it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1775" ANNOTATION_REF="ann1773_flexid_bdc66dbc-d57c-4418-93e3-64530ef7b69e">
                <ANNOTATION_VALUE>We passed twenty kilometers and came to grandfather's house.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann1920" ANNOTATION_REF="ann1918_flexid_ab2c80d6-eb36-4886-8042-f87d8728e2a1">
                <ANNOTATION_VALUE>Grandfather didn't lay in the oda house. A big bench ws placed in the middle of the kitchem, and grandfather lay there</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2211" ANNOTATION_REF="ann2209_flexid_b57b55ce-7093-4a14-a080-4b0657257b66">
                <ANNOTATION_VALUE>Well, I didn't enter.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2297" ANNOTATION_REF="ann2295_flexid_a56872e2-0452-4aa0-a09e-d0ed688c6e51">
                <ANNOTATION_VALUE>I haven never seen a dead. Can you imagine?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2445" ANNOTATION_REF="ann2443_flexid_aec293f3-ad13-4d6d-8b69-5019c4c53700">
                <ANNOTATION_VALUE>And, I and my younger cousin looked at him. He was a little bit younger than me.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2631" ANNOTATION_REF="ann2629_flexid_4cec7cca-152f-4420-9437-5f0e3b0119f4">
                <ANNOTATION_VALUE>When we looked at him, we saw that grandfather's nose was raised too high.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2783" ANNOTATION_REF="ann2781_flexid_ed89446f-a793-4c7d-ad7f-f8757a51fbb8">
                <ANNOTATION_VALUE>We saw that and burst into laughter.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann2903" ANNOTATION_REF="ann2901_flexid_fe7a73cc-c26a-4c24-a848-e7f4dc979c84">
                <ANNOTATION_VALUE>I couldn't stop it until we went to the hazelnut grove.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3059" ANNOTATION_REF="ann3057_flexid_5bb9ae55-74f7-4d15-87fc-ae23efc8bb67">
                <ANNOTATION_VALUE>I still laugh.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3141" ANNOTATION_REF="ann3139_flexid_747dc298-5f9a-4dd3-8253-d6211f895b94">
                <ANNOTATION_VALUE>This is one.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3163" ANNOTATION_REF="ann3161_flexid_87383622-2cdf-47a3-a9dd-89640bbe9204">
                <ANNOTATION_VALUE>There was another.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3212" ANNOTATION_REF="ann3210_flexid_462af70a-c948-45ef-bffe-cd6dcfcbac41">
                <ANNOTATION_VALUE>Another one is that I and my cousin; do you know what 'gele' is?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3397" ANNOTATION_REF="ann3395_flexid_f95057c0-efcc-4838-98ac-2af386e6656e">
                <ANNOTATION_VALUE>Yes, I do.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3413" ANNOTATION_REF="ann3411_flexid_d86e8a40-f1da-4b32-8000-9aa1cd141498">
                <ANNOTATION_VALUE>Do you know what it is?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3470" ANNOTATION_REF="ann3468_flexid_25bb5fc4-f954-46aa-a411-88fbb37c31e8">
                <ANNOTATION_VALUE>A small river.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3505" ANNOTATION_REF="ann3503_flexid_5052badc-fb61-42de-81af-ffb6f170da79">
                <ANNOTATION_VALUE>Yeah, the riverr was dammed up, sometimes muddy, sometimes somethings, and it was along the road.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3639" ANNOTATION_REF="ann3637_flexid_dd14fa9a-90a5-4bdb-91e5-0630e396bdf1">
                <ANNOTATION_VALUE>We were little; however, I don't remember whether we went to school or not.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3825" ANNOTATION_REF="ann3823_flexid_1acb73fc-1c01-4536-bcf4-198e9bd4ad9f">
                <ANNOTATION_VALUE>And, we caught a turtle and went into the river.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann3953" ANNOTATION_REF="ann3951_flexid_11de9384-3824-4e01-a825-a3e7901bfd17">
                <ANNOTATION_VALUE>I put it on my lap, took towards the road, putting stones around it. I wanted to catch another one.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4199" ANNOTATION_REF="ann4197_flexid_0cd758bf-dd67-424c-8c37-ee30d5992957">
                <ANNOTATION_VALUE>Nobody know what I want them for.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4289" ANNOTATION_REF="ann4287_flexid_f112000c-c684-4f7a-b9a8-4eaba7e0ec6e">
                <ANNOTATION_VALUE>And, when I came back, the former one was no longer there; it escaped.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4402" ANNOTATION_REF="ann4400_flexid_ad57ef0d-6774-405a-a8b1-86b6f670c6f8">
                <ANNOTATION_VALUE>Finally, I was there. I took another turtle, which I caught, and went home.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4649" ANNOTATION_REF="ann4647_flexid_bd7ce363-ec5f-4004-8cde-532da8235c49">
                <ANNOTATION_VALUE>I didn't know where to take it.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4664" ANNOTATION_REF="ann4662_flexid_8769ed17-f9a3-4868-8b6d-6b9d0e8c71e9">
                <ANNOTATION_VALUE>Neither to my nor to other people's yeard... Everybody has their "oncha" in their yeards.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4786" ANNOTATION_REF="ann4784_flexid_9fabf829-e640-42e1-af89-8cc16ffebc3d">
                <ANNOTATION_VALUE>Do you know what "oncha" is?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4854" ANNOTATION_REF="ann4852_flexid_c1859678-90ba-45fa-8253-683167edfaac">
                <ANNOTATION_VALUE>A well, isn't it?</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4884" ANNOTATION_REF="ann4882_flexid_21fe0f7e-cbe4-4f77-bb44-c99685f47641">
                <ANNOTATION_VALUE>A well.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4905" ANNOTATION_REF="ann4903_flexid_909eff7c-2e01-4b1f-b950-f26cfbed5b62">
                <ANNOTATION_VALUE>To get water from.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4940" ANNOTATION_REF="ann4938_flexid_4daf2e3a-81c6-40b8-842f-c4c569c7b209">
                <ANNOTATION_VALUE>The Megrelian for it is "oncha".</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann4976" ANNOTATION_REF="ann4974_flexid_b5f66d16-57b3-48de-87b9-6cd2123f0450">
                <ANNOTATION_VALUE>We all had a well. What to do with the turtle? I put it into the well.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5218" ANNOTATION_REF="ann5216_flexid_8f074cf7-8cac-4c1b-a143-bf161130326f">
                <ANNOTATION_VALUE>I dropped it into it. It was deep. Alas, how did I do that?!</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5369" ANNOTATION_REF="ann5367_flexid_b4fbac52-a0ea-4cee-9d67-3e6dcb15da79">
                <ANNOTATION_VALUE>My grandfather. No one and, paticularly my grandfather used to beat me. That wasn't true.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5593" ANNOTATION_REF="ann5591_flexid_0dcb555b-02f9-4ba0-9875-96bda55fb59e">
                <ANNOTATION_VALUE>My grandfather took me a hazelnut twig and beat me brutally, and I ran away to the hazelnut grove.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann5791" ANNOTATION_REF="ann5789_flexid_a025c739-ad2b-4ac2-bdf1-a064edf452aa">
                <ANNOTATION_VALUE>I left the hazelnut grove in the evening. Then, my grandfather caught me and hugged me; he said: "You do know what you did." So many years passed and I have not forgotten that lesson.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6161" ANNOTATION_REF="ann6159_flexid_e7d1ef12-de34-4b86-9eb4-34710726dd4f">
                <ANNOTATION_VALUE>That is the story. There were so many fabulous ones; however, it is impossible to tell all of them.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6360" ANNOTATION_REF="ann6358_flexid_84b58f3c-59a1-4095-bbbc-2de54dbf2eb7">
                <ANNOTATION_VALUE>Life can show one a lot.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6479" ANNOTATION_REF="ann6477_flexid_4faa98ff-08b7-4d3a-8f02-c0ac447312f2">
                <ANNOTATION_VALUE>Many years leave  dissaponitments and traces.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6614" ANNOTATION_REF="ann6612_flexid_a0b5466a-409d-4e07-b72d-9b66aec90367">
                <ANNOTATION_VALUE>Many years passed and a lot happened.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
    </TIER>
    <TIER LANG_REF="ka-Brai" LINGUISTIC_TYPE_REF="phrase-item"
        PARENT_REF="A_phrase-txt-xmf" TIER_ID="A_phrase-gls-ka-Brai">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann6" ANNOTATION_REF="ann3_flexid_4d72b049-e289-4426-90b8-53b2cd0abe0d">
                <ANNOTATION_VALUE>ეს რაღაც  პატარა ზღაპარივით არის ეს.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann81" ANNOTATION_REF="ann78_flexid_cc04c21a-6f4b-44ad-9935-257aadcc9886">
                <ANNOTATION_VALUE>ის დიდი ბაბუა ხომ იყო [=ხომ მყავდა], დიდი ბაბუა.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann195" ANNOTATION_REF="ann192_flexid_2977ba3b-a22f-400f-87ca-826828d6e004">
                <ANNOTATION_VALUE>საერთოდ მამაჩემი სხვანაირი კაცი იყო  იმ დროისთვის.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann324" ANNOTATION_REF="ann321_flexid_8eaeb528-ce16-441b-9c6b-649a5f1e31aa">
                <ANNOTATION_VALUE>მოძრავი რომ იყო, ეგეტი და ბერვი სახლი აქვს გამოცვლილი [=საცხოვრებელ ადგილს იცვლიდა],</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann459" ANNOTATION_REF="ann456_flexid_40cc3e9b-4487-4fe9-8842-b50d94de152b">
                <ANNOTATION_VALUE>ახლა სირცხვილია რომ თქვა, მაგრამ  ისე  ბევრი [სახლი გამოიცვალა],მაგრამ განათლება  ჰქონდა, ჭკვიანი და საუკეთესო მოლაპარაკე [კაცი] იყო</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann716" ANNOTATION_REF="ann713_flexid_6fb98680-86a1-4c43-911d-66094db3728d">
                <ANNOTATION_VALUE>ქალაქში წავედით საცხოვრებლად.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann792" ANNOTATION_REF="ann789_flexid_1558ef45-e6b3-461e-aa6d-6c6bca245127">
                <ANNOTATION_VALUE>პატარა ვიყავი, ეს არის [ათას ცხრაას] ოცდათორმეტი [წელი]</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann897" ANNOTATION_REF="ann894_flexid_351d78ca-a8f8-4b30-9086-9dbcbb18afdc">
                <ANNOTATION_VALUE>ავად არის მამაჩემი.</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="ann967" ANNOTATION_REF="ann964_flexid_97e1cdaa-aefb-43e0-8393-1f38c248a66c">
