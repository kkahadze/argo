                ANNOTATION_ID="ann713_flexid_6fb98680-86a1-4c43-911d-66094db3728d"
                TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts13">
                <ANNOTATION_VALUE>ოდო ქალაქშა მიდაფთით ოცხოვრებშა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann789_flexid_1558ef45-e6b3-461e-aa6d-6c6bca245127"
                TIME_SLOT_REF1="ts14" TIME_SLOT_REF2="ts15">
                <ANNOTATION_VALUE>ჭიჭე ვორდი, თენა რე ეჟდოვითოჟირი.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann894_flexid_351d78ca-a8f8-4b30-9086-9dbcbb18afdc"
                TIME_SLOT_REF1="ts16" TIME_SLOT_REF2="ts17">
                <ANNOTATION_VALUE>ლეხი რე ჩქიმ მუმა.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann964_flexid_97e1cdaa-aefb-43e0-8393-1f38c248a66c"
                TIME_SLOT_REF1="ts18" TIME_SLOT_REF2="ts20">
                <ANNOTATION_VALUE>სოდე მეურს უნჩაშინ, თექ ოკოპუნთ ჩქი, აბა მუ ფქიმჷნათ დო ქიშმოტყვინეს, ბაბუქ დოღურუა, დიდ ბაბუქ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1231_flexid_0be4f817-9d8b-4803-9a6c-c33e421fe355"
                TIME_SLOT_REF1="ts21" TIME_SLOT_REF2="ts22">
                <ANNOTATION_VALUE>დო მალაფთით, მუუთ?</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1296_flexid_98cd8b6b-3142-43d6-b663-3c7d4db6dd3b"
                TIME_SLOT_REF1="ts23" TIME_SLOT_REF2="ts24">
                <ANNOTATION_VALUE>ჩქიმ მუმა ცხენც გეხე, ჭიჭე ჯიმა მიჸუნცუ, სუმ წანერინ, ათაქ უკებ დო ჩქიი, მა, ჩქიმ დიდა დო უნჩაშ ინა, კუჩხით ეკოფთხოზუთუ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1658_flexid_b5ca9c2c-a697-45b0-912f-eac1ebfd6ef4"
                TIME_SLOT_REF1="ts25" TIME_SLOT_REF2="ts26">
                <ANNOTATION_VALUE>ეეჩი კილომეტრი,  ეს ზღაპარივით რე, თიშენ გირაგადუქ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION
                ANNOTATION_ID="ann1773_flexid_bdc66dbc-d57c-4418-93e3-64530ef7b69e"
                TIME_SLOT_REF1="ts27" TIME_SLOT_REF2="ts28">
