                ANNOTATION_ID="ann1918_flexid_ab2c80d6-eb36-4886-8042-f87d8728e2a1"
                TIME_SLOT_REF1="ts29" TIME_SLOT_REF2="ts30">
                <ANNOTATION_VALUE>ათე ბაბუ, ექ ოდას ჸუდეს ვარჷნ, ეთი ქუხნას დიდ ინა, შქა დიხასჷ ქუდუდგუმნა ინა დო ბაბჷ გილაჯან თაქ.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
