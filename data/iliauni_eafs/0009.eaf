                ANNOTATION_ID="ann456_flexid_40cc3e9b-4487-4fe9-8842-b50d94de152b"
                TIME_SLOT_REF1="ts10" TIME_SLOT_REF2="ts11">
                <ANNOTATION_VALUE>ასე ონჯღორე რე თქუენ, მარა - ბრელი ეშ განათლება უღუდ, ჭკვერი დუ დო მორაგადეთ - ირკოჩიშ უჯგუში.</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
